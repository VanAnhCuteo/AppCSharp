<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A1A2E">

    <ScrollView VerticalOptions="Center">
        <VerticalStackLayout Spacing="0" Padding="28,40">

            <!-- Title -->
            <Label x:Name="TitleLabel"
                   TextColor="White" FontSize="30" FontAttributes="Bold"
                   HorizontalOptions="Center" Margin="0,0,0,6"/>
            <Label x:Name="SubtitleLabel"
                   TextColor="#9090AA" FontSize="14"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   Margin="0,0,0,32"/>

            <!-- Form Card -->
            <Frame BackgroundColor="#252540" CornerRadius="24" Padding="24" HasShadow="False">
                <VerticalStackLayout Spacing="18">

                    <!-- Username -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="UsernameLbl" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FF6A88"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="UsernameEntry"
                                       TextColor="White" BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="EmailLbl" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FFAD9F"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="EmailEntry"
                                       Placeholder="yourname@gmail.com"
                                       TextColor="White" BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       Keyboard="Email"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="PasswordLbl" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FF6A88"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="PasswordEntry"
                                       Placeholder="••••••••" IsPassword="True"
                                       TextColor="White" BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="ConfirmPasswordLbl" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FFAD9F"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="ConfirmPasswordEntry"
                                       Placeholder="••••••••" IsPassword="True"
                                       TextColor="White" BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button x:Name="RegisterButton"
                            Clicked="OnRegisterClicked"
                            TextColor="White"
                            FontAttributes="Bold" FontSize="17"
                            CornerRadius="16" HeightRequest="56"
                            Margin="0,10,0,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF6A88" Offset="0.0"/>
                                <GradientStop Color="#FFAD9F" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                </VerticalStackLayout>
            </Frame>

            <!-- Login Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,24,0,0">
                <Label x:Name="HaveAccountLabel" TextColor="#9090AA" FontSize="14"/>
                <Label x:Name="LoginNowLabel" TextColor="#FF6A88"
                       FontAttributes="Bold" FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                               Color="#FF6A88" HorizontalOptions="Center"
                               Margin="0,16,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
