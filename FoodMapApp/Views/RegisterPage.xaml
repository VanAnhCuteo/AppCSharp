<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

	<Grid>
		<BoxView>
			<BoxView.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#FF9A8B" Offset="0.1" />
					<GradientStop Color="#FF6A88" Offset="0.5" />
					<GradientStop Color="#FF99AC" Offset="0.9" />
				</LinearGradientBrush>
			</BoxView.Background>
		</BoxView>

		<ScrollView VerticalOptions="Center">
			<VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

				<Label x:Name="TitleLabel"
                       TextColor="White" FontSize="30" FontAttributes="Bold" HorizontalOptions="Center"/>

				<Label x:Name="SubtitleLabel"
                       TextColor="White" FontSize="14" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" Opacity="0.9"/>

				<Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
					<VerticalStackLayout Spacing="15">

						<Label x:Name="UsernameLbl" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="UsernameEntry"
                               TextColor="Black" BackgroundColor="#F5F5F5" HeightRequest="45"
                               IsTextPredictionEnabled="False" IsSpellCheckEnabled="False"/>

						<Label x:Name="EmailLbl" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="EmailEntry" Placeholder="yourname@gmail.com"
                               TextColor="Black" BackgroundColor="#F5F5F5"
                               HeightRequest="45" Keyboard="Email"
                               IsTextPredictionEnabled="False" IsSpellCheckEnabled="False"/>

						<Label x:Name="PasswordLbl" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="PasswordEntry" Placeholder="********"
                               IsPassword="True" TextColor="Black"
                               BackgroundColor="#F5F5F5" HeightRequest="45"
                               IsTextPredictionEnabled="False" IsSpellCheckEnabled="False"/>

						<Label x:Name="ConfirmPasswordLbl" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="ConfirmPasswordEntry" Placeholder="********"
                               IsPassword="True" TextColor="Black"
                               BackgroundColor="#F5F5F5" HeightRequest="45"
                               IsTextPredictionEnabled="False" IsSpellCheckEnabled="False"/>

						<Button x:Name="RegisterButton"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="#FF6A88" TextColor="White"
                                FontAttributes="Bold" FontSize="18"
                                CornerRadius="12" HeightRequest="55" Margin="0,15,0,0"/>

					</VerticalStackLayout>
				</Frame>

				<HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
					<Label x:Name="HaveAccountLabel" TextColor="White" Opacity="0.9"/>
					<Label x:Name="LoginNowLabel" TextColor="White" FontAttributes="Bold" TextDecorations="Underline">
						<Label.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnLoginTapped" />
						</Label.GestureRecognizers>
					</Label>
				</HorizontalStackLayout>

				<ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="White" HorizontalOptions="Center" />
			</VerticalStackLayout>
		</ScrollView>
	</Grid>
</ContentPage>
