<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Background Gradient (Same as Login for consistency) -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF9A8B" Offset="0.1" />
                    <GradientStop Color="#FF6A88" Offset="0.5" />
                    <GradientStop Color="#FF99AC" Offset="0.9" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

                <Label Text="Join the FoodTour"
                       TextColor="White"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="Create an account to browse restaurants in Bui Vien."
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Opacity="0.8"/>

                <!-- Register Card -->
                <Frame BackgroundColor="White" 
                       CornerRadius="20" 
                       Padding="20" 
                       HasShadow="True">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="Username" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="UsernameEntry" 
                               Placeholder="Choose a username" 
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="45"/>

                        <Label Text="Email Address" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="EmailEntry" 
                               Placeholder="yourname@gmail.com" 
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="45"
                               Keyboard="Email"/>

                        <Label Text="Password" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="PasswordEntry" 
                               Placeholder="********" 
                               IsPassword="True"
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="45"/>

                        <Label Text="Confirm Password" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="ConfirmPasswordEntry" 
                               Placeholder="********" 
                               IsPassword="True"
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="45"/>

                        <Button Text="REGISTER"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="#FF6A88"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="18"
                                CornerRadius="12"
                                HeightRequest="55"
                                Margin="0,15,0,0"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Already have an account?" TextColor="White" Opacity="0.9"/>
                    <Label Text="Login" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="False" 
                                   Color="White" 
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
