<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFF7F8">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto" MinimumHeightRequest="800" Padding="0">

            <!-- ── Top Gradient Banner ── -->
            <Grid Grid.Row="0" MinimumHeightRequest="260" Padding="0,0,0,65">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF6B81" Offset="0.0"/>
                        <GradientStop Color="#FF9A76" Offset="0.5"/>
                        <GradientStop Color="#FFB8A6" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <!-- Decorative circles -->
                <Ellipse WidthRequest="240" HeightRequest="240"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-60,-60,0" Opacity="0.10">
                    <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                </Ellipse>
                <Ellipse WidthRequest="100" HeightRequest="100"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="-20,0,0,30" Opacity="0.06">
                    <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                </Ellipse>

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="10" Margin="0,15,0,0">
                    <!-- Register icon -->
                    <Grid HorizontalOptions="Center">
                        <Ellipse WidthRequest="80" HeightRequest="80"
                                 HorizontalOptions="Center" Opacity="0.18">
                            <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                        </Ellipse>
                        <Border WidthRequest="60" HeightRequest="60" 
                                Padding="0" StrokeThickness="0"
                                BackgroundColor="White"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="30"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,3" Opacity="0.2" Radius="10"/>
                            </Border.Shadow>
                            <Path Data="M15,12 C17.21,12 19,10.21 19,8 C19,5.79 17.21,4 15,4 C12.79,4 11,5.79 11,8 C11,10.21 12.79,12 15,12 M6,10 L6,7 L4,7 L4,10 L1,10 L1,12 L4,12 L4,15 L6,15 L6,12 L9,12 L9,10 L6,10 M15,14 C12.33,14 7,15.34 7,18 L7,20 L23,20 L23,18 C23,15.34 17.67,14 15,14 Z"
                                  Fill="#FF6B81" Aspect="Uniform" WidthRequest="28" HeightRequest="28"
                                  HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                    <Label x:Name="TitleLabel" Text="Tạo tài khoản" FontSize="28" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" CharacterSpacing="0.8"/>
                    <Label x:Name="SubtitleLabel" Text="Tham gia cộng đồng FoodMap" FontSize="14" TextColor="White"
                           Opacity="0.92" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── Form Card ── -->
            <Grid Grid.Row="1" Margin="22,-50,22,0">
                <Border BackgroundColor="White" Padding="28,32"
                        StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="32"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#FF6B81" Offset="0,16" Opacity="0.12" Radius="32"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="18">

                        <!-- Username -->
                        <VerticalStackLayout Spacing="7">
                            <Label x:Name="UsernameLbl" Text="Tên người dùng" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A2E" Margin="4,0"/>
                            <Border BackgroundColor="#FFF7F8" Padding="0"
                                    StrokeThickness="0" HeightRequest="58">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                            BackgroundColor="#FFECEF" StrokeThickness="0"
                                            VerticalOptions="Center" Margin="8,0,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <Path Data="M12,12 C14.21,12 16,10.21 16,8 C16,5.79 14.21,4 12,4 C9.79,4 8,5.79 8,8 C8,10.21 9.79,12 12,12 M12,14 C9.33,14 4,15.34 4,18 L4,20 L20,20 L20,18 C20,15.34 14.67,14 12,14 Z"
                                              Fill="#FF6B81" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                                              HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Entry Grid.Column="1" x:Name="UsernameEntry"
                                           Placeholder="Tên hiển thị"
                                           TextColor="#1A1A2E" BackgroundColor="Transparent"
                                           PlaceholderColor="#B0A3AB" Margin="12,0,16,0"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="7">
                            <Label x:Name="EmailLbl" Text="Email" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A2E" Margin="4,0"/>
                            <Border BackgroundColor="#FFF7F8" Padding="0"
                                    StrokeThickness="0" HeightRequest="58">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                            BackgroundColor="#FFF0E8" StrokeThickness="0"
                                            VerticalOptions="Center" Margin="8,0,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <Path Data="M20,4 L4,4 C2.9,4 2.01,4.9 2.01,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 M20,8 L12,13 L4,8 L4,6 L12,11 L20,6 L20,8 Z"
                                              Fill="#FF9A76" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                                              HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Entry Grid.Column="1" x:Name="EmailEntry"
                                           Placeholder="yourname@gmail.com" Keyboard="Email"
                                           TextColor="#1A1A2E" BackgroundColor="Transparent"
                                           PlaceholderColor="#B0A3AB" Margin="12,0,16,0"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="7">
                            <Label x:Name="PasswordLbl" Text="Mật khẩu" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A2E" Margin="4,0"/>
                            <Border BackgroundColor="#FFF7F8" Padding="0"
                                    StrokeThickness="0" HeightRequest="58">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                            BackgroundColor="#FFECEF" StrokeThickness="0"
                                            VerticalOptions="Center" Margin="8,0,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <Path Data="M18,8 L17,8 L17,6 C17,3.24 14.76,1 12,1 C9.24,1 7,3.24 7,6 L7,8 L6,8 C4.9,8 4,8.9 4,10 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,10 C20,8.9 19.1,8 18,8 M9,6 C9,4.34 10.34,3 12,3 C13.66,3 15,4.34 15,6 L15,8 L9,8 L9,6 M12,17 C10.9,17 10,16.1 10,15 C10,13.9 10.9,13 12,17 Z"
                                              Fill="#FF6B81" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                                              HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Entry Grid.Column="1" x:Name="PasswordEntry"
                                           Placeholder="••••••••" IsPassword="True"
                                           TextColor="#1A1A2E" BackgroundColor="Transparent"
                                           PlaceholderColor="#B0A3AB" Margin="12,0,16,0"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="7">
                            <Label x:Name="ConfirmPasswordLbl" Text="Xác nhận mật khẩu" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A2E" Margin="4,0"/>
                            <Border BackgroundColor="#FFF7F8" Padding="0"
                                    StrokeThickness="0" HeightRequest="58">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                            BackgroundColor="#FFF0E8" StrokeThickness="0"
                                            VerticalOptions="Center" Margin="8,0,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                        <Path Data="M18,8 L17,8 L17,6 C17,3.24 14.76,1 12,1 C9.24,1 7,3.24 7,6 L7,8 L6,8 C4.9,8 4,8.9 4,10 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,10 C20,8.9 19.1,8 18,8 M9,6 C9,4.34 10.34,3 12,3 C13.66,3 15,4.34 15,6 L15,8 L9,8 L9,6 M12,17 C10.9,17 10,16.1 10,15 C10,13.9 10.9,13 12,17 Z"
                                              Fill="#FF9A76" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                                              HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Entry Grid.Column="1" x:Name="ConfirmPasswordEntry"
                                           Placeholder="••••••••" IsPassword="True"
                                           TextColor="#1A1A2E" BackgroundColor="Transparent"
                                           PlaceholderColor="#B0A3AB" Margin="12,0,16,0"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Register Button -->
                        <Button x:Name="RegisterButton" Text="Đăng ký" Clicked="OnRegisterClicked"
                                TextColor="White" FontAttributes="Bold" FontSize="16"
                                CornerRadius="22" HeightRequest="64"
                                Margin="0,10,0,0" BorderWidth="0"
                                CharacterSpacing="0.5">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF6B81" Offset="0.0"/>
                                    <GradientStop Color="#FF8A70" Offset="0.7"/>
                                    <GradientStop Color="#FF9A76" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,10" Opacity="0.35" Radius="20"/>
                            </Button.Shadow>
                        </Button>

                        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                                           Color="#FF6B81" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Login link -->
            <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center"
                                   Spacing="6" Margin="0,30,0,44">
                <Label x:Name="HaveAccountLabel" Text="Đã có tài khoản?" TextColor="#6C6C80" FontSize="14"/>
                <Label x:Name="LoginNowLabel" Text="Đăng nhập" TextColor="#FF6B81"
                       FontAttributes="Bold" FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
