<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.ShopQRListPage"
             Title="Danh sách quán ăn"
             BackgroundColor="#FFF7F8">
    
    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,48,24,20">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6B81" Offset="0.0"/>
                    <GradientStop Color="#FF9A76" Offset="0.6"/>
                    <GradientStop Color="#FFB8A6" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <!-- Decorative -->
            <Ellipse WidthRequest="140" HeightRequest="140"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-40,-30,0" Opacity="0.08">
                <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
            </Ellipse>
            <VerticalStackLayout Spacing="5">
                <Label x:Name="InstructionsTitleLabel"
                       Text="Chọn quán để xem mã QR" 
                       FontSize="20" FontAttributes="Bold" 
                       TextColor="White" CharacterSpacing="0.3"/>
                <Label x:Name="InstructionsSubTitleLabel"
                       Text="Mã QR giúp bạn nhận diện quán nhanh chóng" 
                       FontSize="13" TextColor="White" Opacity="0.9"/>
            </VerticalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" x:Name="shopsCollection"
                        Margin="14,14,14,0"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="14" StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.08" Radius="12"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShopTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="64" HeightRequest="64"
                                    StrokeThickness="0" Padding="0" Margin="0,0,14,0"
                                    BackgroundColor="#FFF7F8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Image Source="{Binding image_url}" 
                                       Aspect="AspectFill" 
                                       HeightRequest="64" WidthRequest="64"/>
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                <Label Text="{Binding name}" 
                                       FontSize="16" FontAttributes="Bold" 
                                       TextColor="#1A1A2E" />
                                <Label Text="{Binding address}" 
                                       FontSize="13" TextColor="#6C6C80" 
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator x:Name="loadingIndicator" 
                           Grid.Row="1"
                           IsRunning="True" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           Color="#FF6B81" />
    </Grid>
</ContentPage>
