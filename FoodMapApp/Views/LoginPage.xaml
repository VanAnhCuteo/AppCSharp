<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFF7F8">

    <ScrollView VerticalOptions="FillAndExpand">
        <Grid RowDefinitions="Auto,*,Auto" MinimumHeightRequest="700" Padding="0">

            <!-- ── Top Gradient Banner ── -->
            <Grid Grid.Row="0" MinimumHeightRequest="300" Padding="0,0,0,65">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF6B81" Offset="0.0"/>
                        <GradientStop Color="#FF9A76" Offset="0.5"/>
                        <GradientStop Color="#FFB8A6" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Top Left QR Icon for Scanner -->
                <Border HorizontalOptions="Start" VerticalOptions="Start" 
                        WidthRequest="42" HeightRequest="42"
                        Margin="20,50,0,0" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="21"/></Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="#33FFFFFF"/>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnQrScanClicked" />
                    </Border.GestureRecognizers>
                    <Path Data="M2,2H8V8H2V2 M4,4H6V6H4V4 M14,2H20V8H14V2 M16,4H18V6H16V4 M2,14H8V20H2V14 M4,16H6V18H4V16 M14,14H16V16H14V14 M18,14H20V16H18V14 M14,18H16V20H14V18 M18,18H20V20H18V18 M10,2H12V4H10V2 M10,6H12V8H10V6 M10,10H12V12H10V10 M10,14H12V16H10V14 M10,18H12V20H10V18 M2,10H4V12H2V10 M6,10H8V12H6V10 M14,10H16V12H14V10 M18,10H20V12H18V10"
                          Fill="White" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Top Right Language Selector with Sliding Bubble -->
                <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Start" 
                                       Margin="0,50,20,0" Spacing="4">
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageClicked" />
                    </HorizontalStackLayout.GestureRecognizers>

                    <!-- Sliding Bubble (Pill) -->
                    <Border x:Name="LangBubble" 
                            WidthRequest="48" HeightRequest="32"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            TranslationX="20" Opacity="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Background>
                            <SolidColorBrush Color="#44FFFFFF"/>
                        </Border.Background>
                        <Label x:Name="LangCodeLabel" 
                               Text="VN" 
                               TextColor="White" 
                               FontSize="13" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Globe Icon -->
                    <Border WidthRequest="42" HeightRequest="42"
                            StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="21"/></Border.StrokeShape>
                        <Border.Background>
                            <SolidColorBrush Color="#33FFFFFF"/>
                        </Border.Background>
                        <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2 0 .68.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.91-4.33-3.56zm2.95-8H5.08c.96-1.65 2.49-2.93 4.33-3.56-.6 1.11-1.06 2.31-1.38 3.56zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2 0-.68.07-1.35.16-2h4.68c.09.65.16 1.32.16 2 0 .68-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2 0-.68-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"
                              Fill="White" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                              HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Decorative glow circles -->
                <Ellipse WidthRequest="260" HeightRequest="260"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-80,-70,0" Opacity="0.10">
                    <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                </Ellipse>
                <Ellipse WidthRequest="140" HeightRequest="140"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="-40,0,0,20" Opacity="0.07">
                    <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                </Ellipse>
                <Ellipse WidthRequest="80" HeightRequest="80"
                         HorizontalOptions="Center" VerticalOptions="Start"
                         Margin="60,20,0,0" Opacity="0.06">
                    <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                </Ellipse>

                <!-- Logo + App name -->
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="14" Margin="0,25,0,0">
                    <!-- Logo Circle with Vector Icon -->
                    <Grid HorizontalOptions="Center">
                        <!-- Outer glow ring -->
                        <Ellipse WidthRequest="110" HeightRequest="110"
                                 HorizontalOptions="Center" Opacity="0.15">
                            <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                        </Ellipse>
                        <!-- Middle glow ring -->
                        <Ellipse WidthRequest="96" HeightRequest="96"
                                 HorizontalOptions="Center" Opacity="0.20">
                            <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                        </Ellipse>
                        <Border WidthRequest="78" HeightRequest="78" 
                                Padding="0" StrokeThickness="0"
                                BackgroundColor="White"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="39"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.25" Radius="12"/>
                            </Border.Shadow>
                               <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 M11,19.92 C6.08,19.43 2.57,15.68 3.12,10.91 L8.52,16.31 L11,16.31 L11,19.92 M18.4,15.82 L16.36,13.78 L14.94,15.19 L16.98,17.23 A8.053,8.053 0 0 1 13,19.9 L13,17 L10,14 L10,12.78 L20.47,2.31 C21.14,3.22 21.65,4.28 21.92,5.41 L14.1,13.23 L15.51,14.64 L21.71,8.44 A8.026,8.026 0 0 1 18.4,15.82 Z"
                                     Fill="#FF6B81" 
                                     Aspect="Uniform"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     WidthRequest="34" HeightRequest="34"/>
                        </Border>
                    </Grid>
                    <Label x:Name="AppTitleLabel" Text="FoodMap" FontSize="32" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" CharacterSpacing="1"/>
                    <Label x:Name="WelcomeLabel" Text="Khám phá ẩm thực quanh bạn" FontSize="14" TextColor="White"
                           Opacity="0.92" HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── Form Card (overlaps banner) ── -->
            <Grid Grid.Row="1" Margin="22,-50,22,0">
                <Border BackgroundColor="White" Padding="28,36"
                        StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="32"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#FF6B81" Offset="0,16" Opacity="0.12" Radius="32"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="22">

                        <!-- Guest Button -->
                        <Button x:Name="QrScanButton" Text="Tài khoản khách" Clicked="OnGuestClicked"
                                TextColor="White" FontAttributes="Bold" FontSize="16"
                                CornerRadius="22" HeightRequest="64"
                                Margin="0,4,0,0" BorderWidth="0" CharacterSpacing="1">
                             <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6C5CE7" Offset="0.0"/>
                                    <GradientStop Color="#A29BFE" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Shadow>
                                <Shadow Brush="#6C5CE7" Offset="0,6" Opacity="0.25" Radius="12"/>
                            </Button.Shadow>
                        </Button>

                        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                                           Color="#FF6B81" HorizontalOptions="Center"/>

                        <!-- OR Separator -->
                        <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,4">
                            <BoxView Grid.Column="0" HeightRequest="1" Color="#F0E8EC" VerticalOptions="Center"/>
                            <Label x:Name="OrLabel" Grid.Column="1" Text="HOẶC" FontSize="11" TextColor="#B0A3AB" Margin="14,0"
                                   VerticalOptions="Center" CharacterSpacing="1.5"/>
                            <BoxView Grid.Column="2" HeightRequest="1" Color="#F0E8EC" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Offline Button -->
                        <Button x:Name="OfflineButton" Text="ĐĂNG NHẬP OFFLINE" Clicked="OnOfflineClicked"
                                TextColor="#FF6B81" FontAttributes="Bold" FontSize="14"
                                CornerRadius="22" HeightRequest="60"
                                BackgroundColor="#FFF0F3" BorderColor="Transparent"
                                BorderWidth="0" CharacterSpacing="0.8">
                            <Button.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.08" Radius="12"/>
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Bottom spacer -->
            <BoxView Grid.Row="2" HeightRequest="44" Color="Transparent"/>

        </Grid>
    </ScrollView>
</ContentPage>
