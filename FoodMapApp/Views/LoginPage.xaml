<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Background Gradient -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF9A8B" Offset="0.1" />
                    <GradientStop Color="#FF6A88" Offset="0.5" />
                    <GradientStop Color="#FF99AC" Offset="0.9" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

                <!-- Logo / Title Section -->
                <Frame BackgroundColor="White" 
                       HeightRequest="100" 
                       WidthRequest="100" 
                       CornerRadius="50" 
                       Padding="0" 
                       HorizontalOptions="Center"
                       HasShadow="True">
                    <Label Text="&#x1F354;" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <Label Text="FoodTour Bui Vien"
                       TextColor="White"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <Label Text="Welcome back! Please login to continue."
                       TextColor="White"
                       FontSize="16"
                       HorizontalOptions="Center"
                       Opacity="0.8"/>

                <!-- Login Card -->
                <Frame BackgroundColor="White" 
                       CornerRadius="20" 
                       Padding="20" 
                       HasShadow="True">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="Username or Email" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="IdentifierEntry" 
                               Placeholder="Enter your username" 
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="50"
                               Keyboard="Email"/>

                        <Label Text="Password" TextColor="#666" FontSize="14" Margin="5,0"/>
                        <Entry x:Name="PasswordEntry" 
                               Placeholder="********" 
                               IsPassword="True"
                               TextColor="Black"
                               BackgroundColor="#F5F5F5"
                               HeightRequest="50"/>

                        <Button Text="LOGIN"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#FF6A88"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="18"
                                CornerRadius="12"
                                HeightRequest="55"
                                Margin="0,10,0,0"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Don't have an account?" TextColor="White" Opacity="0.9"/>
                    <Label Text="Register Now" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="False" 
                                   Color="White" 
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
