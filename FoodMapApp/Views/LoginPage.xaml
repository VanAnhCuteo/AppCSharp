<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

	<Grid>
		<BoxView>
			<BoxView.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#FF9A8B" Offset="0.1" />
					<GradientStop Color="#FF6A88" Offset="0.5" />
					<GradientStop Color="#FF99AC" Offset="0.9" />
				</LinearGradientBrush>
			</BoxView.Background>
		</BoxView>

		<ScrollView VerticalOptions="Center">
			<VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

				<Frame BackgroundColor="White" HeightRequest="100" WidthRequest="100"
                       CornerRadius="50" Padding="0" HorizontalOptions="Center" HasShadow="True">
					<Label x:Name="LogoLabel" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center" />
				</Frame>

				<Label x:Name="AppTitleLabel"
                       TextColor="White" FontSize="32" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,0,0,10"/>

				<Label x:Name="WelcomeLabel"
                       TextColor="White" FontSize="15" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" Opacity="0.9"/>

				<Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
					<VerticalStackLayout Spacing="15">

						<Label x:Name="IdentifierLabel" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="IdentifierEntry"
                               TextColor="Black" BackgroundColor="#F5F5F5"
                               HeightRequest="50" Keyboard="Email"
                               IsTextPredictionEnabled="False"
                               IsSpellCheckEnabled="False"/>

						<Label x:Name="PasswordLabel" TextColor="#666" FontSize="14" Margin="5,0"/>
						<Entry x:Name="PasswordEntry"
                               Placeholder="********"
                               IsPassword="True" TextColor="Black"
                               BackgroundColor="#F5F5F5" HeightRequest="50"
                               IsTextPredictionEnabled="False"
                               IsSpellCheckEnabled="False"/>

						<Button x:Name="LoginButton"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#FF6A88" TextColor="White"
                                FontAttributes="Bold" FontSize="18"
                                CornerRadius="12" HeightRequest="55" Margin="0,10,0,0"/>

					</VerticalStackLayout>
				</Frame>

				<HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
					<Label x:Name="NoAccountLabel" TextColor="White" Opacity="0.9"/>
					<Label x:Name="RegisterNowLabel" TextColor="White" FontAttributes="Bold" TextDecorations="Underline">
						<Label.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnRegisterTapped" />
						</Label.GestureRecognizers>
					</Label>
				</HorizontalStackLayout>

				<ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="White" HorizontalOptions="Center" />
			</VerticalStackLayout>
		</ScrollView>
	</Grid>
</ContentPage>
