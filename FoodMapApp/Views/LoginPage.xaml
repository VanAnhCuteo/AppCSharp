<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A1A2E">

    <ScrollView VerticalOptions="Center">
        <VerticalStackLayout Spacing="0" Padding="28,40">

            <!-- Logo -->
            <Grid HorizontalOptions="Center" Margin="0,0,0,32">
                <Ellipse WidthRequest="110" HeightRequest="110" HorizontalOptions="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                            <GradientStop Color="#4DFF6A88" Offset="0.0" />
                            <GradientStop Color="#00FF6A88" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Frame WidthRequest="88" HeightRequest="88" CornerRadius="44" Padding="0"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       BackgroundColor="#252540" HasShadow="False">
                    <Label x:Name="LogoLabel" FontSize="44"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
            </Grid>

            <!-- Title -->
            <Label x:Name="AppTitleLabel"
                   TextColor="White" FontSize="30" FontAttributes="Bold"
                   HorizontalOptions="Center" Margin="0,0,0,6"/>
            <Label x:Name="WelcomeLabel"
                   TextColor="#9090AA" FontSize="14"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   Margin="0,0,0,36"/>

            <!-- Form Card -->
            <Frame BackgroundColor="#252540" CornerRadius="24" Padding="24" HasShadow="False">
                <VerticalStackLayout Spacing="20">

                    <!-- Identifier -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="IdentifierLabel" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FF6A88"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="IdentifierEntry"
                                       TextColor="White" BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       Keyboard="Email"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="PasswordLabel" TextColor="#9090AA" FontSize="12"
                               FontAttributes="Bold" Margin="4,0"/>
                        <Frame BackgroundColor="#1E1E38" CornerRadius="14" Padding="0"
                               HasShadow="False" HeightRequest="52">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0" BackgroundColor="#FFAD9F"
                                         WidthRequest="4" CornerRadius="4"/>
                                <Entry Grid.Column="1" x:Name="PasswordEntry"
                                       Placeholder="••••••••"
                                       IsPassword="True" TextColor="White"
                                       BackgroundColor="Transparent"
                                       PlaceholderColor="#55557A" Margin="12,0"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Login Button -->
                    <Button x:Name="LoginButton"
                            Clicked="OnLoginClicked"
                            TextColor="White"
                            FontAttributes="Bold" FontSize="17"
                            CornerRadius="16" HeightRequest="56"
                            Margin="0,8,0,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF6A88" Offset="0.0"/>
                                <GradientStop Color="#FFAD9F" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                </VerticalStackLayout>
            </Frame>

            <!-- Register Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,24,0,0">
                <Label x:Name="NoAccountLabel" TextColor="#9090AA" FontSize="14"/>
                <Label x:Name="RegisterNowLabel" TextColor="#FF6A88"
                       FontAttributes="Bold" FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                               Color="#FF6A88" HorizontalOptions="Center"
                               Margin="0,16,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
