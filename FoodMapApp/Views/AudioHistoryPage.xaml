<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodMapApp.Models"
             x:Class="FoodMapApp.Views.AudioHistoryPage"
             Title="Lịch Sử Nghe Audio"
             BackgroundColor="#FFF7F8">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Grid Grid.Row="0" HeightRequest="60" Padding="15,0">
            <Label x:Name="HistoryTitleLabel"
                   Text="Lịch sử nghe Audio" 
                   TextColor="#FF6B81" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Center" />
            <ImageButton Source="back_icon.png" 
                         HeightRequest="24" 
                         WidthRequest="24" 
                         HorizontalOptions="Start" 
                         VerticalOptions="Center"
                         Clicked="OnBackClicked"/>
        </Grid>

        <RefreshView Grid.Row="1" x:Name="refreshView" Command="{Binding RefreshCommand}">
            <CollectionView x:Name="historyListView" Margin="15,10">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                        <Label x:Name="EmptyHistoryLabel"
                               Text="Bạn chưa nghe audio nào" 
                               TextColor="#999" 
                               FontSize="16" 
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AudioLogModel">
                        <Border Margin="0,0,0,15" Padding="12" BackgroundColor="White" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.08" Radius="10"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                <Border Grid.Column="0" WidthRequest="60" HeightRequest="60" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Image Source="{Binding poi_image_url}" Aspect="AspectFill" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding poi_name}" 
                                           TextColor="#333" 
                                           FontSize="16" 
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding DisplayDate}" 
                                           TextColor="#999" 
                                           FontSize="12" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2" BackgroundColor="#FFF0F3" Padding="10,4" VerticalOptions="Center" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="{Binding DisplayDuration}" 
                                           TextColor="#FF6B81" 
                                           FontSize="11" 
                                           FontAttributes="Bold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1" x:Name="loadingOverlay" BackgroundColor="#80FFFFFF" IsVisible="False">
            <ActivityIndicator IsRunning="True" Color="#FF6B81" VerticalOptions="Center" HorizontalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
