<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.QRViewerPage"
             Title="Mã QR của quán"
             BackgroundColor="#FFF7F8">

    <AbsoluteLayout>
        <!-- Nội dung chính -->
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All" Padding="20">
            <Label x:Name="shopNameLabel" 
                   Text="Tên quán" 
                   FontSize="24" FontAttributes="Bold" 
                   HorizontalTextAlignment="Center" 
                   TextColor="#FF6B81"
                   Margin="0,0,0,20" CharacterSpacing="0.3"/>

            <Border Padding="12" StrokeThickness="0" BackgroundColor="White"
                    HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#FF6B81" Offset="0,8" Opacity="0.12" Radius="20"/>
                </Border.Shadow>
                <Image x:Name="qrImage"
                       Aspect="AspectFit"
                       HeightRequest="250" WidthRequest="250" />
            </Border>

            <Label Text="Kéo kính quét bên dưới đè lên ảnh QR để xem" 
                   FontSize="14" HorizontalTextAlignment="Center" 
                   TextColor="#6C6C80"
                   Margin="0,30,0,0" />
            
            <Button x:Name="scanButton" 
                    Text="Bật Kính Quét" 
                    TextColor="White" 
                    CornerRadius="22" 
                    HeightRequest="56" 
                    FontAttributes="Bold"
                    FontSize="15"
                    Margin="40,20,40,0"
                    Clicked="OnScanButtonClicked">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6B81" Offset="0.0"/>
                        <GradientStop Color="#FF9A76" Offset="1.0"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Shadow>
                    <Shadow Brush="#FF6B81" Offset="0,8" Opacity="0.25" Radius="16"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <!-- Kính quét di động (Magic Lens) -->
        <Border x:Name="magicLens"
               Padding="0"
               StrokeThickness="2"
               Stroke="#FF6B81"
               IsVisible="False"
               WidthRequest="300"
               HeightRequest="300"
               BackgroundColor="Transparent"
               AbsoluteLayout.LayoutBounds="0.5, 0.8, AutoSize, AutoSize"
               AbsoluteLayout.LayoutFlags="PositionProportional">
            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.15" Radius="12"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </Border.GestureRecognizers>
            <Grid>
                <BoxView Color="#FF6B81" HeightRequest="3" VerticalOptions="Start" HorizontalOptions="Fill" Margin="20,0" />
                <BoxView Color="#FF6B81" HeightRequest="3" VerticalOptions="End" HorizontalOptions="Fill" Margin="20,0" />
                <BoxView Color="#FF6B81" WidthRequest="3" VerticalOptions="Fill" HorizontalOptions="Start" Margin="0,20" />
                <BoxView Color="#FF6B81" WidthRequest="3" VerticalOptions="Fill" HorizontalOptions="End" Margin="0,20" />
                <BoxView x:Name="laserLine" Color="#FF6B81" HeightRequest="2" VerticalOptions="Center" Opacity="0.6" IsVisible="True" />
            </Grid>
        </Border>

        <!-- Thanh Mini-player -->
        <Border x:Name="miniPlayer"
                IsVisible="False"
                Padding="12,10"
                Margin="12,0,12,30"
                StrokeThickness="0"
                AbsoluteLayout.LayoutBounds="0.5, 1, 1, 95"
                AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF3D78" Offset="0.0"/>
                    <GradientStop Color="#FF6B81" Offset="0.5"/>
                    <GradientStop Color="#FF9A76" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="47.5" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#FF3D78" Offset="0,6" Radius="18" Opacity="0.30" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto">
                <!-- Vùng 1: Thông tin + Sóng âm (Đã tối ưu Grid để không chồng lấn) -->
                <Grid Grid.Column="0" ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="10,0,10,0">
                    <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2.5" HeightRequest="30">
                        <BoxView x:Name="wave1" WidthRequest="3" HeightRequest="12" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                        <BoxView x:Name="wave2" WidthRequest="3" HeightRequest="18" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                        <BoxView x:Name="wave3" WidthRequest="3" HeightRequest="10" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                        <BoxView x:Name="wave4" WidthRequest="3" HeightRequest="22" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                        <BoxView x:Name="wave5" WidthRequest="3" HeightRequest="14" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                        <BoxView x:Name="wave6" WidthRequest="3" HeightRequest="19" Color="White" CornerRadius="1.5" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                        <Label Text="AUDIO GUIDE" FontSize="8" FontAttributes="Bold" TextColor="White" Opacity="0.8" CharacterSpacing="2" />
                        <Label x:Name="detectedShopLabel" 
                               Text="Tên quán" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="White" 
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
                
                <!-- Vùng 2: Nhóm nút bấm điều khiển (Spacing chuẩn) -->
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center" Margin="0,0,10,0">
                    <!-- Nút Play/Pause -->
                    <Grid WidthRequest="46" HeightRequest="46">
                        <Border Padding="0" BackgroundColor="#22FFFFFF" Stroke="White" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="23" />
                            </Border.StrokeShape>
                            <Grid HorizontalOptions="Center" VerticalOptions="Center">
                                <Path x:Name="playIcon" 
                                      Data="M 0,0 L 12,8 L 0,16 Z" 
                                      Fill="White" 
                                      TranslationX="2" />
                                <HorizontalStackLayout x:Name="pauseIcon" Spacing="4" IsVisible="False" HorizontalOptions="Center">
                                    <BoxView WidthRequest="4" HeightRequest="14" Color="White" CornerRadius="1" />
                                    <BoxView WidthRequest="4" HeightRequest="14" Color="White" CornerRadius="1" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlayAudioClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Nút Replay -->
                    <Grid WidthRequest="46" HeightRequest="46">
                        <Border Padding="0" BackgroundColor="#22FFFFFF" Stroke="White" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="23" />
                            </Border.StrokeShape>
                            <Path Data="M17.65,6.35 C16.2,4.9 14.21,4 12,4 c-4.42,0-7.99,3.58-7.99,8 s3.57,8 7.99,8 c3.73,0 6.84,-2.55 7.73,-6 h-2.08 c-0.82,2.33 -3.04,4 -5.65,4 c-3.31,0 -6,-2.69 -6,-6 s2.69,-6 6,-6 c1.66,0 3.14,0.69 4.22,1.78 L13,11 h7 V4 L17.65,6.35 z" 
                                  Fill="White"
                                  HorizontalOptions="Center" 
                                  VerticalOptions="Center"
                                  WidthRequest="22"
                                  HeightRequest="22" />
                        </Border>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnReplayAudioClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Nút Chi tiết -->
                    <Grid WidthRequest="46" HeightRequest="46">
                        <Border Padding="0" BackgroundColor="#22FFFFFF" Stroke="White" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="23" />
                            </Border.StrokeShape>
                            <Path Data="M 0,0 L 7,7 L 0,14" 
                                  Stroke="White" 
                                  StrokeThickness="2.5" 
                                  StrokeLineCap="Round" 
                                  StrokeLineJoin="Round"
                                  HorizontalOptions="Center" 
                                  VerticalOptions="Center" 
                                  TranslationX="1" />
                        </Border>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDetailClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Nút Đóng (X) -->
                    <Grid WidthRequest="34" HeightRequest="34">
                        <Border Padding="0" BackgroundColor="#22FFFFFF" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="17" /></Border.StrokeShape>
                            <Label Text="✕" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClosePlayerClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </HorizontalStackLayout>
            </Grid>
        </Border>
    </AbsoluteLayout>
</ContentPage>
