<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FoodMapApp.Views"
             x:Class="FoodMapApp.Views.HomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#FFF7F8">

    <Grid RowDefinitions="Auto,*">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0" Padding="0,0,0,28">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6B81" Offset="0.0"/>
                    <GradientStop Color="#FF9A76" Offset="0.55"/>
                    <GradientStop Color="#FFB8A6" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative circles -->
            <Ellipse WidthRequest="240" HeightRequest="240"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-90,-50,0" Opacity="0.10">
                <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
            </Ellipse>
            <Ellipse WidthRequest="120" HeightRequest="120"
                     HorizontalOptions="Start" VerticalOptions="End"
                     Margin="-30,0,0,10" Opacity="0.06">
                <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
            </Ellipse>

            <VerticalStackLayout Padding="24,54,24,0" Spacing="20">

                <!-- Greeting row -->
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label x:Name="GreetingLabel" FontSize="14" TextColor="White" Opacity="0.88"/>
                        <Label x:Name="UsernameLabel" FontSize="26" FontAttributes="Bold"
                               TextColor="White" CharacterSpacing="0.5"/>
                    </VerticalStackLayout>

                    <!-- QR Button -->
                    <Border Grid.Column="1" WidthRequest="46" HeightRequest="46"
                            StrokeThickness="0" VerticalOptions="Center" Margin="0,0,10,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="23"/></Border.StrokeShape>
                        <Border.Background>
                            <SolidColorBrush Color="#33FFFFFF"/>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnQRButtonClicked" />
                        </Border.GestureRecognizers>
                        <Path Data="M2,2H8V8H2V2 M4,4H6V6H4V4 M14,2H20V8H14V2 M16,4H18V6H16V4 M2,14H8V20H2V14 M4,16H6V18H4V16 M14,14H16V16H14V14 M18,14H20V16H18V14 M14,18H16V20H14V18 M18,18H20V20H18V18 M10,2H12V4H10V2 M10,6H12V8H10V6 M10,10H12V12H10V10 M10,14H12V16H10V14 M10,18H12V20H10V18 M2,10H4V12H2V10 M6,10H8V12H6V10 M14,10H16V12H14V10 M18,10H20V12H18V10"
                              Fill="White"
                              Aspect="Uniform"
                              WidthRequest="22"
                              HeightRequest="22"
                              HorizontalOptions="Center" 
                              VerticalOptions="Center" />
                    </Border>

                    <!-- Location badge -->
                    <Border Grid.Column="2" WidthRequest="46" HeightRequest="46"
                            StrokeThickness="0" VerticalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="23"/></Border.StrokeShape>
                        <Border.Background>
                            <SolidColorBrush Color="#33FFFFFF"/>
                        </Border.Background>
                        <Path Data="M12,2 C8.13,2 5,5.13 5,9 C5,14.25 12,22 12,22 C12,22 19,14.25 19,9 C19,5.13 15.87,2 12,2 M12,11.5 C10.62,11.5 9.5,10.38 9.5,9 C9.5,7.62 10.62,6.5 12,6.5 C13.38,6.5 14.5,7.62 14.5,9 C14.5,10.38 13.38,11.5 12,11.5 Z"
                              Fill="White" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                              HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Search bar (frosted glass) -->
                <Border StrokeThickness="0" Padding="0" HeightRequest="56">
                    <Border.StrokeShape><RoundRectangle CornerRadius="28"/></Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="#28FFFFFF"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#FF6B81" Offset="0,6" Opacity="0.12" Radius="12"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,0">
                        <Path Grid.Column="0" Data="M15.5,14 L14.71,14 L14.43,13.73 C15.41,12.59 16,11.11 16,9.5 C16,5.91 13.09,3 9.5,3 C5.91,3 3,5.91 3,9.5 C3,13.09 5.91,16 9.5,16 C11.11,16 12.59,15.41 13.73,14.43 L14,14.71 L14,15.5 L19,20.49 L20.49,19 L15.5,14 Z M9.5,14 C7.01,14 5,11.99 5,9.5 C5,7.01 7.01,5 9.5,5 C11.99,5 14,7.01 14,9.5 C14,11.99 11.99,14 9.5,14 Z"
                              Fill="White" Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                              VerticalOptions="Center" Margin="0,0,12,0"/>
                        <Entry Grid.Column="1" x:Name="SearchEntry"
                               TextChanged="OnSearchTextChanged"
                               Placeholder="Tìm quán, địa chỉ..."
                               PlaceholderColor="#D9FFFFFF" TextColor="White"
                               BackgroundColor="Transparent" VerticalOptions="Center"
                               IsTextPredictionEnabled="False" IsSpellCheckEnabled="False"/>
                        <Path x:Name="ClearSearchBtn" Grid.Column="2"
                              Data="M19,6.41 L17.59,5 L12,10.59 L6.41,5 L5,6.41 L10.59,12 L5,17.59 L6.41,19 L12,13.41 L17.59,19 L19,17.59 L13.41,12 L19,6.41 Z"
                              Fill="White" Aspect="Uniform" WidthRequest="16" HeightRequest="16"
                              VerticalOptions="Center" IsVisible="False" Opacity="0.8">
                            <Path.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnClearSearchTapped"/>
                            </Path.GestureRecognizers>
                        </Path>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ── BODY ── -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">

            <VerticalStackLayout Spacing="32" Padding="0,24,0,32">

                <!-- ── CATEGORIES ── -->
                <VerticalStackLayout Spacing="16" Padding="24,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" x:Name="CategoryTitleLabel" Text="Khám Phá"
                               FontSize="20" FontAttributes="Bold" TextColor="#1A1A2E" CharacterSpacing="0.3"/>
                    </Grid>

                    <CollectionView x:Name="CategoriesCollection" VerticalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="20" HorizontalItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:CategoryItem">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCategoryTapped"
                                                              CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout.GestureRecognizers>

                                    <!-- Image Circle -->
                                    <Border WidthRequest="82" HeightRequest="82" Padding="0"
                                            BackgroundColor="{Binding BackgroundColor}"
                                            StrokeThickness="0" HorizontalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="41"/></Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#FF6B81" Offset="0,4" Opacity="0.10" Radius="10"/>
                                        </Border.Shadow>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                    </Border>
                                    <Label Text="{Binding category_name}" FontSize="13" TextColor="#1A1A2E"
                                           FontAttributes="Bold" HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ── TOP RESTAURANTS ── -->
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" Padding="24,0">
                        <Label Grid.Column="0" x:Name="TopRestaurantLabel" Text="Quán nổi bật"
                               FontSize="20" FontAttributes="Bold" TextColor="#1A1A2E" CharacterSpacing="0.3"/>

                    </Grid>

                    <CollectionView x:Name="RestaurantsCollection" HeightRequest="260"
                                    ItemsLayout="HorizontalList" Margin="10,0" HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:FoodItem">
                                <Border WidthRequest="205" HeightRequest="245"
                                        Padding="0" Margin="8,5" StrokeThickness="0"
                                        BackgroundColor="White">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="26"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#FF6B81" Offset="0,8" Opacity="0.10" Radius="18"/>
                                    </Border.Shadow>

                                    <Grid RowDefinitions="135,*">
                                        <!-- Real Restaurant Image from Database -->
                                        <Border Grid.Row="0" Padding="0" StrokeThickness="0" BackgroundColor="#FFF7F8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="26"/></Border.StrokeShape>
                                            
                                            <Grid>
                                                <!-- Fallback vector -->
                                                <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 M12,20 C7.58,20 4,16.42 4,12 C4,7.58 7.58,4 12,4 C16.42,4 20,7.58 20,12 C20,16.42 16.42,20 12,20 M12,6 C8.69,6 6,8.69 6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 C18,8.69 15.31,6 12,6 Z"
                                                      Fill="#FFE8EC" Aspect="Uniform" WidthRequest="40" HeightRequest="40"
                                                      HorizontalOptions="Center" VerticalOptions="Center" />
                                                
                                                <Image Source="{Binding first_image}" Aspect="AspectFill" 
                                                       WidthRequest="205" HeightRequest="135"
                                                       HorizontalOptions="Fill" VerticalOptions="Fill" />
                                            </Grid>
                                        </Border>
                                         <VerticalStackLayout Grid.Row="1" Padding="16,10" Spacing="4">
                                             <Label Text="{Binding name}" FontSize="15"
                                                    FontAttributes="Bold" TextColor="#1A1A2E"
                                                    LineBreakMode="TailTruncation"/>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="Gần đây" FontSize="11" TextColor="#6C6C80" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                            <!-- Explore chip -->
                                            <Border BackgroundColor="#FFECEF" Padding="14,7"
                                                    StrokeThickness="0" Margin="0,6,0,0"
                                                    HorizontalOptions="Start">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnExploreTapped" CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="Chi tiết ›" FontSize="11"
                                                       TextColor="#FF6B81" FontAttributes="Bold"/>
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ── RECOMMENDED RESTAURANTS ── -->
                <VerticalStackLayout Spacing="16" x:Name="RecommendedSection">
                    <Grid Padding="24,0">
                        <Label x:Name="RecommendedLabel" Text="Quán bạn có thể biết"
                               FontSize="20" FontAttributes="Bold" TextColor="#1A1A2E" CharacterSpacing="0.3"/>
                    </Grid>

                    <CollectionView x:Name="RecommendedRestaurantsCollection" Margin="24,0" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:FoodItem">
                                <Border Padding="0" Margin="0,0,0,14" StrokeThickness="0" BackgroundColor="White">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#FF6B81" Offset="0,5" Opacity="0.08" Radius="14"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="105,*" HeightRequest="105">
                                        <Border Grid.Column="0" Padding="0" StrokeThickness="0" BackgroundColor="#FFF7F8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="22,0,22,0"/>
                                            </Border.StrokeShape>
                                            <Grid>
                                                <!-- Fallback vector -->
                                                <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 M12,20 C7.58,20 4,16.42 4,12 C4,7.58 7.58,4 12,4 C16.42,4 20,7.58 20,12 C20,16.42 16.42,20 12,20 M12,6 C8.69,6 6,8.69 6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 C18,8.69 15.31,6 12,6 Z"
                                                      Fill="#FFE8EC" Aspect="Uniform" WidthRequest="40" HeightRequest="40"
                                                      HorizontalOptions="Center" VerticalOptions="Center" />
                                                  
                                                <Image Source="{Binding first_image}" Aspect="AspectFill"
                                                       HorizontalOptions="Fill" VerticalOptions="Fill" />
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Padding="16,14" Spacing="5" VerticalOptions="Center" HorizontalOptions="Fill">
                                            <Label Text="{Binding name}" FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E" HorizontalOptions="Start" HorizontalTextAlignment="Start" />
                                            <Label Text="{Binding address}" FontSize="12" TextColor="#6C6C80" LineBreakMode="TailTruncation" HorizontalOptions="Start" HorizontalTextAlignment="Start" />
                                            <Label Text="Xem quán ›" FontSize="12" TextColor="#FF6B81" FontAttributes="Bold" Margin="0,4,0,0" HorizontalOptions="Start" HorizontalTextAlignment="Start">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnExploreTapped" CommandParameter="{Binding .}"/>
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ── NO RESULTS ── -->
                <Label x:Name="NoResultsLabel"
                       Text="Không tìm thấy quán phù hợp"
                       FontSize="15" TextColor="#6C6C80"
                       HorizontalOptions="Center" Padding="0,10"
                       IsVisible="False"/>

                <!-- ── EVENTS ── -->
                <VerticalStackLayout Spacing="16" Padding="24,0">
                    <Label x:Name="EventTitleLabel" Text="Sự Kiện Đặc Biệt" FontSize="20" FontAttributes="Bold"
                           TextColor="#1A1A2E" CharacterSpacing="0.3"/>

                    <!-- Event 1 -->
                    <Border BackgroundColor="White" Padding="0" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#FF6B81" Offset="0,6" Opacity="0.08" Radius="16"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="5,*,Auto">
                            <Border Grid.Column="0" WidthRequest="5" Margin="0,16" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="3"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF6B81" Offset="0.0"/>
                                        <GradientStop Color="#FF9A76" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" Padding="16,18">
                                <Label x:Name="Event1Title" Text="Khung giờ vàng" FontSize="15" FontAttributes="Bold"
                                       TextColor="#1A1A2E"/>
                                <Label x:Name="Event1Desc" Text="Tặng 1 món ăn kèm từ 17:00 - 19:00" FontSize="13" TextColor="#6C6C80"/>
                                <Label x:Name="Event1Sub" Text="Áp dụng với hóa đơn 50k" FontSize="11" TextColor="#B0A3AB"/>
                            </VerticalStackLayout>
                            <Path Grid.Column="2" Data="M12,21.35 L10.55,20.03 C5.4,15.36 2,12.28 2,8.5 C2,5.42 4.42,3 7.5,3 C9.24,3 10.91,3.81 12,5.09 C13.09,3.81 14.76,3 16.5,3 C19.58,3 22,5.42 22,8.5 C22,12.28 18.6,15.36 13.45,20.04 L12,21.35 Z"
                                  Fill="#FFECEF" Aspect="Uniform" WidthRequest="30" HeightRequest="30"
                                  VerticalOptions="Center" Margin="0,0,24,0"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
