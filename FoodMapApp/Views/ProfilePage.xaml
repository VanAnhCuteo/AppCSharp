<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F9F1F0">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,50,20,24">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6A88" Offset="0.0" />
                    <GradientStop Color="#FF99AC" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                <Frame WidthRequest="80" HeightRequest="80" CornerRadius="40" Padding="0"
                       BackgroundColor="White" HorizontalOptions="Center">
                    <Label Text="&#x1F464;" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                <Label x:Name="ProfileUsernameLabel" Text="Dang tai..." TextColor="White"
                       FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label x:Name="ProfileEmailLabel" Text="" TextColor="White" FontSize="13"
                       Opacity="0.85" HorizontalOptions="Center"/>
                <Frame BackgroundColor="#00000033" CornerRadius="12" Padding="10,4" HorizontalOptions="Center">
                    <Label x:Name="ProfileRoleLabel" Text="user" TextColor="White" FontSize="12"/>
                </Frame>
            </VerticalStackLayout>
        </Grid>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="20,20">

                <!-- Stats Row -->
                <Frame BackgroundColor="White" CornerRadius="16" Padding="16" HasShadow="True">
                    <Grid ColumnDefinitions="*,*,*">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                            <Label x:Name="VisitCountLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="#FF6A88" HorizontalOptions="Center"/>
                            <Label Text="Quan da ghe" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#EEE" HorizontalOptions="End" VerticalOptions="Fill"/>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                            <Label x:Name="ReviewCountLabel" Text="0" FontSize="22" FontAttributes="Bold" TextColor="#FF6A88" HorizontalOptions="Center"/>
                            <Label Text="Danh gia" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#EEE" HorizontalOptions="End" VerticalOptions="Fill"/>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                            <Label Text="Bui Vien" FontSize="14" FontAttributes="Bold" TextColor="#FF6A88" HorizontalOptions="Center"/>
                            <Label Text="Khu vuc" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Food Tour History -->
                <Label Text="Lich su Foodtour" FontSize="17" FontAttributes="Bold" TextColor="#333"/>
                <CollectionView x:Name="HistoryCollection" EmptyView="Chua co lich su.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" CornerRadius="12" Padding="14,10" Margin="0,4" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Frame Grid.Column="0" WidthRequest="44" HeightRequest="44" CornerRadius="22"
                                           Padding="0" BackgroundColor="#FFE4EC" Margin="0,0,12,0">
                                        <Label Text="&#x1F374;" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding name}" FontSize="14" FontAttributes="Bold" TextColor="#222"/>
                                        <Label Text="{Binding address}" FontSize="12" TextColor="#888" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="&#x276F;" FontSize="16" TextColor="#DDD" VerticalOptions="Center"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Reviews Written -->
                <Label Text="Danh gia da viet" FontSize="17" FontAttributes="Bold" TextColor="#333" Margin="0,8,0,0"/>
                <CollectionView x:Name="ReviewsCollection" EmptyView="Chua co danh gia nao.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" CornerRadius="12" Padding="14,10" Margin="0,4" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding comment}" FontSize="13" TextColor="#444"/>
                                    <Label Text="{Binding created_at}" FontSize="11" TextColor="#AAA"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Logout -->
                <Button Text="Dang xuat"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="White"
                        TextColor="#FF6A88"
                        BorderColor="#FF6A88"
                        BorderWidth="1.5"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Margin="0,10,0,0"/>

                <BoxView HeightRequest="30" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
