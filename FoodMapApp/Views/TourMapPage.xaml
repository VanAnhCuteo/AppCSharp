<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.Views.TourMapPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFF7F8">

    <Grid>
        <WebView x:Name="tourMapView" />

        <!-- Bottom Overlay: Dynamic Layout -->
        <Border VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,40" Padding="0"
                BackgroundColor="White" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="26"/></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#1A1A2E" Offset="0,12" Radius="24" Opacity="0.12" />
            </Border.Shadow>
            
            <VerticalStackLayout Padding="22,20" Spacing="16" WidthRequest="320">
                <!-- Status Row -->
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label x:Name="statusTitleLabel" Text="Bản đồ Tour" FontSize="11" FontAttributes="Bold" TextColor="#FF6B81" CharacterSpacing="1.5" />
                        <Label x:Name="currentStopNameLabel" Text="Sẵn sàng bắt đầu" FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#FFECEF" StrokeThickness="0" Padding="12,6" VerticalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label x:Name="stopCountLabel" Text="5 quán" FontSize="12" TextColor="#FF6B81" FontAttributes="Bold"/>
                    </Border>
                </Grid>

                <!-- Action Button -->
                <Button x:Name="actionButton" Text="Bắt đầu hành trình" Clicked="OnNextStopClicked" 
                        TextColor="White" 
                        CornerRadius="20" HeightRequest="56" FontSize="15" FontAttributes="Bold"
                        CharacterSpacing="0.3">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF6B81" Offset="0.0"/>
                            <GradientStop Color="#FF9A76" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Shadow>
                        <Shadow Brush="#FF6B81" Offset="0,8" Opacity="0.30" Radius="16"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
