<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.FoodTourPage"
             BackgroundColor="#FFF7F8"
             Title="Khám Phá Tour"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Main Content -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            
            <!-- Header & Search Section -->
            <VerticalStackLayout Grid.Row="0" Spacing="16">
                <!-- Gradient Header Banner -->
                <Grid Padding="24,50,24,24">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF6B81" Offset="0.0"/>
                            <GradientStop Color="#FF9A76" Offset="0.55"/>
                            <GradientStop Color="#FFB8A6" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <!-- Decorative -->
                    <Ellipse WidthRequest="180" HeightRequest="180"
                             HorizontalOptions="End" VerticalOptions="Start"
                             Margin="0,-60,-40,0" Opacity="0.08">
                        <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                    </Ellipse>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Khám Phá Tour" FontSize="28" FontAttributes="Bold" TextColor="White" CharacterSpacing="0.5"/>
                        <Label Text="Chọn hành trình ẩm thực dành cho riêng bạn" FontSize="14" TextColor="White" Opacity="0.9"/>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="20,0,20,10" Spacing="16">
                    <!-- Search Bar Container -->
                    <Border StrokeThickness="0" BackgroundColor="White" Padding="5,2" HeightRequest="54">
                        <Border.StrokeShape><RoundRectangle CornerRadius="27"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#FF6B81" Offset="0,5" Radius="14" Opacity="0.10" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Path Grid.Column="0" 
                                  Data="M15.5,14 L14.71,14 L14.43,13.73 C15.41,12.59 16,11.11 16,9.5 C16,5.91 13.09,3 9.5,3 C5.91,3 3,5.91 3,9.5 C3,13.09 5.91,16 9.5,16 C11.11,16 12.59,15.41 13.73,14.43 L14,14.71 L14,15.5 L19,20.49 L20.49,19 L15.5,14 Z M9.5,14 C7.01,14 5,11.99 5,9.5 C5,7.01 7.01,5 9.5,5 C11.99,5 14,7.01 14,9.5 C14,11.99 11.99,14 9.5,14 Z"
                                  Fill="#FFB8A6" Aspect="Uniform" WidthRequest="18" HeightRequest="18"
                                  VerticalOptions="Center" Margin="15,0,10,0"/>
                            <Entry Grid.Column="1" x:Name="searchEntry" Placeholder="Tìm tên tour, thời gian, giá..." 
                                   PlaceholderColor="#B0A3AB" TextColor="#1A1A2E" VerticalOptions="Center"
                                   TextChanged="OnSearchTextChanged" />
                            <Button Grid.Column="2" x:Name="clearBtn" Text="✕" BackgroundColor="Transparent" TextColor="#B0A3AB" 
                                    IsVisible="False" Clicked="OnClearSearchClicked" WidthRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Vertical Filters Section -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="14">
                        <!-- Time Filters -->
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="Theo thời gian" FontAttributes="Bold" FontSize="13" TextColor="#1A1A2E" />
                            
                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#FFF7F8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                </Border.Shadow>
                                <Label Text="≤ 1 giờ" TextColor="#6C6C80" FontSize="13" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="TIME_60" /></Border.GestureRecognizers>
                            </Border>
                            
                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#FFF7F8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                </Border.Shadow>
                                <Label Text="1 - 2 giờ" TextColor="#6C6C80" FontSize="13" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="TIME_120" /></Border.GestureRecognizers>
                            </Border>

                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#FFF7F8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                </Border.Shadow>
                                <Label Text="Trên 3 giờ" TextColor="#6C6C80" FontSize="13" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="TIME_999" /></Border.GestureRecognizers>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Price Filters -->
                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Theo giá cả" FontAttributes="Bold" FontSize="13" TextColor="#1A1A2E" />

                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#FFECEF">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#FF6B81" Offset="0,2" Radius="6" Opacity="0.06" />
                                </Border.Shadow>
                                <Label Text="Tiết kiệm" TextColor="#FF6B81" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="PRICE_100000" /></Border.GestureRecognizers>
                            </Border>

                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#EDF8FF">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#4895EF" Offset="0,2" Radius="6" Opacity="0.06" />
                                </Border.Shadow>
                                <Label Text="Trung bình" TextColor="#4895EF" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="PRICE_300000" /></Border.GestureRecognizers>
                            </Border>

                            <Border StrokeThickness="0" Padding="14,10" BackgroundColor="#FFF7E6">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#FAAD14" Offset="0,2" Radius="6" Opacity="0.06" />
                                </Border.Shadow>
                                <Label Text="Cao cấp" TextColor="#E89B00" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnQuickFilterTapped" CommandParameter="PRICE_999999" /></Border.GestureRecognizers>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Tours List -->
            <RefreshView Grid.Row="1" x:Name="refreshView" Refreshing="OnRefresh" RefreshColor="#FF6B81">
                <CollectionView x:Name="tourList" SelectionMode="None" Margin="12,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" BackgroundColor="White" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#FF6B81" Offset="0,5" Radius="14" Opacity="0.10" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="5,*">
                                    <!-- Accent bar -->
                                    <Border Grid.Column="0" WidthRequest="5" Margin="0,14" StrokeThickness="0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="3"/></Border.StrokeShape>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FF6B81" Offset="0.0"/>
                                                <GradientStop Color="#FF9A76" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="8" Padding="16,18">
                                        <Label Text="{Binding name}" TextColor="#1A1A2E" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding description}" TextColor="#6C6C80" FontSize="13" MaxLines="2" LineBreakMode="TailTruncation" />
                                        <HorizontalStackLayout Spacing="18" Margin="0,4,0,0">
                                            <HorizontalStackLayout Spacing="6">
                                                <Border BackgroundColor="#FFECEF" WidthRequest="26" HeightRequest="26" StrokeThickness="0" Padding="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                                                    <Label Text="🕒" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="{Binding DurationDisplay}" TextColor="#6C6C80" FontSize="12" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="6">
                                                <Border BackgroundColor="#FFF0E8" WidthRequest="26" HeightRequest="26" StrokeThickness="0" Padding="0">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                                                    <Label Text="💰" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="{Binding PriceDisplay}" TextColor="#6C6C80" FontSize="12" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTourSelected" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="50">
                            <Label Text="🍱" FontSize="56" HorizontalOptions="Center" />
                            <Label Text="Chưa có tour nào phù hợp" TextColor="#6C6C80" FontSize="15" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>