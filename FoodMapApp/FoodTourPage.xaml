<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"
             x:Class="FoodMapApp.FoodTourPage">

    <Grid>

        <Image Source="https://images.unsplash.com/photo-1504674900247-0877df9cc836"
Aspect="AspectFill"/>

        <VerticalStackLayout
VerticalOptions="Center"
HorizontalOptions="Center"
Spacing="20">

            <Label
Text="🍜 Food Tour Vĩnh Khánh"
FontSize="36"
TextColor="White"
HorizontalOptions="Center"/>

            <Button
Text="Bắt đầu Food Tour"
Clicked="StartTour"
BackgroundColor="#FB6F92"
TextColor="White"
CornerRadius="25"
WidthRequest="240"
HeightRequest="55"
FontSize="18"
FontAttributes="Bold"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>