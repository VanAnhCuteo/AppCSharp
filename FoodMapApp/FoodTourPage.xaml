<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.FoodTourPage"
             BackgroundColor="#FDFCFD"
             Title="Khám Phá Tour">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Main Content -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            
            <!-- Header & Search Section -->
            <VerticalStackLayout Grid.Row="0" Padding="20,10,20,15" Spacing="15">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Khám Phá Tour" FontSize="28" FontAttributes="Bold" TextColor="#333" />
                    <Label Text="Chọn hành trình ẩm thực dành cho riêng bạn" FontSize="14" TextColor="#777" />
                </VerticalStackLayout>

                <!-- Search Bar Container -->
                <Border StrokeShape="RoundRectangle 25" StrokeThickness="0" BackgroundColor="White" Padding="5,2" HeightRequest="50">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" Margin="15,0,10,0" FontSize="16" />
                        <Entry Grid.Column="1" x:Name="searchEntry" Placeholder="Tìm tên tour, thời gian, giá..." 
                               PlaceholderColor="#BBB" TextColor="#333" VerticalOptions="Center"
                               Focused="OnSearchFocused" Unfocused="OnSearchUnfocused" TextChanged="OnSearchTextChanged" />
                        <Button Grid.Column="2" x:Name="clearBtn" Text="✕" BackgroundColor="Transparent" TextColor="#999" 
                                IsVisible="False" Clicked="OnClearSearchClicked" WidthRequest="40" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Tours List -->
            <RefreshView Grid.Row="1" x:Name="refreshView" Refreshing="OnRefresh" RefreshColor="#FF6A88">
                <CollectionView x:Name="tourList" SelectionMode="None" Margin="10,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Padding="16">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding name}" TextColor="#222" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding description}" TextColor="#777" FontSize="13" MaxLines="2" LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="15" Margin="0,4,0,0">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="🕒" FontSize="12" />
                                            <Label Text="{Binding DurationDisplay}" TextColor="#555" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="💰" FontSize="12" />
                                            <Label Text="{Binding PriceDisplay}" TextColor="#555" FontSize="12" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTourSelected" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="50">
                            <Label Text="🍱" FontSize="50" HorizontalOptions="Center" />
                            <Label Text="Chưa có tour nào phù hợp" TextColor="#999" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- Suggestions Overlay (Initially Hidden) -->
        <Grid Grid.Row="1" x:Name="suggestionOverlay" IsVisible="False" InputTransparent="False" BackgroundColor="#40000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped" />
            </Grid.GestureRecognizers>
            
            <Border VerticalOptions="Start" Margin="20,10" Padding="20" StrokeShape="RoundRectangle 20" 
                    BackgroundColor="White" StrokeThickness="0" TranslationY="-20" x:Name="suggestionPanel">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Gợi ý tìm kiếm" FontAttributes="Bold" FontSize="14" TextColor="#555" />
                    
                    <!-- Time Suggestions -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Thời gian" FontSize="12" TextColor="#999" />
                        <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#F5F5FA" StrokeThickness="0">
                                <Label Text="≤ 1 giờ" TextColor="#666" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="TIME_60" /></Border.GestureRecognizers>
                            </Border>
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#F5F5FA" StrokeThickness="0">
                                <Label Text="1-2 giờ" TextColor="#666" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="TIME_120" /></Border.GestureRecognizers>
                            </Border>
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#F5F5FA" StrokeThickness="0">
                                <Label Text="> 3 giờ" TextColor="#666" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="TIME_999" /></Border.GestureRecognizers>
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <!-- Price Suggestions -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Ngân sách" FontSize="12" TextColor="#999" />
                        <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#FFF0F3" StrokeThickness="0">
                                <Label Text="Tiết kiệm" TextColor="#FF6A88" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="PRICE_100000" /></Border.GestureRecognizers>
                            </Border>
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#EDF8FF" StrokeThickness="0">
                                <Label Text="Trung bình" TextColor="#4895EF" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="PRICE_300000" /></Border.GestureRecognizers>
                            </Border>
                            <Border StrokeShape="RoundRectangle 15" Padding="12,6" Margin="0,0,8,8" BackgroundColor="#FFF7E6" StrokeThickness="0">
                                <Label Text="Cao cấp" TextColor="#FAAD14" FontSize="13" />
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSuggestionTapped" CommandParameter="PRICE_999999" /></Border.GestureRecognizers>
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

    </Grid>
</ContentPage>