<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodMapApp.FoodTourPage"
             BackgroundColor="#FFF7F8"
             Title="Khám Phá Tour"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Main Content -->
        <Grid RowDefinitions="Auto, *">
            <Grid Grid.Row="1" RowDefinitions="Auto, *">
                
                <!-- Header & Search Section -->
                <VerticalStackLayout Grid.Row="0" Spacing="16">
                    <!-- Gradient Header Banner -->
                    <Grid Padding="24,50,24,24">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF6B81" Offset="0.0"/>
                                <GradientStop Color="#FF9A76" Offset="0.55"/>
                                <GradientStop Color="#FFB8A6" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <!-- Decorative -->
                        <Ellipse WidthRequest="180" HeightRequest="180"
                                 HorizontalOptions="End" VerticalOptions="Start"
                                 Margin="0,-60,-40,0" Opacity="0.08">
                            <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                        </Ellipse>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Khám Phá Tour" FontSize="28" FontAttributes="Bold" TextColor="White" CharacterSpacing="0.5"/>
                            <Label Text="Chọn hành trình ẩm thực dành cho riêng bạn" FontSize="14" TextColor="White" Opacity="0.9"/>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Padding="20,0,20,10" Spacing="16">
                        <!-- Search Bar Container -->
                        <Border StrokeThickness="0" BackgroundColor="White" Padding="5,2" HeightRequest="54">
                            <Border.StrokeShape><RoundRectangle CornerRadius="27"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#FF6B81" Offset="0,5" Radius="14" Opacity="0.10" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Path Grid.Column="0" 
                                      Data="M15.5,14 L14.71,14 L14.43,13.73 C15.41,12.59 16,11.11 16,9.5 C16,5.91 13.09,3 9.5,3 C5.91,3 3,5.91 3,9.5 C3,13.09 5.91,16 9.5,16 C11.11,16 12.59,15.41 13.73,14.43 L14,14.71 L14,15.5 L19,20.49 L20.49,19 L15.5,14 Z M9.5,14 C7.01,14 5,11.99 5,9.5 C5,7.01 7.01,5 9.5,5 C11.99,5 14,7.01 14,9.5 C14,11.99 11.99,14 9.5,14 Z"
                                      Fill="#FFB8A6" Aspect="Uniform" WidthRequest="18" HeightRequest="18"
                                      VerticalOptions="Center" Margin="15,0,10,0"/>
                                <Entry Grid.Column="1" x:Name="searchEntry" Placeholder="Tìm tên tour, thời gian, giá..." 
                                       PlaceholderColor="#B0A3AB" TextColor="#1A1A2E" VerticalOptions="Center"
                                       TextChanged="OnSearchTextChanged" />
                                <Button Grid.Column="2" x:Name="clearBtn" Text="✕" BackgroundColor="Transparent" TextColor="#B0A3AB" 
                                        IsVisible="False" Clicked="OnClearSearchClicked" WidthRequest="40" />
                            </Grid>
                        </Border>

                        <!-- Dropdown Filters Section -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <!-- Time Dropdown -->
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Thời gian" FontAttributes="Bold" FontSize="12" TextColor="#1A1A2E" Margin="4,0,0,0"/>
                                <Border StrokeThickness="1.5" Stroke="#FFE4EA" BackgroundColor="White" Padding="12,0" HeightRequest="48">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Picker x:Name="timePicker" Grid.Column="0" Title="Tất cả" FontSize="13" TextColor="#1A1A2E"
                                                VerticalOptions="Center" TitleColor="#6C6C80"
                                                SelectedIndexChanged="OnTimeFilterChanged">
                                            <Picker.ItemsSource>
                                                <x:Array Type="{x:Type x:String}">
                                                    <x:String>Tất cả</x:String>
                                                    <x:String>&lt; 1 giờ</x:String>
                                                    <x:String>1 - 2 giờ</x:String>
                                                    <x:String>2 - 3 giờ</x:String>
                                                    <x:String>Trên 3 giờ</x:String>
                                                </x:Array>
                                            </Picker.ItemsSource>
                                            <Picker.SelectedIndex>0</Picker.SelectedIndex>
                                        </Picker>
                                        <Label Grid.Column="1" Text="▼" FontSize="10" TextColor="#FF6B81" 
                                               VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,5,0" InputTransparent="True"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Price Dropdown -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Giá tiền" FontAttributes="Bold" FontSize="12" TextColor="#1A1A2E" Margin="4,0,0,0" />
                                <Border StrokeThickness="1.5" Stroke="#FFE4EA" BackgroundColor="White" Padding="12,0" HeightRequest="48">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Picker x:Name="pricePicker" Grid.Column="0" Title="Tất cả" FontSize="13" TextColor="#1A1A2E"
                                                VerticalOptions="Center" TitleColor="#6C6C80"
                                                SelectedIndexChanged="OnPriceFilterChanged">
                                            <Picker.ItemsSource>
                                                <x:Array Type="{x:Type x:String}">
                                                    <x:String>Tất cả</x:String>
                                                    <x:String>&lt; 100.000đ</x:String>
                                                    <x:String>100k - 250k</x:String>
                                                    <x:String>250k - 500k</x:String>
                                                    <x:String>Trên 500.000đ</x:String>
                                                </x:Array>
                                            </Picker.ItemsSource>
                                            <Picker.SelectedIndex>0</Picker.SelectedIndex>
                                        </Picker>
                                        <Label Grid.Column="1" Text="▼" FontSize="10" TextColor="#FF6B81" 
                                               VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,5,0" InputTransparent="True"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Tours List -->
                <RefreshView Grid.Row="1" x:Name="refreshView" Refreshing="OnRefresh" RefreshColor="#FF6B81">
                    <CollectionView x:Name="tourList" SelectionMode="None" Margin="12,0">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0" BackgroundColor="#FFF5F2" Padding="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#FF6B81" Offset="0,5" Radius="14" Opacity="0.10" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="5,*">
                                        <!-- Accent bar -->
                                        <Border Grid.Column="0" WidthRequest="5" Margin="0,14" StrokeThickness="0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="3"/></Border.StrokeShape>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#FF6B81" Offset="0.0"/>
                                                    <GradientStop Color="#FF9A76" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="8" Padding="16,18">
                                            <Label Text="{Binding name}" TextColor="#1A1A2E" FontSize="18" FontAttributes="Bold" />
                                            <Label Text="{Binding description}" TextColor="#6C6C80" FontSize="13" MaxLines="2" LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="18" Margin="0,4,0,0">
                                                <HorizontalStackLayout Spacing="6">
                                                    <Border BackgroundColor="#FFECEF" WidthRequest="26" HeightRequest="26" StrokeThickness="0" Padding="0">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                                                        <Label Text="🕒" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Text="{Binding DurationDisplay}" TextColor="#6C6C80" FontSize="12" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Border BackgroundColor="#FFF0E8" WidthRequest="26" HeightRequest="26" StrokeThickness="0" Padding="0">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                                                        <Label Text="💰" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Text="{Binding PriceDisplay}" TextColor="#6C6C80" FontSize="12" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTourSelected" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="50">
                                <Label Text="🍱" FontSize="56" HorizontalOptions="Center" />
                                <Label Text="Chưa có tour nào phù hợp" TextColor="#6C6C80" FontSize="15" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </Grid>

        <!-- Dim Overlay For Bottom Sheet -->
        <BoxView x:Name="dimOverlay" BackgroundColor="Black" Opacity="0" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseBottomSheet" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Bottom Sheet overlay -->
        <Border x:Name="bottomSheet" BackgroundColor="White" VerticalOptions="End" TranslationY="1000" Padding="0,15,0,0" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="30,30,0,0" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="0">
                <!-- Drag Handle -->
                <BoxView HeightRequest="5" WidthRequest="40" Color="#EAEAEA" CornerRadius="2.5" HorizontalOptions="Center" Margin="0,0,0,15" />
                
                <VerticalStackLayout Padding="20,0,20,15">
                    <Label x:Name="sheetTitle" Text="Tên Tour" FontSize="22" FontAttributes="Bold" TextColor="#1A1A2E" />
                </VerticalStackLayout>

                <ScrollView HeightRequest="300">
                    <VerticalStackLayout Padding="20,0,20,30" Spacing="15">
                        <Label x:Name="sheetDesc" Text="Đang cập nhật nội dung..." FontSize="14" TextColor="#6C6C80" LineHeight="1.5" />
                        
                        <HorizontalStackLayout Spacing="15" Margin="0,10,0,0">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="🕒" FontSize="14" VerticalOptions="Center" />
                                <Label x:Name="sheetTime" Text="-" FontSize="14" TextColor="#1A1A2E" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="💰" FontSize="14" VerticalOptions="Center" />
                                <Label x:Name="sheetPrice" Text="-" FontSize="14" TextColor="#1A1A2E" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                        
                        <Button Text="Bắt đầu hành trình" BackgroundColor="#FF6B81" TextColor="White" CornerRadius="14" HeightRequest="50" FontSize="16" FontAttributes="Bold" Margin="0,15,0,0" Clicked="OnStartJourneyClicked" />
                    </VerticalStackLayout>
                </ScrollView>
            </VerticalStackLayout>
        </Border>


    </Grid>
</ContentPage>