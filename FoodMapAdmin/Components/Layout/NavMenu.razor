<aside class="sidebar">
    <div class="logo">
        <i class="bi bi-heart-fill" style="color: var(--primary); font-size: 1.4rem;"></i> FoodMap
    </div>

    <nav class="nav-menu">
        <AuthorizeView Roles="admin">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2-fill"></i> Tổng quan
            </NavLink>
        </AuthorizeView>

        <!-- Q.Lý Cửa Hàng - Admin Version (with Dropdown) -->
        <AuthorizeView Roles="admin">
            <div class="nav-item-group">
                <div class="nav-link nav-link-item @(isPoisExpanded ? "is-expanded" : "")" @onclick="TogglePois">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-shop-window"></i> Q.Lý Cửa Hàng
                    </div>
                    <i class="bi bi-chevron-down dropdown-arrow"></i>
                </div>
                
                <div class="submenu-wrapper">
                    <NavLink class="nav-link nav-link-sub" href="/pois">
                        <i class="bi bi-list-ul"></i> Danh sách
                    </NavLink>

                    <NavLink class="nav-link nav-link-sub" href="/map">
                        <i class="bi bi-geo-alt"></i> Vị trí
                    </NavLink>

                    <NavLink class="nav-link nav-link-sub" href="/categories">
                        <i class="bi bi-tags-fill"></i> Danh mục
                    </NavLink>

                    <div class="nav-item-group-sub">
                        <div class="nav-link nav-link-sub nav-link-sub-item @(isModerationExpanded ? "is-expanded" : "")" @onclick="ToggleModeration">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-shield-check"></i> Phê duyệt
                            </div>
                            <i class="bi bi-chevron-down dropdown-arrow-sub"></i>
                        </div>
                        <div class="submenu-wrapper-sub @(isModerationExpanded ? "is-open" : "")">
                            <NavLink class="nav-link nav-link-sub nav-link-sub-sub" href="/moderation/pois">
                                <i class="bi bi-geo-alt-fill"></i> Địa điểm
                            </NavLink>
                            <NavLink class="nav-link nav-link-sub nav-link-sub-sub" href="/moderation/images">
                                <i class="bi bi-image"></i> Hình ảnh
                            </NavLink>
                        </div>
                    </div>
                </div>
            </div>
        </AuthorizeView>

        <!-- Q.Lý Cửa Hàng - Chủ Quán Version (Direct Link) -->
        <AuthorizeView Roles="CNH">
            <NavLink class="nav-link" href="/pois">
                <i class="bi bi-shop-window"></i> Q.Lý Cửa Hàng
            </NavLink>
        </AuthorizeView>

        <NavLink class="nav-link" href="/images">
            <i class="bi bi-image-fill"></i> Quản lý hình ảnh
        </NavLink>

        <AuthorizeView Roles="admin">
            <NavLink class="nav-link" href="/qr-management">
                <i class="bi bi-qr-code"></i> Quản lý mã QR
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="admin">
            <NavLink class="nav-link" href="/audio-management">
                <i class="bi bi-mic-fill"></i> Hướng dẫn Audio
            </NavLink>

            <NavLink class="nav-link" href="/tours">
                <i class="bi bi-geo-fill"></i> Quản lý Tour
            </NavLink>

            <NavLink class="nav-link" href="/poi-analytics">
                <i class="bi bi-bar-chart-line-fill"></i> Thống kê lượt nghe
            </NavLink>

            <NavLink class="nav-link" href="/users">
                <i class="bi bi-people-fill"></i> Người dùng
            </NavLink>
        </AuthorizeView>

        <div style="margin-top: auto; padding-top: 2rem;">
            <a class="nav-link logout-link" href="/api/auth/logout" style="color: #ff4d4d; background: rgba(255, 77, 77, 0.03); border: 1px solid rgba(255,77,77,0.1);">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </nav>
</aside>

@code {
    private bool isPoisExpanded = false;
    private bool isModerationExpanded = false;

    @inject NavigationManager Navigation

    protected override void OnInitialized()
    {
        // Auto-expand if on related pages
        var uri = Navigation.Uri.ToLower();
        if (uri.Contains("/pois") || uri.Contains("/moderation") || uri.Contains("/categories"))
        {
            isPoisExpanded = true;
        }

        if (uri.Contains("/moderation/"))
        {
            isModerationExpanded = true;
        }
    }

    private void TogglePois()
    {
        isPoisExpanded = !isPoisExpanded;
        if (!isPoisExpanded) isModerationExpanded = false;
    }

    private void ToggleModeration()
    {
        isModerationExpanded = !isModerationExpanded;
    }
}
