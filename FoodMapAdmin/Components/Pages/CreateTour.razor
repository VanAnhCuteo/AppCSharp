@page "/tours/create"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject ITourService TourService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "admin")]

<PageTitle>Tạo Tour mới - FoodMap Admin</PageTitle>

<div class="header-container animate-fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <button class="btn-back-glass" @onclick='(() => Navigation.NavigateTo("/tours"))'>
                <i class="bi bi-arrow-left"></i>
            </button>
            <div>
                <h1 class="display-5 fw-900 mb-0 text-gradient">Khởi tạo Tour mới</h1>
                <p class="text-muted mb-0 small">Thiết lập thông tin cơ bản cho lộ trình ẩm thực</p>
            </div>
        </div>
        <p class="text-muted mb-0 d-none d-md-block">BƯỚC 1: THÔNG TIN TỔNG QUAN</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="create-card shadow-glass">
            @* Section 1: Basic Info *@
            <div class="card-section">
                <div class="section-icon-header">
                    <div class="section-icon"><i class="bi bi-info-circle-fill"></i></div>
                    <div>
                        <h5 class="section-title mb-0">Thông tin tổng quan</h5>
                        <p class="section-subtitle">Tên, mô tả sẽ hiển thị cho người dùng</p>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label-custom">Tên Tour ẩm thực</label>
                    <input type="text" @bind="newTour.Name" class="form-control glass-input" placeholder="VD: Food Tour Vĩnh Khánh - Thiên đường ốc" />
                </div>
                
                <div class="mb-4">
                    <label class="form-label-custom">Mô tả ngắn gọn</label>
                    <textarea @bind="newTour.Description" class="form-control glass-input" rows="3" placeholder="Giới thiệu về trải nghiệm của tour này..."></textarea>
                </div>
            </div>

            <div class="section-divider"></div>

            @* Section 2: Duration *@
            <div class="card-section">
                <div class="section-icon-header">
                    <div class="section-icon icon-blue"><i class="bi bi-clock-fill"></i></div>
                    <div>
                        <h5 class="section-title mb-0">Thời lượng Tour</h5>
                        <p class="section-subtitle">Chọn nhanh hoặc nhập trực tiếp số phút</p>
                    </div>
                </div>

                <div class="preset-chips mb-3">
                    @foreach (var d in new[] { 30, 60, 90, 120, 150, 180, 240 })
                    {
                        var minutes = d;
                        <button class="preset-chip @(newTour.DurationMinutes == minutes ? "active" : "")" @onclick="() => newTour.DurationMinutes = minutes">
                            @FormatDuration(minutes)
                        </button>
                    }
                </div>

                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="input-group-fancy">
                            <input type="number" @bind="newTour.DurationMinutes" class="form-control glass-input" min="15" step="15" />
                            <span class="input-suffix">phút</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="preview-badge">
                            <i class="bi bi-clock me-2"></i>
                            <span>@FormatDuration(newTour.DurationMinutes)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            @* Section 3: Price *@
            <div class="card-section">
                <div class="section-icon-header">
                    <div class="section-icon icon-green"><i class="bi bi-wallet2"></i></div>
                    <div>
                        <h5 class="section-title mb-0">Mức giá Tour</h5>
                        <p class="section-subtitle">Giá tổng cho cả lộ trình</p>
                    </div>
                </div>

                <div class="preset-chips mb-3">
                    @foreach (var p in new[] { 50000m, 100000m, 150000m, 200000m, 300000m, 500000m, 1000000m })
                    {
                        var price = p;
                        <button class="preset-chip @(newTour.Price == price ? "active" : "")" @onclick="() => newTour.Price = price">
                            @FormatPrice(price)
                        </button>
                    }
                </div>

                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="input-group-fancy">
                            <input type="number" @bind="newTour.Price" class="form-control glass-input" min="0" step="10000" />
                            <span class="input-suffix">VNĐ</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="preview-badge preview-green">
                            <i class="bi bi-wallet2 me-2"></i>
                            <span>@FormatPrice(newTour.Price)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="action-footer">
                <button class="btn-cancel" @onclick='(() => Navigation.NavigateTo("/tours"))'>Hủy bỏ</button>
                <button class="btn-save" @onclick="HandleCreate" disabled="@string.IsNullOrWhiteSpace(newTour.Name)">
                    Lưu và Tiếp tục <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gradient {
        background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .fw-900 { font-weight: 900; }

    .create-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 36px;
        padding: 2.5rem;
    }

    .card-section { padding: 0.5rem 0; }

    .section-icon-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 1.8rem;
    }

    .section-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background: rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: #555;
        flex-shrink: 0;
    }

    .section-icon.icon-blue { background: rgba(59,130,246,0.1); color: #3b82f6; }
    .section-icon.icon-green { background: rgba(16,185,129,0.1); color: #10b981; }

    .section-title {
        font-weight: 800;
        color: #1a1a1a;
        font-size: 1.05rem;
    }

    .section-subtitle {
        font-size: 0.78rem;
        color: #999;
        margin-bottom: 0;
    }

    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #eee, transparent);
        margin: 1.5rem 0;
    }

    .form-label-custom {
        display: block;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.7rem;
        letter-spacing: 0.5px;
    }

    .glass-input {
        background: rgba(240, 242, 245, 0.5);
        border: 1px solid #eee;
        border-radius: 18px;
        padding: 0.85rem 1.3rem;
        font-weight: 500;
        transition: all 0.3s;
    }

    .glass-input:focus {
        background: white;
        border-color: #1a1a1a;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    /* ── Preset Chips ── */
    .preset-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .preset-chip {
        background: #f7f8fa;
        border: 1px solid #eee;
        border-radius: 14px;
        padding: 8px 18px;
        font-size: 0.82rem;
        font-weight: 700;
        color: #555;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .preset-chip:hover {
        background: #f0f0ff;
        border-color: #c7c7ff;
        transform: translateY(-2px);
    }

    .preset-chip.active {
        background: #1a1a1a;
        color: white;
        border-color: #1a1a1a;
        transform: scale(1.05);
    }

    /* ── Input Group ── */
    .input-group-fancy {
        position: relative;
    }

    .input-group-fancy .glass-input {
        padding-right: 60px;
    }

    .input-suffix {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.78rem;
        font-weight: 700;
        color: #aaa;
    }

    /* ── Preview Badge ── */
    .preview-badge {
        background: rgba(59,130,246,0.08);
        border: 1px solid rgba(59,130,246,0.15);
        border-radius: 16px;
        padding: 0.8rem 1.2rem;
        font-weight: 800;
        font-size: 1rem;
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .preview-badge.preview-green {
        background: rgba(16,185,129,0.08);
        border-color: rgba(16,185,129,0.15);
        color: #10b981;
    }

    .action-footer {
        margin-top: 2.5rem;
        padding-top: 1.8rem;
        border-top: 1px solid #f0f0f0;
        display: flex;
        justify-content: flex-end;
        gap: 15px;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border: none;
        padding: 0.8rem 2.2rem;
        border-radius: 16px;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 20px var(--primary-glow);
    }

    .btn-save:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px var(--primary-glow);
        filter: brightness(1.1);
    }

    .btn-save:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-cancel {
        background: rgba(0, 0, 0, 0.05);
        color: #666;
        border: none;
        padding: 0.8rem 1.8rem;
        border-radius: 16px;
        font-weight: 700;
        transition: all 0.2s;
    }

    .btn-cancel:hover {
        background: rgba(0, 0, 0, 0.1);
        color: #333;
    }
    .btn-back-glass {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background: white;
        border: 1px solid #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #666;
        font-size: 1.2rem;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-back-glass:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        transform: translateX(-3px);
        box-shadow: 0 5px 15px var(--primary-glow);
    }
</style>

@code {
    private Tour newTour = new Tour { DurationMinutes = 90, Price = 100000 };

    private string FormatDuration(int minutes)
    {
        if (minutes <= 0) return "N/A";
        int h = minutes / 60;
        int m = minutes % 60;
        if (h > 0 && m > 0) return $"{h}h{m:D2}'";
        if (h > 0) return $"{h} giờ";
        return $"{m} phút";
    }

    private string FormatPrice(decimal price)
    {
        if (price <= 0) return "Miễn phí";
        if (price >= 1000000) return $"{price / 1000000:0.#}tr";
        if (price >= 1000) return $"{price / 1000:0}k";
        return $"{price:N0}đ";
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(newTour.Name)) return;

        var id = await TourService.CreateTourAsync(newTour);
        if (id > 0)
        {
            Navigation.NavigateTo($"/tours/{id}/manage");
        }
    }
}
