@page "/login"
@layout EmptyLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using FoodMapAdmin.Services
@inject IUserService UserService
@inject NavigationManager Navigator

<div class="login-container" style="display: flex; min-height: 100vh; width: 100%; align-items: center; justify-content: center; background: #ffffff; position: relative; overflow: hidden; padding: 20px;">
    <!-- Hiệu ứng nền nhẹ nhàng hơn -->
    <div style="position: absolute; width: 600px; height: 600px; background: rgba(255, 45, 133, 0.03); filter: blur(150px); border-radius: 50%; top: -200px; right: -200px;"></div>
    
    <div class="card shadow-lg" style="width: 100%; max-width: 440px; padding: 3.5rem 2.8rem; text-align: center; border: 1px solid rgba(255, 45, 133, 0.06); border-radius: 40px; background: #fff9fb; backdrop-filter: blur(20px); box-shadow: 0 40px 100px -20px rgba(255, 45, 133, 0.08) !important;">
        <div class="logo-circle mb-4" style="width: 75px; height: 75px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); border-radius: 22px; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; box-shadow: 0 12px 30px var(--primary-glow);">
            <i class="bi bi-shield-lock-fill text-white" style="font-size: 2.2rem;"></i>
        </div>
        
        <h2 style="background: linear-gradient(to right, var(--text-main), var(--primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem; font-weight: 800; letter-spacing: -1.5px; display: inline-block;">FOODMAP ADMIN</h2>
        <p style="color: var(--text-muted); margin-bottom: 3rem; font-weight: 500; font-size: 0.95rem;">Đăng nhập hệ thống quản trị viên</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert mb-4 py-3" style="background: rgba(255, 77, 77, 0.05); color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.1); border-radius: 16px; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                <i class="bi bi-exclamation-circle-fill"></i> @errorMessage
            </div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <div style="text-align: left; margin-bottom: 1.8rem;">
                <label style="display: block; margin-bottom: 0.7rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.2px; font-weight: 700;">Tên đăng nhập</label>
                <div style="position: relative; width: 100%;">
                    <i class="bi bi-person" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: var(--primary); font-size: 1.2rem; z-index: 5;"></i>
                    <InputText @bind-Value="loginModel.Username" class="form-control shadow-sm" style="width: 100%; padding: 1.1rem 1rem 1.1rem 3.5rem; border-radius: 18px; background: #ffffff; border: 1px solid rgba(0,0,0,0.06); color: var(--text-main); font-size: 1rem; box-sizing: border-box;" placeholder="Username..." />
                </div>
            </div>
            
            <div style="text-align: left; margin-bottom: 2.8rem;">
                <label style="display: block; margin-bottom: 0.7rem; color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.2px; font-weight: 700;">Mật khẩu</label>
                <div style="position: relative; width: 100%;">
                    <i class="bi bi-key" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: var(--primary); font-size: 1.2rem; z-index: 5;"></i>
                    <InputText type="password" @bind-Value="loginModel.Password" class="form-control shadow-sm" style="width: 100%; padding: 1.1rem 1rem 1.1rem 3.5rem; border-radius: 18px; background: #ffffff; border: 1px solid rgba(0,0,0,0.06); color: var(--text-main); font-size: 1rem; box-sizing: border-box;" placeholder="••••••••" />
                </div>
            </div>

            <button type="submit" class="glass-btn" style="width: 100%; height: 60px; font-size: 1.1rem; border-radius: 18px; justify-content: center; box-shadow: 0 10px 25px var(--primary-glow) !important; display: flex; align-items: center; gap: 10px;">
                Bắt đầu làm việc <i class="bi bi-arrow-right-short" style="font-size: 1.8rem;"></i>
            </button>
        </EditForm>

        <div style="margin-top: 3.5rem; display: flex; flex-direction: column; gap: 0.5rem; opacity: 0.5;">
            <p style="margin: 0; color: var(--text-muted); font-size: 0.75rem;">&copy; 2026 FoodMap Excellence Team</p>
            <div style="width: 40px; height: 2px; background: var(--primary); margin: 0 auto; border-radius: 10px; opacity: 0.3;"></div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private async Task HandleLogin()
    {
        var user = await UserService.AuthenticateAsync(loginModel.Username, loginModel.Password);

        if (user != null)
        {
            if (user.Role == "user")
            {
                errorMessage = "Truy cập bị từ chối. Tài khoản khách hàng không thể vào trang quản lý.";
                return;
            }

            var claims = new List<Claim>
            {
                new Claim(ClaimTypes.Name, user.Username),
                new Claim(ClaimTypes.NameIdentifier, user.UserId.ToString()),
                new Claim(ClaimTypes.Role, user.Role),
                new Claim("sub", user.UserId.ToString())
            };

            var claimsIdentity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            
            // In Blazor Server, we can't easily SignIn here because HttpContext is usually already used or not active for SSR interactive.
            // But we can use a redirect to an API endpoint that does the SignIn.
            // For simplicity in this demo, let's assume we use a controller or a standard form post.
            // However, with InteractiveServer, the best way is often to use a standard Post to a login controller.
            
            // For this specific implementation, I will just display a "Success" message or redirect if I can.
            // Actually, I'll redirect to a specialized login controller endpoint.
            Navigator.NavigateTo($"/api/auth/login-cookie?username={user.Username}&password={user.Password}", forceLoad: true);
        }
        else
        {
            errorMessage = "Tên đăng nhập hoặc mật khẩu không chính xác.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

