@page "/login"
@layout EmptyLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using FoodMapAdmin.Services
@inject IUserService UserService
@inject NavigationManager Navigator

<div class="login-wrapper">
    <!-- Left: Branding -->
    <div class="login-brand">
        <div class="brand-content">
            <div class="brand-icon">
                <i class="bi bi-heart-fill"></i>
            </div>
            <h1>FoodMap</h1>
            <p>Hệ thống quản lý bản đồ ẩm thực thông minh</p>
            <div class="brand-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>

    <!-- Right: Form -->
    <div class="login-form-side">
        <div class="login-card">
            <div class="login-card-header">
                <h2>Đăng nhập</h2>
                <p>Nhập thông tin để truy cập hệ thống quản trị</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="login-error">
                    <i class="bi bi-exclamation-circle-fill"></i> @errorMessage
                </div>
            }

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <div class="login-field">
                    <label>Tên đăng nhập</label>
                    <div class="login-input-wrap">
                        <i class="bi bi-person"></i>
                        <InputText @bind-Value="loginModel.Username" class="login-input" placeholder="Nhập tên đăng nhập..." />
                    </div>
                </div>
                
                <div class="login-field">
                    <label>Mật khẩu</label>
                    <div class="login-input-wrap">
                        <i class="bi bi-key"></i>
                        <InputText type="password" @bind-Value="loginModel.Password" class="login-input" placeholder="••••••••" />
                    </div>
                </div>

                <button type="submit" class="login-btn">
                    Bắt đầu làm việc <i class="bi bi-arrow-right"></i>
                </button>
            </EditForm>

            <div class="login-footer">
                <p>&copy; 2026 FoodMap VanAnhCuteo</p>
            </div>
        </div>
    </div>
</div>

<style>
    .login-wrapper {
        display: flex;
        min-height: 100vh;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

    .login-brand {
        flex: 1;
        background: linear-gradient(135deg, #0F0F1A 0%, #1A1A3E 50%, #2D1B3D 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .login-brand::before {
        content: '';
        position: absolute;
        width: 450px;
        height: 450px;
        background: rgba(248, 43, 96, 0.12);
        border-radius: 50%;
        filter: blur(120px);
        top: 15%;
        left: 25%;
        animation: orb-float 8s ease-in-out infinite;
    }

    .login-brand::after {
        content: '';
        position: absolute;
        width: 350px;
        height: 350px;
        background: rgba(108, 92, 231, 0.10);
        border-radius: 50%;
        filter: blur(100px);
        bottom: 15%;
        right: 20%;
        animation: orb-float 10s ease-in-out infinite reverse;
    }

    @@keyframes orb-float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -30px) scale(1.05); }
        66% { transform: translate(-20px, 20px) scale(0.95); }
    }

    .brand-content {
        text-align: center;
        color: white;
        padding: 2rem;
        position: relative;
        z-index: 1;
    }

    .brand-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #F82B60, #D91A50);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin: 0 auto 2rem;
        box-shadow: 0 15px 40px rgba(248, 43, 96, 0.35);
        animation: icon-glow 3s ease-in-out infinite;
    }

    @@keyframes icon-glow {
        0%, 100% { box-shadow: 0 15px 40px rgba(248, 43, 96, 0.35); }
        50% { box-shadow: 0 15px 50px rgba(248, 43, 96, 0.5); }
    }

    .brand-content h1 {
        font-size: 2.8rem;
        font-weight: 900;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        color: white;
    }

    .brand-content p {
        color: rgba(255,255,255,0.45);
        font-size: 0.95rem;
        font-weight: 400;
        max-width: 300px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .brand-dots {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 2.5rem;
    }

    .brand-dots span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(248, 43, 96, 0.35);
        transition: all 0.3s ease;
    }

    .brand-dots span:first-child {
        background: #F82B60;
        box-shadow: 0 0 8px rgba(248, 43, 96, 0.4);
    }

    .login-form-side {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #FAFAFE;
        padding: 2rem;
        position: relative;
    }

    .login-form-side::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 1px;
        height: 100%;
        background: linear-gradient(180deg, transparent, rgba(248, 43, 96, 0.15), transparent);
    }

    .login-card {
        width: 100%;
        max-width: 420px;
    }

    .login-card-header {
        margin-bottom: 2.5rem;
    }

    .login-card-header h2 {
        font-size: 1.75rem;
        font-weight: 800;
        color: #1A1A2E;
        margin-bottom: 0.4rem;
    }

    .login-card-header p {
        color: #8E8EA0;
        font-size: 0.9rem;
        margin: 0;
    }

    .login-error {
        background: rgba(255, 71, 87, 0.06);
        color: #FF4757;
        border: 1px solid rgba(255, 71, 87, 0.12);
        border-radius: 12px;
        padding: 0.85rem 1.1rem;
        font-size: 0.85rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        animation: shake 0.4s ease-in-out;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-6px); }
        40%, 80% { transform: translateX(6px); }
    }

    .login-field {
        margin-bottom: 1.5rem;
    }

    .login-field label {
        display: block;
        margin-bottom: 0.5rem;
        color: #555770;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 600;
    }

    .login-input-wrap {
        position: relative;
    }

    .login-input-wrap i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #B0B0C0;
        font-size: 1.1rem;
        z-index: 5;
        transition: all 0.3s var(--ease-smooth);
    }

    .login-input {
        width: 100%;
        padding: 0.9rem 1rem 0.9rem 3rem;
        border-radius: 12px;
        background: #fff;
        border: 1.5px solid rgba(0,0,0,0.08);
        color: #1A1A2E;
        font-size: 0.92rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.3s var(--ease-smooth);
        outline: none;
    }

    .login-input:focus {
        border-color: #F82B60;
        box-shadow: 0 0 0 4px rgba(248, 43, 96, 0.10);
    }

    .login-input:focus + .login-input-wrap i,
    .login-input-wrap:focus-within i {
        color: #F82B60;
        transform: translateY(-50%) scale(1.1);
    }

    .login-input::placeholder {
        color: #B0B0C0;
    }

    .login-btn {
        width: 100%;
        padding: 0.95rem;
        background: linear-gradient(135deg, #F82B60, #D91A50);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 0.95rem;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.3s var(--ease-out);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        box-shadow: 0 8px 24px rgba(248, 43, 96, 0.2);
        position: relative;
        overflow: hidden;
    }

    .login-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        transition: left 0.6s ease;
    }

    .login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(248, 43, 96, 0.3);
    }

    .login-btn:hover::before {
        left: 100%;
    }

    .login-btn:active {
        transform: translateY(0);
    }

    .login-footer {
        text-align: center;
        margin-top: 3rem;
    }

    .login-footer p {
        color: #B0B0C0;
        font-size: 0.75rem;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .login-brand { display: none; }
        .login-form-side { padding: 1.5rem; }
    }
</style>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private async Task HandleLogin()
    {
        var user = await UserService.AuthenticateAsync(loginModel.Username, loginModel.Password);

        if (user != null)
        {
            if (user.IsBlocked)
            {
                errorMessage = "Tài khoản của bạn đã bị khóa. Vui lòng liên hệ quản trị viên.";
                return;
            }

            if (user.Role == "user")
            {
                errorMessage = "Truy cập bị từ chối. Tài khoản khách hàng không thể vào trang quản lý.";
                return;
            }

            var claims = new List<Claim>
            {
                new Claim(ClaimTypes.Name, user.Username),
                new Claim(ClaimTypes.NameIdentifier, user.UserId.ToString()),
                new Claim(ClaimTypes.Role, user.Role),
                new Claim("sub", user.UserId.ToString())
            };

            var claimsIdentity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            
            Navigator.NavigateTo($"/api/auth/login-cookie?username={user.Username}&password={user.Password}", forceLoad: true);
        }
        else
        {
            errorMessage = "Tên đăng nhập hoặc mật khẩu không chính xác.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
