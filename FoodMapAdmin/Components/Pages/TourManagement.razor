@page "/tours"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject ITourService TourService
@inject NavigationManager Navigator
@inject IJSRuntime JSRuntime
@inject IActivityLogger Logger
@attribute [Authorize(Roles = "admin,CNH")]

<PageTitle>Quản lý Tour - FoodMap Admin</PageTitle>

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
    <div>
        <h2 class="page-title">Quản lý Tour Ẩm Thực</h2>
        <p class="page-subtitle">Quản lý danh sách các hành trình ẩm thực đặc sắc trên hệ thống</p>
    </div>
    <button class="glass-btn" @onclick="AddNew">
        <i class="bi bi-plus-lg"></i> Thêm tour mới
    </button>
</div>

<!-- Table Card -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="padding-left: 1.75rem; width: 70px;">Mã</th>
                    <th>Tên Tour</th>
                    <th>Mô tả</th>
                    <th>Ngày tạo</th>
                    <th style="text-align: center; width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (tours == null)
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 3rem 0;">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                        </td>
                    </tr>
                }
                else if (!tours.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
                            <i class="bi bi-map" style="font-size: 2.5rem; opacity: 0.2; display: block; margin-bottom: 0.5rem;"></i>
                            Chưa có dữ liệu tour nào
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var tour in tours)
                    {
                        <tr>
                            <td style="padding-left: 1.75rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem;">#@tour.Id</td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div class="tour-avatar">@(tour.Name.Substring(0, 1).ToUpper())</div>
                                    <div style="font-weight: 700; color: var(--text-main); font-size: 0.92rem;">
                                        @tour.Name
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="color: var(--text-secondary); font-size: 0.85rem; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@tour.Description">
                                    @tour.Description
                                </div>
                            </td>
                            <td>
                                <span style="font-size: 0.85rem; color: var(--text-muted);">@(tour.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</span>
                            </td>
                            <td style="text-align: center;">
                                <div style="display: flex; justify-content: center; gap: 0.5rem;">
                                    <button class="act-btn act-edit" title="Chỉnh sửa" @onclick="() => Edit(tour.Id)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="act-btn act-del" title="Xóa" @onclick="() => Delete(tour.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .tour-avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #FF6B6B, #FF8E53);
        color: white;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(255, 107, 107, 0.3);
    }

    .act-btn {
        width: 34px;
        height: 34px;
        border-radius: var(--radius-sm);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s var(--ease-out);
        font-size: 0.95rem;
        cursor: pointer;
    }

    .act-edit {
        background: var(--primary-subtle);
        color: var(--primary);
    }

    .act-edit:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-1px);
    }

    .act-del {
        background: rgba(255, 71, 87, 0.06);
        color: #FF4757;
    }

    .act-del:hover {
        background: #FF4757;
        color: white;
        transform: translateY(-1px);
    }

    table {
        width: 100% !important;
    }
</style>

@code {
    private List<Tour>? tours;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            tours = await TourService.GetAllToursAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading Tours: {ex.Message}");
            tours = new List<Tour>();
        }
    }

    private void AddNew() => Navigator.NavigateTo("/tours/add");
    private void Edit(int id) => Navigator.NavigateTo($"/tours/edit/{id}");
    
    private async Task Delete(int id) {
        var authState = await AuthStateTask!;
        var user = authState.User;
        var tour = tours?.FirstOrDefault(t => t.Id == id);
        if (tour == null) return;

        string msg = "Bạn có chắc chắn muốn xóa tour này không? Hành động này không thể hoàn tác và sẽ xoá toàn bộ dữ liệu lộ trình bên trong.";

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", msg);
        if (confirmed)
        {
            if (await TourService.DeleteTourAsync(id))
            {
                var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                int.TryParse(userIdStr, out var currentUserId);
                await Logger.LogAsync(currentUserId, "Xóa tour", tour.Name);
                
                tours = tours?.Where(t => t.Id != id).ToList();
                StateHasChanged();
            }
        }
    }
}
