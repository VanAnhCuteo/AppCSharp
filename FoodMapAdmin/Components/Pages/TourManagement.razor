        border-color: #1a1a1a;
    }
</style>

@code {
    private List<Tour>? tours;
    private bool showEditModal = false;
    private Tour? editingTour;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        tours = await TourService.GetAllToursAsync();
    }

    private string FormatDuration(int minutes)
    {
        if (minutes <= 0) return "N/A";
        int h = minutes / 60;
        int m = minutes % 60;
        if (h > 0 && m > 0) return $"{h}h{m:D2}'";
        if (h > 0) return $"{h} giờ";
        return $"{m} phút";
    }

    private string FormatPrice(decimal price)
    {
        if (price <= 0) return "Miễn phí";
        if (price >= 1000000) return $"{price / 1000000:0.#}tr";
        if (price >= 1000) return $"{price / 1000:0}k";
        return $"{price:N0}đ";
    }

    private void OpenEditModal(Tour tour)
    {
        editingTour = new Tour
        {
            TourId = tour.TourId,
            Name = tour.Name,
            Description = tour.Description,
            DurationMinutes = tour.DurationMinutes,
            Price = tour.Price,
            CreatedAt = tour.CreatedAt
        };
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editingTour = null;
    }

    private async Task SaveEdit()
    {
        if (editingTour == null || string.IsNullOrEmpty(editingTour.Name)) return;

        await TourService.UpdateTourAsync(editingTour);
        showEditModal = false;
        editingTour = null;
        await LoadData();
    }

    private async Task DeleteTour(int id)
    {
        var ok = await JSRuntime.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa tour này và toàn bộ lộ trình liên quan?");
        if (ok)
        {
            await TourService.DeleteTourAsync(id);
            await LoadData();
        }
    }
}
