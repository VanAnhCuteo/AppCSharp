@page "/tours"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject ITourService TourService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin")]

<PageTitle>Quản lý Tour - FoodMap Admin</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
    <div>
        <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 0.2rem;">Quản lý Tour</h2>
        <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">Hệ thống tối ưu hóa và quản lý lộ trình ẩm thực</p>
    </div>
    <button class="glass-btn" @onclick='(() => Navigation.NavigateTo("/tours/create"))'>
        <i class="bi bi-plus-lg"></i> Tạo Tour mới
    </button>
</div>

@* ── Stats Overview ── *@
<div class="stats-premium-row mb-5 animate-fade-in">
    <div class="stat-premium-item">
        <div class="stat-premium-icon bg-primary-soft">
            <i class="bi bi-map-fill text-primary"></i>
        </div>
        <div class="stat-premium-info">
            <div class="stat-premium-value">@(tours?.Count ?? 0)</div>
            <div class="stat-premium-label">Tổng số Tour</div>
        </div>
    </div>
    <div class="stat-premium-divider"></div>
    <div class="stat-premium-item">
        <div class="stat-premium-icon bg-success-soft">
            <i class="bi bi-shop text-success"></i>
        </div>
        <div class="stat-premium-info">
            <div class="stat-premium-value">@(tours?.Sum(t => t.Pois?.Count ?? 0) ?? 0)</div>
            <div class="stat-premium-label">Tổng điểm dừng</div>
        </div>
    </div>
    <div class="stat-premium-divider"></div>
    <div class="stat-premium-item">
        <div class="stat-premium-icon bg-warning-soft">
            <i class="bi bi-currency-exchange text-warning"></i>
        </div>
        <div class="stat-premium-info">
            <div class="stat-premium-value">@FormatPrice(tours?.Where(t => t.Price > 0).Select(t => t.Price).DefaultIfEmpty(0).Average() ?? 0)</div>
            <div class="stat-premium-label">Giá trung bình</div>
        </div>
    </div>
</div>

@* ── Tour Cards Grid ── *@
<div class="row g-4 animate-stagger">
    @if (tours == null)
    {
        @for (int i = 0; i < 3; i++)
        {
            <div class="col-md-6 col-xl-4">
                <div class="skeleton-card"></div>
            </div>
        }
    }
    else if (!tours.Any())
    {
        <div class="col-12">
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-map"></i></div>
                <h3>Chưa có tour nào</h3>
                <p>Bắt đầu xây dựng lộ trình ẩm thực đầu tiên của bạn ngay hôm nay!</p>
                <button class="btn btn-primary rounded-pill px-4" @onclick='(() => Navigation.NavigateTo("/tours/create"))'>Tạo ngay</button>
            </div>
        </div>
    }
    else
    {
        @foreach (var tour in tours)
        {
            <div class="col-md-6 col-xl-4">
                <div class="tour-item-card">
                    <div class="card-header-row">
                        <div class="card-status-pill">
                            <span class="status-dot"></span> Đang hoạt động
                        </div>
                        <div class="card-header-actions">
                            <button class="btn-icon-sm" title="Chỉnh sửa" @onclick="() => OpenEditModal(tour)">
                                <i class="bi bi-pencil-fill"></i>
                            </button>
                            <button class="btn-icon-sm btn-icon-danger" title="Xóa tour" @onclick="() => DeleteTour(tour.TourId)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    </div>

                    <div class="card-main-info">
                        <h4 class="tour-name">@tour.Name</h4>
                        <p class="tour-desc">@tour.Description</p>
                    </div>

                    <div class="card-stats">
                        <div class="stat-chip">
                            <i class="bi bi-clock text-primary"></i>
                            <span>@FormatDuration(tour.DurationMinutes)</span>
                        </div>
                        <div class="stat-chip">
                            <i class="bi bi-wallet2 text-success"></i>
                            <span>@FormatPrice(tour.Price)</span>
                        </div>
                        <div class="stat-chip">
                            <i class="bi bi-geo-alt text-danger"></i>
                            <span>@(tour.Pois?.Count ?? 0) quán</span>
                        </div>
                    </div>

                    @if (tour.Pois != null && tour.Pois.Any())
                    {
                        <div class="card-poi-preview">
                            @foreach (var stop in tour.Pois.OrderBy(p => p.SequenceOrder).Take(4))
                            {
                                <div class="poi-mini-badge" title="@stop.Poi?.Name">
                                    <span class="poi-mini-number">@stop.SequenceOrder</span>
                                    <span class="poi-mini-name">@stop.Poi?.Name</span>
                                </div>
                            }
                            @if (tour.Pois.Count > 4)
                            {
                                <div class="poi-mini-badge poi-mini-more">+@(tour.Pois.Count - 4)</div>
                            }
                        </div>
                    }

                    <div class="card-actions">
                        <button class="btn-manage" @onclick='(() => Navigation.NavigateTo($"/tours/{tour.TourId}/manage"))'>
                            Thiết lập lộ trình <i class="bi bi-arrow-right-short"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@* ── Edit Modal ── *@
@if (showEditModal && editingTour != null)
{
    <div class="modal-overlay" @onclick="CloseEditModal">
        <div class="modal-glass" @onclick:stopPropagation="true">
            <div class="modal-glass-header">
                <h4 class="fw-800 mb-0">Chỉnh sửa Tour</h4>
                <button class="btn-close-modal" @onclick="CloseEditModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-glass-body">
                <div class="mb-4">
                    <label class="form-label-custom">Tên Tour</label>
                    <input type="text" @bind="editingTour.Name" class="form-control glass-input" />
                </div>
                <div class="mb-4">
                    <label class="form-label-custom">Mô tả</label>
                    <textarea @bind="editingTour.Description" class="form-control glass-input" rows="3"></textarea>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label-custom">Thời lượng (phút)</label>
                        <input type="number" @bind="editingTour.DurationMinutes" class="form-control glass-input" min="15" step="15" />
                        <div class="input-hint mt-1">≈ @FormatDuration(editingTour.DurationMinutes)</div>
                    </div>
                    <div class="col-6">
                        <label class="form-label-custom">Giá Tour (VNĐ)</label>
                        <input type="number" @bind="editingTour.Price" class="form-control glass-input" min="0" step="10000" />
                        <div class="input-hint mt-1">≈ @FormatPrice(editingTour.Price)</div>
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label-custom">Chọn nhanh thời gian</label>
                    <div class="preset-chips">
                        @foreach (var d in new[] { 30, 60, 90, 120, 150, 180 })
                        {
                            var minutes = d;
                            <button class="preset-chip @(editingTour.DurationMinutes == minutes ? "active" : "")" @onclick="() => editingTour.DurationMinutes = minutes">@FormatDuration(minutes)</button>
                        }
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label-custom">Chọn nhanh giá</label>
                    <div class="preset-chips">
                        @foreach (var p in new[] { 50000m, 100000m, 150000m, 200000m, 300000m, 500000m })
                        {
                            var price = p;
                            <button class="preset-chip @(editingTour.Price == price ? "active" : "")" @onclick="() => editingTour.Price = price">@FormatPrice(price)</button>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-glass-footer">
                <button class="btn btn-light rounded-pill px-4 fw-bold" @onclick="CloseEditModal">Hủy</button>
                <button class="btn btn-dark rounded-pill px-5 fw-bold" @onclick="SaveEdit">
                    <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
}


