@page "/audio-management"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IPoiGuideService GuideService
@inject IPoiService PoiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable
@attribute [Authorize(Roles = "admin")]

<PageTitle>Quản lý Audio Guide - FoodMap Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-5 mt-2 animate-fade-in">
    <div>
        <h2 class="mb-1" style="font-size: 2.2rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Quản lí Audio</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">Quản lý thuyết minh đa ngôn ngữ cho các địa điểm</p>
    </div>
    <button class="glass-btn pulse-animation" style="padding: 1rem 2.2rem; font-size: 1.05rem; border-radius: 20px; box-shadow: 0 15px 35px var(--primary-glow);" @onclick="@(() => Navigation.NavigateTo("/audio-add"))">
        <i class="bi bi-plus-lg me-2"></i> Thêm Audio mới
    </button>
</div>


<!-- Table Section -->
<div class="card shadow-glass border-0 animate-stagger" style="border-radius: 30px; overflow: hidden; background: var(--surface);">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr style="background: rgba(255, 45, 133, 0.03);">
                    <th style="padding: 1.5rem 2rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Địa điểm / Thuyết minh</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; text-align: center;">Ngôn ngữ hỗ trợ</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; text-align: center;">Nghe thử</th>
                    <th style="padding: 1.5rem 2rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (poiGroups == null) {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="loader-spinner"></div>
                            <p class="mt-3 text-muted">Đang tải dữ liệu thuyết minh...</p>
                        </td>
                    </tr>
                } else if (!poiGroups.Any()) {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="empty-state py-4">
                                <i class="bi bi-mic-mute text-muted" style="font-size: 4rem; opacity: 0.2;"></i>
                                <h4 class="mt-3 font-weight-bold">Chưa có bản thuyết minh nào</h4>
                                <p class="text-muted">Hãy bắt đầu bằng việc thêm bản thuyết minh cho các địa điểm.</p>
                            </div>
                        </td>
                    </tr>
                } else {
                    @foreach (var group in poiGroups) {
                        <tr class="align-middle">
                            <td style="padding: 1.2rem 2rem;">
                                <div class="d-flex align-items-center">
                                    <div class="poi-avatar-modern me-3">
                                        @(group.Poi.Name.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div style="font-weight: 800; color: var(--text-main); font-size: 1.1rem;">@group.Poi.Name</div>
                                        <div class="text-muted" style="font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-bookmark-fill me-1" style="color: var(--primary); opacity: 0.6;"></i>
                                            @(group.GetActiveGuide()?.Title ?? "Chưa có tiêu đề")
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td style="text-align: center;">
                                <div class="lang-status-row">
                                    <div class="lang-dot @(group.Guides.Any(g => g.Language == "vi") ? "active" : "")" title="Tiếng Việt">VI</div>
                                    <div class="lang-dot @(group.Guides.Any(g => g.Language == "en") ? "active" : "")" title="Tiếng Anh">EN</div>
                                    <div class="lang-dot @(group.Guides.Any(g => g.Language == "zh") ? "active" : "")" title="Tiếng Trung">ZH</div>
                                    <div class="lang-dot @(group.Guides.Any(g => g.Language == "ko") ? "active" : "")" title="Tiếng Hàn">KO</div>
                                    <div class="lang-dot @(group.Guides.Any(g => g.Language == "ja") ? "active" : "")" title="Tiếng Nhật">JA</div>
                                </div>
                            </td>
                            <td style="text-align: center;">
                                <div class="play-action-btns">
                                    <button class="btn-play-mini vi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "vi" && isActuallyPlaying && !isPaused ? "playing" : "")" 
                                            disabled="@(!group.Guides.Any(g => g.Language == "vi"))"
                                            @onclick="@(() => PlayAudio(group, "vi"))">
                                        <i class="bi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "vi" && isActuallyPlaying && !isPaused ? "bi-pause-fill" : "bi-play-fill")"></i>
                                    </button>
                                    <button class="btn-play-mini en @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "en" && isActuallyPlaying && !isPaused ? "playing" : "")" 
                                            disabled="@(!group.Guides.Any(g => g.Language == "en"))"
                                            @onclick="@(() => PlayAudio(group, "en"))">
                                        <i class="bi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "en" && isActuallyPlaying && !isPaused ? "bi-pause-fill" : "bi-play-fill")"></i>
                                    </button>
                                    <button class="btn-play-mini zh @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "zh" && isActuallyPlaying && !isPaused ? "playing" : "")" 
                                            disabled="@(!group.Guides.Any(g => g.Language == "zh"))"
                                            @onclick="@(() => PlayAudio(group, "zh"))">
                                        <i class="bi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "zh" && isActuallyPlaying && !isPaused ? "bi-pause-fill" : "bi-play-fill")"></i>
                                    </button>
                                    <button class="btn-play-mini ko @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "ko" && isActuallyPlaying && !isPaused ? "playing" : "")" 
                                            disabled="@(!group.Guides.Any(g => g.Language == "ko"))"
                                            @onclick="@(() => PlayAudio(group, "ko"))">
                                        <i class="bi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "ko" && isActuallyPlaying && !isPaused ? "bi-pause-fill" : "bi-play-fill")"></i>
                                    </button>
                                    <button class="btn-play-mini ja @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "ja" && isActuallyPlaying && !isPaused ? "playing" : "")" 
                                            disabled="@(!group.Guides.Any(g => g.Language == "ja"))"
                                            @onclick="@(() => PlayAudio(group, "ja"))">
                                        <i class="bi @(currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == "ja" && isActuallyPlaying && !isPaused ? "bi-pause-fill" : "bi-play-fill")"></i>
                                    </button>
                                </div>
                            </td>
                            <td style="text-align: center; padding-right: 2rem; white-space: nowrap;">
                                <div style="display: flex !important; flex-direction: row !important; justify-content: center; align-items: center; gap: 0.75rem;">
                                    <button class="action-btn btn-edit" title="Chỉnh sửa" @onclick="() => NavigateToEdit(group)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="action-btn btn-delete" title="Xóa" @onclick="() => DeleteGuide(group)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (isPlayerVisible && currentPlayingPoi != null)
{
    <div class="audio-player-fixed animate-slide-up">
        <div class="player-content">
            <div class="player-info">
                <div class="player-avatar">
                    <i class="bi bi-mic-fill"></i>
                </div>
                <div class="player-text">
                    <div class="player-poi-name">@currentPlayingPoi.Name</div>
                    <div class="player-status">
                        @if (isPaused) { <span class="text-warning">Đã tạm dừng</span> }
                        else { <span class="text-primary">Đang thuyết minh...</span> }
                    </div>
                </div>
            </div>

            <div class="player-controls">
                <button class="player-btn toggle-btn" @onclick="TogglePlayPause">
                    <i class="bi @(isPaused ? "bi-play-fill" : "bi-pause-fill")"></i>
                </button>
                <button class="player-btn stop-btn" @onclick="StopAudio">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="player-progress-container">
            <div class="player-progress-bar" style="width: @(ttsProgress)%"></div>
        </div>
    </div>
}

<style>
    /* Stats Layout */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .stat-glass {
        background: white;
        padding: 1.2rem 1.5rem;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
        display: flex;
        align-items: center;
        gap: 1.2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: #f8f9fb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--primary);
    }
    .stat-icon.vi { background: rgba(255, 45, 133, 0.05); }
    .stat-icon.en { background: rgba(0, 150, 255, 0.05); }
    .stat-icon.zh { background: rgba(255, 100, 0, 0.05); }

    .stat-info .sv { display: block; font-size: 1.6rem; font-weight: 900; color: var(--text-main); line-height: 1; }
    .stat-info .sl { font-size: 0.75rem; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Table & Card */
    .shadow-glass {
        box-shadow: 0 20px 60px rgba(0,0,0,0.03) !important;
        border: 1px solid var(--glass-border) !important;
    }

    .poi-avatar-modern {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.3rem;
        box-shadow: 0 8px 18px var(--primary-glow);
    }

    /* Language Status Dots */
    .lang-status-row { display: flex; gap: 0.6rem; justify-content: center; }
    .lang-dot {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: #f0f2f5;
        color: #BCC;
        font-size: 0.65rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }
    .lang-dot.active {
        background: rgba(255, 45, 133, 0.1);
        color: var(--primary);
        border: 1px solid rgba(255, 45, 133, 0.2);
    }

    /* Mini Play Buttons */
    .play-action-btns { display: flex; gap: 0.5rem; justify-content: center; }
    .btn-play-mini {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        background: #f0f2f5;
        color: #999;
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .btn-play-mini:hover:not(:disabled) { transform: scale(1.15); }
    .btn-play-mini.vi:hover:not(:disabled) { background: #E6FFFA; color: #38B2AC; }
    .btn-play-mini.en:hover:not(:disabled) { background: #EBF4FF; color: #4299E1; }
    .btn-play-mini.zh:hover:not(:disabled) { background: #FFF5F5; color: #E53E3E; }
    .btn-play-mini.ko:hover:not(:disabled) { background: #F5F3FF; color: #7C3AED; }
    .btn-play-mini.ja:hover:not(:disabled) { background: #FFF1F2; color: #E11D48; }
    
    .btn-play-mini.playing {
        background: var(--primary) !important;
        color: white !important;
        box-shadow: 0 5px 15px var(--primary-glow);
        animation: mini-pulse 1.5s infinite;
    }

    @@keyframes mini-pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .btn-play-mini:disabled { opacity: 0.3; cursor: not-allowed; }

    /* Action Buttons */
    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        font-size: 1.1rem;
    }
    .btn-edit { background: rgba(255, 45, 133, 0.05); color: var(--primary); }
    .btn-edit:hover { background: var(--primary); color: white; transform: translateY(-2px); }
    .btn-delete { background: rgba(255, 0, 0, 0.05); color: #ff4d4f; }
    .btn-delete:hover { background: #ff4d4f; color: white; transform: translateY(-2px); }

    /* Animations */
    .animate-fade-in { animation: fadeIn 0.6s ease-out; }
    .animate-slide-up { animation: slideUp 0.7s cubic-bezier(0.19, 1, 0.22, 1); }
    .animate-stagger > * { animation: slideUp 0.6s cubic-bezier(0.19, 1, 0.22, 1) both; }
    .animate-stagger > *:nth-child(1) { animation-delay: 0.1s; }
    .animate-stagger > *:nth-child(2) { animation-delay: 0.2s; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .loader-spinner {
        width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid var(--primary);
        border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto;
    }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Floating Player Styles */
    .audio-player-fixed {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 45, 133, 0.2);
        border-radius: 25px;
        box-shadow: 0 20px 50px rgba(255, 45, 133, 0.15);
        z-index: 1000;
        padding: 0;
        overflow: hidden;
    }

    .player-content {
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .player-info { display: flex; align-items: center; gap: 1rem; }
    .player-avatar {
        width: 40px; height: 40px; background: var(--primary); color: white;
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
    }
    .player-poi-name { font-weight: 800; color: #1A1A1A; font-size: 1rem; line-height: 1.2; }
    .player-status { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }

    .player-controls { display: flex; gap: 0.8rem; }
    .player-btn {
        width: 40px; height: 40px; border-radius: 50%; border: none;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; transition: all 0.2s;
    }
    .toggle-btn { background: var(--primary); color: white; box-shadow: 0 5px 15px var(--primary-glow); }
    .toggle-btn:hover { transform: scale(1.1); }
    .stop-btn { background: #f0f2f5; color: #666; }
    .stop-btn:hover { background: #fee2e2; color: #ef4444; }

    .player-progress-container { width: 100%; height: 4px; background: rgba(0,0,0,0.05); }
    .player-progress-bar { height: 100%; background: var(--primary); transition: width 0.3s; }

    .animate-slide-up { animation: playerSlideUp 0.5s cubic-bezier(0.19, 1, 0.22, 1); }
    @@keyframes playerSlideUp { from { transform: translate(-50%, 100px); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
</style>

@code {
    private List<PoiGroup>? poiGroups;
    private DotNetObjectReference<AudioManagement>? dotNetHelper;
    private Poi? currentPlayingPoi;
    private string currentLang = "vi";
    private int ttsProgress = 0;
    private bool isPlayerVisible = false;
    private bool isActuallyPlaying = false;
    private bool isPaused = false;

    public class PoiGroup {
        public Poi Poi { get; set; } = null!;
        public List<PoiGuide> Guides { get; set; } = new();

        public PoiGuide? GetActiveGuide() =>
            Guides.FirstOrDefault(g => g.Language == "vi") ?? Guides.FirstOrDefault();
    }

    protected override async Task OnInitializedAsync() {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            dotNetHelper = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("ttsHelper.init", dotNetHelper);
        }
    }

    private async Task LoadData() {
        try {
            var guides = await GuideService.GetAllGuidesAsync();
            var allPois = await PoiService.GetAllPoisAsync();
            poiGroups = allPois
                .Where(p => guides.Any(g => g.PoiId == p.PoiId))
                .Select(p => new PoiGroup {
                    Poi = p,
                    Guides = guides.Where(g => g.PoiId == p.PoiId).ToList()
                })
                .ToList();
        } catch (Exception ex) {
            Console.WriteLine($"LoadData error: {ex.Message}");
            poiGroups = new();
        }
    }

    [JSInvokable]
    public void OnTtsProgress(int progress) {
        ttsProgress = progress;
        isActuallyPlaying = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnTtsFinished() {
        isActuallyPlaying = false;
        isPaused = false;
        ttsProgress = 100;
        await InvokeAsync(StateHasChanged);

        // Wait a bit to let the user see the progress at 100%
        await Task.Delay(1000);

        // Only hide the player if no NEW audio has started playing in the meantime
        if (!isActuallyPlaying) {
            isPlayerVisible = false;
            currentPlayingPoi = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task TogglePlayPause() {
        if (!isActuallyPlaying) return;
        if (!isPaused) {
            await JSRuntime.InvokeVoidAsync("ttsHelper.pause");
            isPaused = true;
        } else {
            await JSRuntime.InvokeVoidAsync("ttsHelper.resume");
            isPaused = false;
        }
        StateHasChanged();
    }

    private async Task PlayAudio(PoiGroup group, string lang) {
        var guide = group.Guides.FirstOrDefault(g => g.Language == lang);
        if (guide == null || string.IsNullOrEmpty(guide.Description)) return;

        // Nếu có audio đang chạy...
        if (isActuallyPlaying) {
            // ...mà là cùng quán và cùng ngôn ngữ -> Toggle Pause/Resume
            if (currentPlayingPoi?.PoiId == group.Poi.PoiId && currentLang == lang) {
                if (!isPaused) {
                    await JSRuntime.InvokeVoidAsync("ttsHelper.pause");
                    isPaused = true;
                } else {
                    await JSRuntime.InvokeVoidAsync("ttsHelper.resume");
                    isPaused = false;
                }
                StateHasChanged();
                return;
            }
            
            // ...nếu là quán khác hoặc ngôn ngữ khác -> Không làm gì (Yêu cầu phải bấm Stop trước)
            await JSRuntime.InvokeVoidAsync("alert", "Hệ thống đang phát thuyết minh khác. Vui lòng bấm Dừng (Stop) trước khi chọn thuyết minh mới.");
            return;
        }

        // Nếu mới hoặc đổi quán (và không có cái nào đang chạy) -> Phát mới từ đầu
        currentPlayingPoi = group.Poi;
        currentLang = lang;
        ttsProgress = 0;
        isPaused = false;
        isPlayerVisible = true;
        isActuallyPlaying = true;
        StateHasChanged();

        await JSRuntime.InvokeVoidAsync("ttsHelper.speak", guide.Description, lang);
    }


    private async Task StopAudio() {
        await JSRuntime.InvokeVoidAsync("ttsHelper.stop");
        isPlayerVisible = false;
        isActuallyPlaying = false;
        isPaused = false;
        ttsProgress = 0;
        StateHasChanged();
    }

    private void NavigateToEdit(PoiGroup group) {
        var guide = group.Guides.FirstOrDefault(g => g.Language == "vi") ?? group.Guides.FirstOrDefault();
        if (guide != null) Navigation.NavigateTo($"/audio-edit/{guide.GuideId}");
    }

    private async Task DeleteGuide(PoiGroup group) {
        var ok = await JSRuntime.InvokeAsync<bool>("confirm", $"Xóa toàn bộ thuyết minh của \"{group.Poi.Name}\"?");
        if (!ok) return;
        foreach (var g in group.Guides) await GuideService.DeleteGuideAsync(g.GuideId);
        await LoadData();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync() {
        if (dotNetHelper != null) {
            try { await JSRuntime.InvokeVoidAsync("ttsHelper.stop"); } catch { }
            dotNetHelper.Dispose();
        }
    }
}
