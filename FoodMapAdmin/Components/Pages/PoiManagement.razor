@page "/pois"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IPoiService PoiService
@inject IPoiPendingChangeService PendingChangeService
@inject NavigationManager Navigator
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin,CNH")]

<PageTitle>Quản lý Quán ăn - FoodMap Admin</PageTitle>

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
    <div>
        <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 0.2rem;">Quán ăn & Địa điểm</h2>
        <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">Quản lý danh sách các điểm đến trên hệ thống FoodMap</p>
    </div>
    <button class="glass-btn" @onclick="AddNew">
        <i class="bi bi-plus-lg"></i> Thêm quán mới
    </button>
</div>

<!-- Table Card -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="padding-left: 1.75rem; width: 70px;">Mã</th>
                    <th>Tên quán ăn</th>
                    <th>Danh mục</th>
                    <th>Địa chỉ</th>
                    <th>Chủ sở hữu</th>
                    <th style="text-align: center; width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (pois == null)
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 3rem 0;">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                        </td>
                    </tr>
                }
                else if (!pois.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
                            <i class="bi bi-shop-window" style="font-size: 2.5rem; opacity: 0.2; display: block; margin-bottom: 0.5rem;"></i>
                            Chưa có dữ liệu quán ăn nào
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var poi in pois)
                    {
                        <tr>
                            <td style="padding-left: 1.75rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem;">#@poi.PoiId</td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div class="poi-avatar">@(poi.Name.Substring(0, 1).ToUpper())</div>
                                    <div>
                                        <div style="font-weight: 700; color: var(--text-main); font-size: 0.92rem;">
                                            @poi.Name
                                            @if (pendingChangesList.Any(pc => pc.PoiId == poi.PoiId))
                                            {
                                                var change = pendingChangesList.FirstOrDefault(pc => pc.PoiId == poi.PoiId);
                                                string badgeText = change?.ChangeType == "delete" ? "CHỜ XÓA" : "CHỜ SỬA";
                                                string badgeColor = change?.ChangeType == "delete" ? "background: rgba(255,71,87,0.08); color: #FF4757;" : "background: rgba(255,159,67,0.08); color: #FF9F43;";
                                                <span style="@badgeColor padding: 0.2rem 0.5rem; border-radius: 6px; font-size: 0.62rem; font-weight: 700; margin-left: 0.4rem; letter-spacing: 0.3px;">
                                                    @badgeText
                                                </span>
                                            }
                                        </div>
                                        <div style="color: var(--text-muted); font-size: 0.78rem;">@poi.OpenTime</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="cat-badge">@(poi.Category?.CategoryName ?? "Chưa phân loại")</span>
                            </td>
                            <td>
                                <div style="color: var(--text-secondary); font-size: 0.85rem; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@poi.Address">
                                    @poi.Address
                                </div>
                            </td>
                            <td>
                                <span class="owner-pill">
                                    <i class="bi bi-person-circle"></i> @(poi.Owner?.Username ?? "Hệ thống")
                                </span>
                            </td>
                            <td style="text-align: center;">
                                <div style="display: flex; justify-content: center; gap: 0.5rem;">
                                    <button class="act-btn act-edit" title="Chỉnh sửa" @onclick="() => Edit(poi.PoiId)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="act-btn act-del" title="Xóa" @onclick="() => Delete(poi.PoiId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .poi-avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
        box-shadow: 0 4px 12px var(--primary-glow);
    }

    .cat-badge {
        padding: 0.3rem 0.75rem;
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        background: var(--primary-subtle);
        color: var(--primary);
    }

    .owner-pill {
        background: var(--bg);
        padding: 0.3rem 0.65rem;
        border-radius: var(--radius-sm);
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .act-btn {
        width: 34px;
        height: 34px;
        border-radius: var(--radius-sm);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s var(--ease-out);
        font-size: 0.95rem;
        cursor: pointer;
    }

    .act-edit {
        background: var(--primary-subtle);
        color: var(--primary);
    }

    .act-edit:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-1px);
    }

    .act-del {
        background: rgba(255, 71, 87, 0.06);
        color: #FF4757;
    }

    .act-del:hover {
        background: #FF4757;
        color: white;
        transform: translateY(-1px);
    }
</style>

@code {
    private List<Poi>? pois;
    private List<PoiPendingChange> pendingChangesList = new();
    
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (AuthStateTask != null)
            {
                var authState = await AuthStateTask;
                var user = authState.User;

                if (user.IsInRole("admin"))
                {
                    pois = await PoiService.GetAllPoisAsync();
                }
                else if (user.IsInRole("CNH"))
                {
                    var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    if (int.TryParse(userIdStr, out var userId))
                    {
                        pois = await PoiService.GetPoisByOwnerAsync(userId);
                    }
                }

                // Load pending changes to show badges
                pendingChangesList = await PendingChangeService.GetPendingChangesAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex.Message}");
            pois = new List<Poi>(); // Avoid sticking with spinner on error
        }
    }

    private void AddNew() => Navigator.NavigateTo("/pois/add");
    private void Edit(int id) => Navigator.NavigateTo($"/pois/edit/{id}");
    
    private async Task Delete(int id) {
        var authState = await AuthStateTask!;
        var user = authState.User;
        var poi = pois?.FirstOrDefault(p => p.PoiId == id);
        if (poi == null) return;

        string msg = user.IsInRole("admin") 
            ? "Bạn có chắc chắn muốn xóa quán ăn này không? Hành động này không thể hoàn tác."
            : "Bạn có chắc chắn muốn gửi yêu cầu XÓA quán ăn này? Hệ thống sẽ ẩn quán ngay sau khi Admin phê duyệt.";

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", msg);
        if (confirmed)
        {
            if (user.IsInRole("admin"))
            {
                if (await PoiService.DeletePoiAsync(id))
                {
                    pois = pois?.Where(p => p.PoiId != id).ToList();
                    StateHasChanged();
                }
            }
            else
            {
                // CNH: Create delete request
                var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(userIdStr, out var userId))
                {
                    if (await PendingChangeService.CreatePendingChangeAsync(poi, userId, "delete"))
                    {
                        await JSRuntime.InvokeVoidAsync("alert", "Yêu cầu xóa đã được gửi. Quán sẽ biến mất sau khi được Admin phê duyệt.");
                        pendingChangesList = await PendingChangeService.GetPendingChangesAsync();
                        StateHasChanged();
                    }
                }
            }
        }
    }
}
