@page "/pois"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IPoiService PoiService
@inject IPoiPendingChangeService PendingChangeService
@inject NavigationManager Navigator
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin,CNH")]

<PageTitle>Quản lý Quán ăn - FoodMap Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-5 mt-2">
    <div>
        <h2 class="mb-1" style="font-size: 2.2rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Quán ăn & Địa điểm</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">Quản lý danh sách các điểm đến trên hệ thống FoodMap</p>
    </div>
    <button class="glass-btn pulse-animation" style="padding: 1rem 2.2rem; font-size: 1.05rem; border-radius: 20px; box-shadow: 0 15px 35px var(--primary-glow);" @onclick="AddNew">
        <i class="bi bi-plus-lg me-2"></i> Thêm quán mới
    </button>
</div>

<div class="card shadow-glass border-0" style="border-radius: 30px; overflow: hidden; background: var(--surface);">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr style="background: rgba(255, 45, 133, 0.03);">
                    <th style="padding: 1.5rem 1rem 1.5rem 2rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Mã số</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Tên quán ăn</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Danh mục</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Địa chỉ</th>
                    <th style="padding: 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Chủ sở hữu</th>
                    <th style="padding: 1.5rem 2rem 1.5rem 1rem; border-bottom: 2px solid rgba(255, 45, 133, 0.05); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (pois == null)
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                        </td>
                    </tr>
                }
                else if (!pois.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="empty-state">
                                <i class="bi bi-shop-window text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                                <p class="text-muted mt-3">Chưa có dữ liệu quán ăn nào.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var poi in pois)
                    {
                        <tr class="align-middle transition-all">
                            <td style="padding-left: 2rem; color: var(--text-muted); font-weight: 600;">#@poi.PoiId</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="poi-avatar me-3">
                                        @(poi.Name.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div style="font-weight: 800; color: var(--text-main); font-size: 1.05rem;">
                                            @poi.Name 
                                            @if (pendingChangesList.Any(pc => pc.PoiId == poi.PoiId))
                                            {
                                                var change = pendingChangesList.FirstOrDefault(pc => pc.PoiId == poi.PoiId);
                                                string badgeText = change?.ChangeType == "delete" ? "CHỜ DUYỆT XÓA" : "CHỜ DUYỆT SỬA";
                                                string badgeClass = change?.ChangeType == "delete" ? "bg-danger text-white" : "bg-warning text-dark";
                                                <span class="badge rounded-pill @badgeClass ms-2" style="font-size: 0.65rem; font-weight: 700; padding: 0.3rem 0.6rem; vertical-align: middle;">
                                                    <i class="bi bi-clock-history"></i> @badgeText
                                                </span>
                                            }
                                        </div>
                                        <div class="text-muted" style="font-size: 0.8rem;">@poi.OpenTime</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-custom @(poi.Category?.CategoryName == "Hải sản" ? "badge-blue" : "badge-pink")">
                                    @(poi.Category?.CategoryName ?? "Chưa phân loại")
                                </span>
                            </td>
                            <td>
                                <div class="text-muted text-truncate" style="max-width: 250px; font-size: 0.9rem;" title="@poi.Address">
                                    <i class="bi bi-geo-alt-fill me-1" style="color: var(--primary); opacity: 0.6;"></i> @poi.Address
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="owner-pill">
                                        <i class="bi bi-person-circle me-1"></i> @(poi.Owner?.Username ?? "Hệ thống")
                                    </span>
                                </div>
                            </td>
                            <td style="text-align: center; padding-right: 2rem; white-space: nowrap;">
                                <div style="display: flex !important; flex-direction: row !important; justify-content: center; align-items: center; gap: 0.75rem;">
                                    <button class="action-btn btn-edit" title="Chỉnh sửa" @onclick="() => Edit(poi.PoiId)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="action-btn btn-delete" title="Xóa" @onclick="() => Delete(poi.PoiId)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .shadow-glass {
        box-shadow: 0 20px 60px rgba(0,0,0,0.03) !important;
        border: 1px solid var(--glass-border) !important;
    }

    .poi-avatar {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        box-shadow: 0 8px 20px var(--primary-glow);
    }

    .badge-custom {
        padding: 0.5rem 1.1rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-pink {
        background: rgba(255, 45, 133, 0.08);
        color: var(--primary);
        border: 1px solid rgba(255, 45, 133, 0.1);
    }

    .badge-blue {
        background: rgba(0, 184, 212, 0.08);
        color: #00acc1;
        border: 1px solid rgba(0, 184, 212, 0.1);
    }

    .owner-pill {
        background: #f8f8f8;
        padding: 0.4rem 0.8rem;
        border-radius: 10px;
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 600;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        font-size: 1.1rem;
    }

    .btn-edit {
        background: rgba(255, 45, 133, 0.05);
        color: var(--primary);
    }

    .btn-edit:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: rgba(255, 0, 0, 0.05);
        color: #ff4d4f;
    }

    .btn-delete:hover {
        background: #ff4d4f;
        color: white;
        transform: translateY(-2px);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    tr:hover {
        background: rgba(255, 45, 133, 0.01) !important;
        transform: scale(1.002);
    }

    .pulse-animation:active {
        transform: scale(0.95);
    }
</style>

@code {
    private List<Poi>? pois;
    private List<PoiPendingChange> pendingChangesList = new();
    
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (AuthStateTask != null)
            {
                var authState = await AuthStateTask;
                var user = authState.User;

                if (user.IsInRole("admin"))
                {
                    pois = await PoiService.GetAllPoisAsync();
                }
                else if (user.IsInRole("CNH"))
                {
                    var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    if (int.TryParse(userIdStr, out var userId))
                    {
                        pois = await PoiService.GetPoisByOwnerAsync(userId);
                    }
                }

                // Load pending changes to show badges
                pendingChangesList = await PendingChangeService.GetPendingChangesAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex.Message}");
            pois = new List<Poi>(); // Avoid sticking with spinner on error
        }
    }

    private void AddNew() => Navigator.NavigateTo("/pois/add");
    private void Edit(int id) => Navigator.NavigateTo($"/pois/edit/{id}");
    
    private async Task Delete(int id) {
        var authState = await AuthStateTask!;
        var user = authState.User;
        var poi = pois?.FirstOrDefault(p => p.PoiId == id);
        if (poi == null) return;

        string msg = user.IsInRole("admin") 
            ? "Bạn có chắc chắn muốn xóa quán ăn này không? Hành động này không thể hoàn tác."
            : "Bạn có chắc chắn muốn gửi yêu cầu XÓA quán ăn này? Hệ thống sẽ ẩn quán ngay sau khi Admin phê duyệt.";

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", msg);
        if (confirmed)
        {
            if (user.IsInRole("admin"))
            {
                if (await PoiService.DeletePoiAsync(id))
                {
                    pois = pois?.Where(p => p.PoiId != id).ToList();
                    StateHasChanged();
                }
            }
            else
            {
                // CNH: Create delete request
                var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(userIdStr, out var userId))
                {
                    if (await PendingChangeService.CreatePendingChangeAsync(poi, userId, "delete"))
                    {
                        await JSRuntime.InvokeVoidAsync("alert", "Yêu cầu xóa đã được gửi. Quán sẽ biến mất sau khi được Admin phê duyệt.");
                        pendingChangesList = await PendingChangeService.GetPendingChangesAsync();
                        StateHasChanged();
                    }
                }
            }
        }
    }
}
