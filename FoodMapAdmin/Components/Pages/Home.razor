@page "/"

<PageTitle>Dashboard - FoodMap Admin</PageTitle>

<div class="dashboard-stats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
    <div class="card">
        <p style="color: var(--text-muted); margin-bottom: 0.5rem;">Total Restaurants</p>
        <h2 style="font-size: 2.5rem; margin: 0;">128</h2>
        <p style="color: #4CAF50; font-size: 0.9rem; margin-top: 0.5rem;">+12% from last month</p>
    </div>
    <div class="card">
        <p style="color: var(--text-muted); margin-bottom: 0.5rem;">Total Reviews</p>
        <h2 style="font-size: 2.5rem; margin: 0;">1.2k</h2>
        <p style="color: #4CAF50; font-size: 0.9rem; margin-top: 0.5rem;">+5% from last week</p>
    </div>
    <div class="card">
        <p style="color: var(--text-muted); margin-bottom: 0.5rem;">Active Users</p>
        <h2 style="font-size: 2.5rem; margin: 0;">450</h2>
        <p style="color: var(--primary); font-size: 0.9rem; margin-top: 0.5rem;">Ongoing promotion</p>
    </div>
</div>

<div class="card">
    <h3>Recent Activity</h3>
    <table style="width: 100%; border-collapse: collapse; margin-top: 1.5rem;">
        <thead>
            <tr style="text-align: left; border-bottom: 1px solid var(--glass);">
                <th style="padding: 1rem;">Action</th>
                <th style="padding: 1rem;">User</th>
                <th style="padding: 1rem;">Target</th>
                <th style="padding: 1rem;">Time</th>
            </tr>
        </thead>
        <tbody>
            <tr style="border-bottom: 1px solid var(--glass);">
                <td style="padding: 1rem;">New Review</td>
                <td style="padding: 1rem;">Nguyen Van A</td>
                <td style="padding: 1rem;">Oc Bui Vien</td>
                <td style="padding: 1rem;">2 mins ago</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--glass);">
                <td style="padding: 1rem;">Update Info</td>
                <td style="padding: 1rem;">Chu Quan 1</td>
                <td style="padding: 1rem;">Hai San 5KU</td>
                <td style="padding: 1rem;">15 mins ago</td>
            </tr>
            <tr>
                <td style="padding: 1rem;">New Registration</td>
                <td style="padding: 1rem;">Admin</td>
                <td style="padding: 1rem;">User "Tran B"</td>
                <td style="padding: 1rem;">1 hour ago</td>
            </tr>
        </tbody>
    </table>
</div>
