@page "/"
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IDashboardService DashService
@inject NavigationManager Navigator

<PageTitle>Tổng quan - FoodMap Admin</PageTitle>

@if (stats == null)
{
    <div style="display: flex; justify-content: center; padding: 4rem 0;">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else
{
    <!-- Page Header -->
    <div style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.65rem; font-weight: 800; margin-bottom: 0.25rem; color: var(--text-main);">Tổng quan hệ thống</h2>
        <p style="color: var(--text-muted); font-size: 0.88rem; margin: 0;">Theo dõi hoạt động và dữ liệu FoodMap</p>
    </div>

    <!-- Stats Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 2rem;">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(248, 43, 96, 0.1); color: var(--primary);"><i class="bi bi-shop"></i></div>
            <div class="stat-info">
                <span class="stat-label">Tổng số quán ăn</span>
                <span class="stat-value">@stats.TotalPois</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(108, 92, 231, 0.1); color: #6c5ce7;"><i class="bi bi-shield-lock"></i></div>
            <div class="stat-info">
                <span class="stat-label">Quản trị viên</span>
                <span class="stat-value">@stats.TotalAdmins</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(69, 170, 242, 0.1); color: #45AAF2;"><i class="bi bi-person-badge"></i></div>
            <div class="stat-info">
                <span class="stat-label">Chủ nhà hàng</span>
                <span class="stat-value">@stats.TotalOwners</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(46, 213, 115, 0.1); color: #2ED573;"><i class="bi bi-people"></i></div>
            <div class="stat-info">
                <span class="stat-label">Khách hàng</span>
                <span class="stat-value">@stats.TotalCustomers</span>
            </div>
        </div>
    </div>

    <!-- Activity Table -->
    <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 1.5rem 1.75rem 1rem;">
            <h3 style="font-size: 1.05rem; font-weight: 700; margin: 0; color: var(--text-main);">Hoạt động gần đây</h3>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="table-layout: fixed; width: 100%;">
                <thead>
                    <tr>
                        <th style="width: 22%; padding-left: 1.75rem;">Hành động</th>
                        <th style="width: 23%;">Người thực hiện</th>
                        <th style="width: 35%;">Đối tượng</th>
                        <th style="width: 20%;">Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                    @if (stats.RecentActivities == null || !stats.RecentActivities.Any())
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
                                <i class="bi bi-inbox" style="font-size: 2rem; opacity: 0.3; display: block; margin-bottom: 0.5rem;"></i>
                                Chưa có hoạt động nào gần đây
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var activity in stats.RecentActivities)
                        {
                            <tr>
                                <td style="padding-left: 1.75rem;">
                                    <span class="activity-badge @(activity.ActionType switch { 
                                        "Đăng ký mới" => "ab-pink",
                                        "Thêm quán ăn mới" => "ab-pink",
                                        "Cập nhật thông tin" => "ab-blue",
                                        "Thêm danh mục" => "ab-pink",
                                        "Xóa quán ăn" => "ab-red",
                                        _ => "ab-gray"
                                    })">@activity.ActionType</span>
                                </td>
                                <td><span style="font-weight: 600; color: var(--text-main); font-size: 0.88rem;">@activity.UserName</span></td>
                                <td><span class="text-truncate d-block" style="max-width: 100%; font-size: 0.88rem; color: var(--text-secondary);" title="@activity.TargetName">@activity.TargetName</span></td>
                                <td style="color: var(--text-muted); font-size: 0.82rem;">@activity.RelativeTime</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <style>
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 1.35rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: all 0.25s var(--ease-out);
            box-shadow: var(--shadow-sm);
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            border-color: rgba(248, 43, 96, 0.12);
        }
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        .stat-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .stat-label {
            color: var(--text-muted);
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .stat-value {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--text-main);
            line-height: 1;
        }

        .activity-badge {
            padding: 0.3rem 0.65rem;
            border-radius: var(--radius-sm);
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            display: inline-block;
        }
        .ab-pink { background: rgba(248, 43, 96, 0.08); color: var(--primary); }
        .ab-blue { background: rgba(69, 170, 242, 0.08); color: #2D98DA; }
        .ab-red { background: rgba(255, 71, 87, 0.08); color: #FF4757; }
        .ab-gray { background: rgba(0, 0, 0, 0.04); color: var(--text-muted); }
    </style>
}

@code {
    private DashboardStats? stats;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.IsInRole("CNH"))
            {
                Navigator.NavigateTo("/pois");
                return;
            }
        }
        stats = await DashService.GetDashboardStatsAsync();
    }
}
