@page "/categories/edit/{id:int}"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject ICategoryService CategoryService
@inject NavigationManager Navigator
@inject IActivityLogger Logger
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "admin")]

<PageTitle>Chỉnh sửa Danh mục - FoodMap Admin</PageTitle>

@if (category == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-5 mt-2">
        <div>
            <h2 class="page-title">Sửa danh mục</h2>
            <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">Cập nhật thông tin cho danh mục "@category.CategoryName"</p>
        </div>
        <button class="back-btn-premium transition-up" @onclick="Cancel" title="Quay lại">
            <i class="bi bi-arrow-left-short"></i>
        </button>
    </div>

    <CategoryForm CategoryModel="category" 
                  Title="Cập nhật danh mục"
                  OnSubmit="HandleSubmit" 
                  OnCancel="Cancel" />
}

<style>
    .back-btn-premium {
        width: 50px;
        height: 50px;
        border-radius: 18px;
        background: white;
        border: 1px solid var(--glass-border);
        color: var(--primary);
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .back-btn-premium:hover {
        background: var(--primary);
        color: white;
        box-shadow: 0 15px 30px var(--primary-glow);
    }
</style>

@code {
    [Parameter] public int id { get; set; }
    private Category? category;

    protected override async Task OnInitializedAsync()
    {
        category = await CategoryService.GetCategoryByIdAsync(id);
        if (category == null)
        {
            Navigator.NavigateTo("/categories");
        }
    }

    private async Task HandleSubmit()
    {
        if (category != null && await CategoryService.UpdateCategoryAsync(category))
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            int.TryParse(userIdStr, out var currentUserId);
            
            await Logger.LogAsync(currentUserId, "Sửa danh mục", category.CategoryName);
            Navigator.NavigateTo("/categories");
        }
    }

    private void Cancel() => Navigator.NavigateTo("/categories");
}
