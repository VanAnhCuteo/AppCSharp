@page "/qr-management/edit/{PoiId:int}"
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IPoiService PoiService
@inject NavigationManager Navigator
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin")]

<div class="d-flex justify-content-between align-items-center mb-5 mt-2">
    <div>
        <h2 class="mb-1" style="font-size: 2.2rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Cập nhật mã QR</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">
            Cập nhật mã QR cho quán <strong>@(poi?.Name ?? "...")</strong>
        </p>
    </div>
    <button class="back-btn-premium transition-up" @onclick="GoBack" title="Quay lại">
        <i class="bi bi-arrow-left-short"></i>
    </button>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else if (poi == null)
{
    <div class="card shadow-glass border-0 mx-auto text-center p-5" style="max-width: 500px; border-radius: 30px;">
        <i class="bi bi-exclamation-triangle-fill text-warning mb-3" style="font-size: 3.5rem;"></i>
        <h3 style="font-weight: 800;">Không tìm thấy quán ăn</h3>
        <p class="text-muted">ID quán ăn không hợp lệ hoặc quán ăn đã bị xóa khỏi hệ thống.</p>
        <button class="glass-btn btn-save-premium mt-3" @onclick="GoBack">
            <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
        </button>
    </div>
}
else
{
    <div class="card shadow-glass border-0 mx-auto" style="max-width: 650px; border-radius: 40px; background: white; overflow: hidden; transform: translateY(0); transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);">
        <div class="p-5">
            <!-- Phần hiển thị QR hiện tại -->
            <div class="text-center mb-5">
                <h5 class="uppercase-tracking text-primary mb-4">Mã QR hiện tại</h5>
                
                <div class="qr-main-container mx-auto">
                    @if (!string.IsNullOrEmpty(currentQrUrl))
                    {
                        <div class="qr-frame shadow-sm">
                            <img src="@currentQrUrl" alt="Current QR" />
                        </div>
                        
                        <!-- Nút X (Xóa) được đưa ra ngoài khung hình -->
                        <div class="mt-4">
                            <button type="button" class="btn-remove-qr" @onclick="RemoveQr">
                                <i class="bi bi-trash3-fill me-2"></i> Xóa mã QR hiện tại
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="qr-placeholder shadow-sm">
                            <i class="bi bi-qr-code-scan"></i>
                            <p>Chưa có mã QR</p>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-5" style="border-top: 2px dashed rgba(255, 45, 133, 0.1); border-bottom: none;" />

            <!-- Phần tải ảnh mới -->
            <div class="upload-section text-center">
                <label class="form-label-premium mb-4">Tải lên mã QR mới</label>
                
                <div class="upload-zone mx-auto">
                    <i class="bi bi-cloud-arrow-up text-primary mb-3" style="font-size: 2.5rem; display: block;"></i>
                    <InputFile OnChange="HandleFileSelected" class="custom-file-input" accept="image/*" id="qrUpload" />
                    <label for="qrUpload" class="file-label">
                        @(selectedFile?.Name ?? "Nhấp để chọn hoặc kéo thả file vào đây")
                    </label>
                </div>
                
                <div class="mt-3 text-muted" style="font-size: 0.8rem; font-weight: 500;">
                    <i class="bi bi-info-circle me-1"></i> Định dạng hỗ trợ: .jpg, .png. Tối đa 2MB.
                </div>
            </div>

            <!-- Nút Lưu -->
            <div class="mt-5 d-grid px-4">
                <button class="glass-btn btn-save-premium pulse-on-hover" @onclick="SaveQr" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Đang xử lý...</span>
                    }
                    else
                    {
                        <i class="bi bi-check-all me-2"></i>
                        <span>Cập nhật mã QR</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<style>
    .shadow-glass {
        box-shadow: 0 40px 100px rgba(0,0,0,0.06) !important;
        border: 1px solid var(--glass-border) !important;
    }

    .uppercase-tracking {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 900;
    }

    .qr-main-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .qr-frame {
        width: 240px;
        height: 240px;
        background: white;
        padding: 15px;
        border-radius: 30px;
        border: 1px solid rgba(255, 45, 133, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 10% 10%, rgba(255, 45, 133, 0.02) 0%, white 100%);
    }

    .qr-frame img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 15px;
    }

    .qr-placeholder {
        width: 240px;
        height: 240px;
        background: rgba(0,0,0,0.02);
        border: 2px dashed rgba(0,0,0,0.05);
        border-radius: 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
    }

    .qr-placeholder i {
        font-size: 4rem;
        opacity: 0.15;
        margin-bottom: 10px;
    }

    .btn-remove-qr {
        background: rgba(255, 0, 0, 0.06);
        color: #ff4d4f;
        border: 1px solid rgba(255, 0, 0, 0.1);
        padding: 0.6rem 1.5rem;
        border-radius: 14px;
        font-size: 0.85rem;
        font-weight: 700;
        transition: all 0.2s ease;
    }

    .btn-remove-qr:hover {
        background: #ff4d4f;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(255, 77, 79, 0.2);
    }

    .upload-zone {
        max-width: 450px;
        padding: 30px;
        border: 2px dashed rgba(255, 45, 133, 0.15);
        border-radius: 24px;
        background: rgba(255, 45, 133, 0.01);
        position: relative;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .upload-zone:hover {
        background: rgba(255, 45, 133, 0.03);
        border-color: var(--primary);
    }

    .custom-file-input {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
        z-index: 2;
    }

    .file-label {
        font-weight: 600;
        color: var(--text-main);
        font-size: 0.95rem;
        margin-bottom: 0;
    }

    .btn-save-premium {
        height: 60px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        box-shadow: 0 15px 35px var(--primary-glow);
        border-radius: 20px;
        font-size: 1.1rem;
        color: white;
    }

    .pulse-on-hover:hover {
        transform: scale(1.02);
        box-shadow: 0 20px 45px var(--primary-glow);
    }

    .form-label-premium {
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 800;
        font-size: 0.72rem;
        color: var(--text-muted);
    }

    .back-btn-premium {
        width: 50px;
        height: 50px;
        border-radius: 18px;
        background: white;
        border: 1px solid var(--glass-border);
        color: var(--primary);
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .back-btn-premium:hover {
        background: var(--primary);
        color: white;
        box-shadow: 0 15px 30px var(--primary-glow);
    }
</style>

@code {
    [Parameter] public int PoiId { get; set; }
    private Poi? poi;
    private string? currentQrUrl;
    private IBrowserFile? selectedFile;
    private bool isSaving = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            poi = await PoiService.GetPoiByIdAsync(PoiId);
            if (poi != null && poi.QrCode != null)
            {
                currentQrUrl = poi.QrCode.QrCodeUrl;
                poi.QrCodeUrl = currentQrUrl;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task SaveQr()
    {
        if (poi == null) return;
        
        isSaving = true;
        try
        {
            if (selectedFile != null)
            {
                // Upload file
                var storagePath = Configuration["ImageStoragePath"] ?? @"d:\MapApp\FoodMapApp\Resources\Raw\images";
                if (!Directory.Exists(storagePath)) Directory.CreateDirectory(storagePath);

                var fileName = $"qr_{Guid.NewGuid()}{Path.GetExtension(selectedFile.Name)}";
                var filePath = Path.Combine(storagePath, fileName);

                using (var stream = selectedFile.OpenReadStream(2 * 1024 * 1024))
                using (var fs = new FileStream(filePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fs);
                }

                poi.QrCodeUrl = $"/images/{fileName}";
            }

            // The PoiService.UpdatePoiAsync handles syncing QrCodeUrl to the poi_qrs table
            var success = await PoiService.UpdatePoiAsync(poi);
            if (success)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Đã cập nhật mã QR thành công!");
                Navigator.NavigateTo("/qr-management");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Lỗi: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RemoveQr()
    {
        currentQrUrl = null;
        poi!.QrCodeUrl = null;
        selectedFile = null;
    }

    private void GoBack() => Navigator.NavigateTo("/qr-management");
}
