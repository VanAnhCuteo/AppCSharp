@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IJSRuntime JSRuntime
@inject ITranslationService TranslationService
@inject ILanguageService LanguageService

<EditForm Model="Guide" OnValidSubmit="HandleValidSubmit" class="af-container">
    <DataAnnotationsValidator />

    <div class="af-card animate-fade-in">
        <!-- Header -->
        <div class="af-card-header">
            <div>
                <span class="af-tag">@Title.ToUpper()</span>
                <h2 class="af-card-title">@(Guide.Poi?.Name ?? "Nội dung thuyết minh")</h2>
            </div>
            <div class="af-stats">
                <div class="af-stat">
                    <span class="af-stat-val">@WordCount</span>
                    <span class="af-stat-label">Từ</span>
                </div>
            </div>
        </div>

        <!-- Body: Single Column Center -->
        <div class="af-body-clean">
            @if (IsAddMode) {
                <div class="af-field">
                    <label>CHỌN ĐỊA ĐIỂM THUYẾT MINH</label>
                    <InputSelect @bind-Value="Guide.PoiId" class="af-select">
                        <option value="">-- Chọn quán ăn --</option>
                        @foreach (var poi in AvailablePois) {
                            <option value="@poi.PoiId">@poi.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(()=>Guide.PoiId)" class="modern-error" />
                </div>
            }

            <div class="af-field">
                <label>TIÊU ĐỀ KỊCH BẢN (TIẾNG VIỆT)</label>
                <InputText @bind-Value="Guide.Title" class="af-input"
                           placeholder="Nhập tiêu đề hấp dẫn..." />
                <ValidationMessage For="@(()=>Guide.Title)" />
            </div>

            <div class="af-field">
                <label>NỘI DUNG THUYẾT MINH (TIẾNG VIỆT)</label>
                <InputTextArea @bind-Value="Guide.Description"
                               @oninput="OnContentInput"
                               class="af-textarea"
                               placeholder="Ghi lại câu chuyện của quán ăn bằng Tiếng Việt... Hệ thống sẽ tự động đồng bộ sang các ngôn ngữ khác sau khi lưu." />
                <div class="af-footer-info">
                    <p class="af-hint"><i class="bi bi-magic me-1"></i> Hệ thống sẽ tự động dịch sang các ngôn ngữ được chọn bên dưới sau khi lưu.</p>
                </div>
            </div>

            @if (IsAddMode) {
                <div class="af-field mt-2">
                    <label>NGÔN NGỮ SẼ ĐƯỢC TỰ ĐỘNG DỊCH</label>
                    <div class="lang-preview-list">
                        @if (allLanguages != null && allLanguages.Any(l => l.LanguageCode != "vi"))
                        {
                            @foreach (var lang in allLanguages.Where(l => l.LanguageCode != "vi"))
                            {
                                <div class="lang-badge-preview">
                                    <i class="bi bi-translate me-1"></i>
                                    <span>@lang.Name (@lang.LanguageCode.ToUpper())</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="lang-empty-inline">
                                <i class="bi bi-info-circle me-1"></i>
                                <span>Tất cả ngôn ngữ hệ thống hỗ trợ sẽ được áp dụng.</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Section for Edit Mode: Managing specific translations -->
                <div class="af-field mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label>TRẠNG THÁI BẢN DỊCH HỆ THỐNG</label>
                    </div>
                    <div class="lang-management-list">
                        @if (allLanguages != null)
                        {
                            @foreach (var lang in allLanguages.Where(l => l.LanguageCode != "vi"))
                            {
                                var guideForLang = ExistingGuides?.FirstOrDefault(g => g.Language == lang.LanguageCode);
                                <div class="lang-row">
                                    <div class="d-flex align-items-center flex-grow-1">
                                        <div class="lang-status-dot @(guideForLang != null ? "active" : "")"></div>
                                        <span class="lang-name">@lang.Name</span>
                                    </div>
                                    @if(guideForLang != null)
                                    {
                                        <span class="badge-status-ok">Đã dịch</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn-translate-mini" @onclick="() => OnTranslateRequested.InvokeAsync(lang.LanguageCode)">
                                            <i class="bi bi-magic me-1"></i> Dịch ngay
                                        </button>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <!-- Actions -->
            <div class="af-actions-row">
                <button type="button" class="af-btn-sec" @onclick="OnCancelClick">Hủy bỏ</button>
                <button type="submit" class="af-btn-pri">
                    <i class="bi bi-cloud-arrow-up-fill me-1"></i> Lưu và Tự động Dịch
                </button>
            </div>
        </div>
    </div>
</EditForm>

<style>
    .af-container { max-width: 700px; margin: 0 auto; }

    .af-card {
        background: white;
        border-radius: 15px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 20px 60px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .af-card-header {
        padding: 1.2rem 1.8rem;
        background: rgba(255, 45, 133, 0.02);
        border-bottom: 1px solid #F0F0F0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .af-tag { font-size: 0.6rem; font-weight: 800; color: #FF2D85; letter-spacing: 1.5px; }
    .af-card-title { margin: 0.3rem 0 0; font-weight: 900; letter-spacing: -0.5px; font-size: 1.4rem; color: #1A1A1A; }
    .af-stat { display: flex; flex-direction: column; align-items: flex-end; }
    .af-stat-val { font-size: 1.35rem; font-weight: 950; color: var(--primary); line-height: 1; }
    .af-stat-label { font-size: 0.6rem; font-weight: 800; color: #AAA; text-transform: uppercase; margin-top: 3px; }

    .af-body-clean {
        padding: 1.5rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .af-field { display: flex; flex-direction: column; gap: 0.5rem; }
    .af-field label {
        font-size: 0.65rem; font-weight: 900; color: #666; letter-spacing: 1px; text-transform: uppercase;
    }

    .af-input, .af-select, .af-textarea {
        width: 100%;
        background: #F8F9FC;
        border: 1.5px solid transparent;
        border-radius: 12px;
        padding: 0.7rem 1rem;
        font-weight: 600;
        color: #1A1A1A;
        transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
        font-size: 0.95rem;
    }
    .af-textarea {
        height: 250px;
        resize: none;
        line-height: 1.6;
    }
    .af-input:focus, .af-textarea:focus, .af-select:focus {
        outline: none;
        background: #FFF;
        border-color: #FF2D85;
        box-shadow: 0 0 0 4px rgba(255,45,133,0.06);
    }
    
    .af-footer-info { display: flex; justify-content: flex-end; margin-top: -0.5rem; }
    .af-hint { font-size: 0.82rem; color: #888; margin: 0; font-weight: 600; display: flex; align-items: center; }

    .af-actions-row { 
        display: flex; 
        gap: 1rem; 
        margin-top: 1rem; 
        padding-top: 1.5rem; 
        border-top: 1px dashed #EEE; 
    }
    
    .af-btn-pri {
        flex: 3;
        background: linear-gradient(135deg, #FF2D85, #FF7EB3);
        color: white;
        border: none;
        padding: 0.8rem;
        border-radius: 12px;
        font-weight: 900;
        font-size: 1rem;
        display: flex; align-items: center; justify-content: center; gap: 0.6rem;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(255,45,133,0.2);
        transition: all 0.3s;
    }
    .af-btn-pri:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 15px 35px rgba(255,45,133,0.3); }
    .af-btn-sec {
        flex: 1;
        background: #F3F5F9;
        border: none;
        padding: 0.8rem;
        border-radius: 12px;
        font-weight: 800;
        color: #777;
        cursor: pointer;
        transition: all 0.2s;
    }
    .af-btn-sec:hover { background: #EEE; color: #333; }

    .modern-error {
        font-size: 0.75rem;
        font-weight: 700;
        color: #E53E3E;
        margin-top: 0.4rem;
        padding-left: 0.5rem;
    }

    .lang-preview-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        background: #F8F9FC;
        padding: 12px;
        border-radius: 12px;
        border: 1px dashed rgba(255, 45, 133, 0.2);
    }
    .lang-badge-preview {
        background: white;
        color: #FF2D85;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 20px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        display: flex;
        align-items: center;
    }
    .lang-empty-inline {
        font-size: 0.8rem;
        color: #888;
        font-weight: 600;
    }

    /* Translation management styles */
    .lang-management-list {
        background: #F8F9FC;
        border-radius: 12px;
        padding: 5px;
    }
    .lang-row {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }
    .lang-row:last-child { border-bottom: none; }
    .lang-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 12px;
        background: #D1D5DB;
    }
    .lang-status-dot.active { background: #10B981; box-shadow: 0 0 8px rgba(16, 185, 129, 0.4); }
    .lang-name { font-size: 0.9rem; font-weight: 700; color: #4B5563; }
    .badge-status-ok {
        font-size: 0.7rem;
        font-weight: 800;
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        padding: 4px 10px;
        border-radius: 20px;
    }
    .btn-translate-mini {
        border: none;
        background: white;
        color: var(--primary);
        font-size: 0.75rem;
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: all 0.2s;
    }
    .btn-translate-mini:hover { transform: translateY(-1px); box-shadow: 0 4px 12px var(--primary-glow); }

    .animate-fade-in { animation: fadeIn 0.8s cubic-bezier(0.19, 1, 0.22, 1); }
    @("@")keyframes fadeIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    [Parameter] public PoiGuide Guide { get; set; } = new();
    [Parameter] public List<Poi> AvailablePois { get; set; } = new();
    [Parameter] public bool IsAddMode { get; set; } = true;
    [Parameter] public string Title { get; set; } = "Thông tin Audio Guide";
    [Parameter] public List<string> SelectedLanguages { get; set; } = new();
    [Parameter] public List<PoiGuide> ExistingGuides { get; set; } = new(); 
    [Parameter] public EventCallback<string> OnTranslateRequested { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private List<Language>? allLanguages;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            allLanguages = await LanguageService.GetAllLanguagesAsync();
            
            // Auto-sync selected languages with available languages (Add Mode)
            if (IsAddMode && allLanguages != null)
            {
                SelectedLanguages.Clear();
                foreach(var lang in allLanguages.Where(l => l.LanguageCode != "vi"))
                {
                    SelectedLanguages.Add(lang.LanguageCode);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading languages: {ex.Message}");
        }
    }

    private int WordCount => string.IsNullOrEmpty(Guide.Description)
        ? 0 : Guide.Description.Split(new[] { ' ', '\n' }, StringSplitOptions.RemoveEmptyEntries).Length;

    private void OnContentInput(ChangeEventArgs e) {
        Guide.Description = e.Value?.ToString();
        StateHasChanged();
    }

    private void ToggleLang(string lang, object checkedVal)
    {
        bool isChecked = (bool)(checkedVal ?? false);
        if (isChecked && !SelectedLanguages.Contains(lang))
            SelectedLanguages.Add(lang);
        else if (!isChecked && SelectedLanguages.Contains(lang))
            SelectedLanguages.Remove(lang);
    }

    private async Task HandleValidSubmit() => await OnSubmit.InvokeAsync();

    private async Task OnCancelClick() {
        await OnCancel.InvokeAsync();
    }
}
