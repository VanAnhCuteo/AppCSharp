@page "/images/add"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IPoiImageService PoiImageService
@inject IPoiService PoiService
@inject NavigationManager Navigator
@inject IJSRuntime JS
@attribute [Authorize(Roles = "admin,CNH")]

<div class="d-flex justify-content-between align-items-center mb-5 mt-2">
    <div>
        <h2 class="mb-1" style="font-size: 2.2rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Thêm ảnh mới</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">Tải lên hình ảnh mới cho hệ thống FoodMap</p>
    </div>
    <button class="back-btn-premium transition-up" @onclick="Cancel" title="Quay lại">
        <i class="bi bi-arrow-left-short"></i>
    </button>
</div>

<ImageForm ImageModel="image" 
           AvailablePois="pois" 
           IsAddMode="true" 
           Title="Thêm Hình ảnh mới"
           OnSubmitWithFile="HandleSubmit" 
           OnCancel="Cancel" />

<style>
    .back-btn-premium {
        width: 50px;
        height: 50px;
        border-radius: 18px;
        background: white;
        border: 1px solid var(--glass-border);
        color: var(--primary);
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .back-btn-premium:hover {
        background: var(--primary);
        color: white;
        box-shadow: 0 15px 30px var(--primary-glow);
    }
</style>

@code {
    private PoiImage image = new();
    private List<Poi> pois = new();
    
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.IsInRole("admin"))
            {
                pois = await PoiService.GetAllPoisAsync();
            }
            else if (user.IsInRole("CNH"))
            {
                var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(userIdStr, out var userId))
                {
                    pois = await PoiService.GetPoisByOwnerAsync(userId);
                }
            }
        }
    }

    private async Task HandleSubmit((IBrowserFile? file, string? fileName) uploadData)
    {
        if (uploadData.file != null && !string.IsNullOrEmpty(uploadData.fileName))
        {
            using var stream = uploadData.file.OpenReadStream(2 * 1024 * 1024); // max 2MB
            if (await PoiImageService.CreateImageAsync(image, stream, uploadData.fileName))
            {
                var authState = await AuthStateTask!;
                if (authState.User.IsInRole("CNH"))
                {
                    await JS.InvokeVoidAsync("alert", "Yêu cầu thêm ảnh đã được gửi và đang chờ Admin phê duyệt.");
                }
                Navigator.NavigateTo("/images");
            }
        }
    }

    private void Cancel() => Navigator.NavigateTo("/images");
}
