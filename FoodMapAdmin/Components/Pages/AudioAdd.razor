@page "/audio-add"
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@using Microsoft.AspNetCore.Authorization
@inject IPoiGuideService GuideService
@inject IPoiService PoiService
@inject NavigationManager Navigation
@inject ITranslationService TranslationService
@attribute [Authorize(Roles = "admin")]

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <div>
        <h2 class="mb-1" style="font-size: 1.6rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Tạo Audio Guide</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem; font-weight: 500;">Thêm nội dung thuyết minh mới cho địa điểm</p>
    </div>
    <button class="back-btn-premium transition-up" @onclick="GoBack" title="Quay lại">
        <i class="bi bi-arrow-left-short"></i>
    </button>
</div>

@if (availablePois == null || isSaving)
{
    <div class="modern-loading-zone animate-fade-in">
        <div class="loading-orb"></div>
        <h3>@(isSaving ? "Đang xử lý kịch bản..." : "Đang chuẩn bị...")</h3>
        @if (isSaving)
        {
            <p>Hệ thống đang tự động dịch sang các ngôn ngữ đã chọn để đảm bảo trải nghiệm đa ngôn ngữ cho du khách. Vui lòng đợi trong giây lát...</p>
        }
    </div>
}
else
{
    <AudioForm 
        Guide="newGuide" 
        AvailablePois="availablePois" 
        IsAddMode="true" 
        Title="Thông tin bản thuyết minh mới"
        SelectedLanguages="selectedLangs"
        OnSubmit="HandleSubmit" 
        OnCancel="GoBack" />
}

<style>
    .back-btn-premium {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: white;
        border: 1px solid var(--glass-border);
        color: var(--primary);
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 15px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .back-btn-premium:hover {
        background: var(--primary);
        color: white;
        box-shadow: 0 10px 20px var(--primary-glow);
    }

    .modern-loading-zone {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
        text-align: center;
    }

    .loading-orb {
        width: 60px;
        height: 60px;
        background: var(--primary-gradient);
        border-radius: 50%;
        margin-bottom: 1.5rem;
        animation: pulse-orb 2s infinite ease-in-out;
        box-shadow: 0 0 30px rgba(255, 45, 133, 0.4);
    }

    @@keyframes pulse-orb {
        0%, 100% { transform: scale(0.8); opacity: 0.5; }
        50% { transform: scale(1.1); opacity: 1; }
    }

    .modern-loading-zone h3 { font-size: 1.25rem; font-weight: 800; margin-bottom: 0.8rem; }
    .modern-loading-zone p { font-size: 0.85rem; color: #888; max-width: 450px; font-weight: 500; }
</style>

@code {
    private PoiGuide newGuide = new() { Language = "vi" };
    private List<Poi>? availablePois;
    private bool isSaving = false;
    private List<string> selectedLangs = new() { "en", "zh", "ko", "ja" };

    protected override async Task OnInitializedAsync()
    {
        var allPois = await PoiService.GetAllPoisAsync();
        var allGuides = await GuideService.GetAllGuidesAsync();
        
        // Only show POIs that don't have a guide yet
        availablePois = allPois.Where(p => !allGuides.Any(g => g.PoiId == p.PoiId)).ToList();
    }

    private async Task HandleSubmit()
    {
        if (newGuide.PoiId == null || newGuide.PoiId == 0)
        {
            await GuideService.GetAllGuidesAsync(); // Refresh just in case
            return;
        }

        if (string.IsNullOrEmpty(newGuide.Title)) return;

        isSaving = true;
        StateHasChanged();

        try 
        {
            // 1. Save Vietnamese record
            bool success = await GuideService.CreateGuideAsync(newGuide);
            if (success)
            {
                // 2. Auto-translate and save for SELECTED languages
                // Find the POI name to protect it during translation
                var poiName = availablePois?.FirstOrDefault(p => p.PoiId == newGuide.PoiId)?.Name ?? "";
                var placeholder = "[[POI_NAME]]";

                foreach (var lang in selectedLangs)
                {
                    try 
                    {
                        // Normalize title and script for translation
                        var sourceTitle = newGuide.Title?.Trim() ?? "";
                        var sourceDesc = newGuide.Description?.Trim() ?? "";

                        // Inject placeholder for the POI name
                        if (!string.IsNullOrEmpty(poiName))
                        {
                            sourceTitle = sourceTitle.Replace(poiName, placeholder);
                            sourceDesc = sourceDesc.Replace(poiName, placeholder);
                        }

                        var tTitle = await TranslationService.TranslateAsync(sourceTitle, lang);
                        var tDesc = await TranslationService.TranslateAsync(sourceDesc, lang);
                        
                        // Swap placeholder back with original POI name
                        if (!string.IsNullOrEmpty(poiName))
                        {
                            tTitle = tTitle?.Replace(placeholder, poiName) ?? "";
                            tDesc = tDesc?.Replace(placeholder, poiName) ?? "";
                            // Some translation APIs might add spaces around brackets or lowercase the placeholder
                            tTitle = tTitle.Replace("[[ POI_NAME ]]", poiName).Replace("[[ poi_name ]]", poiName);
                            tDesc = tDesc.Replace("[[ POI_NAME ]]", poiName).Replace("[[ poi_name ]]", poiName);
                        }

                        var tGuide = new PoiGuide {
                            PoiId = newGuide.PoiId,
                            Title = tTitle,
                            Description = tDesc,
                            Language = lang
                        };
                        await GuideService.CreateGuideAsync(tGuide);
                        
                        // Add a small delay to be kind to the translation API and improve reliability
                        await Task.Delay(500);
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[Translation Error] Failed for {lang}: {ex.Message}");
                    }
                }
                
                Navigation.NavigateTo("/audio-management");
            }
        }
        finally 
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/audio-management");
    }
}
