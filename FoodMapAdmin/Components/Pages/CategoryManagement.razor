@page "/categories"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject ICategoryService CategoryService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigator
@inject IActivityLogger Logger
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "admin")]

<PageTitle>Quản lý Danh mục - FoodMap Admin</PageTitle>

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
    <div>
        <h2 class="page-title">Danh mục</h2>
        <p class="page-subtitle">Phân loại các địa điểm ăn uống trên toàn hệ thống</p>
    </div>
    <button class="glass-btn" @onclick='() => Navigator.NavigateTo("/categories/add")'>
        <i class="bi bi-plus-lg"></i> Thêm danh mục
    </button>
</div>

<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="padding-left: 2rem; width: 120px;">Mã số</th>
                    <th style="width: 300px;">Tên danh mục</th>
                    <th>Mô tả chi tiết</th>
                    <th style="text-align: center; padding-right: 2rem; width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (categories == null)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var cat in categories)
                    {
                        <tr class="align-middle transition-all">
                            <td style="padding-left: 2rem; color: var(--text-muted); font-weight: 600;">#@cat.CategoryId</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="cat-icon me-3">
                                        <i class="bi bi-bookmark-star-fill"></i>
                                    </div>
                                    <div>
                                        <span style="font-weight: 800; color: var(--text-main); font-size: 1.05rem;">@cat.CategoryName</span>
                                        @if (cat.IsHidden)
                                        {
                                            <span class="badge-hidden ms-2">ĐANG ẨN</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted" style="font-size: 0.9rem;">@cat.Description</span>
                            </td>
                            <td style="text-align: center; padding-right: 2rem; white-space: nowrap;">
                                <div style="display: flex !important; flex-direction: row !important; justify-content: center; align-items: center; gap: 0.75rem;">
                                    @if (cat.IsHidden)
                                    {
                                        <button class="action-btn btn-restore" title="Bỏ ẩn" @onclick="() => Restore(cat.CategoryId)">
                                            <i class="bi bi-eye-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="action-btn btn-edit" title="Chỉnh sửa" @onclick='() => Navigator.NavigateTo($"/categories/edit/{cat.CategoryId}")'>
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="action-btn btn-delete" title="Xóa" @onclick="() => Delete(cat.CategoryId)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .cat-icon {
        width: 38px;
        height: 38px;
        background: rgba(45, 133, 255, 0.08);
        color: #2d85ff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .form-label-premium {
        display: block;
        margin-bottom: 0.6rem;
        color: var(--text-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 800;
    }

    .form-control-premium {
        width: 100%;
        padding: 0.9rem 1.2rem;
        border-radius: 16px;
        background: #f8f9fa;
        border: 1px solid rgba(0,0,0,0.05);
        color: var(--text-main);
        font-size: 1rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .form-control-premium:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        box-shadow: 0 10px 25px var(--primary-glow);
    }
    
    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .btn-edit { background: rgba(255, 45, 133, 0.05); color: var(--primary); }
    .btn-edit:hover { background: var(--primary); color: white; }
    .btn-delete { background: rgba(255, 0, 0, 0.05); color: #ff4d4f; }
    .btn-delete:hover { background: #ff4d4f; color: white; }
    
    .btn-restore { background: rgba(52, 168, 83, 0.05); color: #34a853; }
    .btn-restore:hover { background: #34a853; color: white; }

    .badge-hidden {
        background: rgba(255, 159, 67, 0.1);
        color: #FF9F43;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        letter-spacing: 0.5px;
    }
    
    tr:hover { background: rgba(255, 45, 133, 0.01) !important; }

    table {
        width: 100% !important;
    }
</style>

@code {
    private List<Category>? categories;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData() => categories = await CategoryService.GetAllCategoriesAsync();

    private async Task Delete(int id)
    {
        var category = categories?.FirstOrDefault(c => c.CategoryId == id);
        if (category == null) return;

        bool hasPois = category.Pois?.Any() == true;
        string msg = hasPois 
            ? $"Danh mục '{category.CategoryName}' đang có quán ăn liên kết. Hệ thống sẽ CHỈ ẨN danh mục này bên App. Bạn có chắc chắn?"
            : $"Bạn có chắc muốn XÓA VĨNH VIỄN danh mục '{category.CategoryName}'?";

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", msg);
        if (confirmed && await CategoryService.DeleteCategoryAsync(id))
        {
            await LoadData();
        }
    }

    private async Task Restore(int id)
    {
        if (await CategoryService.RestoreCategoryAsync(id))
        {
            await LoadData();
        }
    }
}
