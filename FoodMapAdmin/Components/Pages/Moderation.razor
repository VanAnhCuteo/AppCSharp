@page "/moderation"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IPoiPendingChangeService PendingChangeService
@inject IPoiService PoiService
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin")]

<PageTitle>Phê duyệt thay đổi - FoodMap Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="mb-1" style="font-size: 2.2rem; font-weight: 900; background: linear-gradient(135deg, var(--text-main) 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px;">Phê duyệt thay đổi</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem; font-weight: 500;">Quản lý các yêu cầu Thêm, Sửa, Xóa từ các chủ nhà hàng</p>
    </div>
</div>

<!-- Category Tabs -->
<div class="moderation-tabs mb-5">
    <button class="mod-tab @(activeTab == "create" ? "active" : "")" @onclick='() => SetTab("create")'>
        <i class="bi bi-plus-circle-fill"></i> Thêm mới
        @if (getTabCount("create") > 0) { <span class="tab-badge">@getTabCount("create")</span> }
    </button>
    <button class="mod-tab @(activeTab == "update" ? "active" : "")" @onclick='() => SetTab("update")'>
        <i class="bi bi-pencil-square"></i> Chỉnh sửa
        @if (getTabCount("update") > 0) { <span class="tab-badge">@getTabCount("update")</span> }
    </button>
    <button class="mod-tab @(activeTab == "delete" ? "active" : "")" @onclick='() => SetTab("delete")'>
        <i class="bi bi-trash3-fill"></i> Yêu cầu Xóa
        @if (getTabCount("delete") > 0) { <span class="tab-badge">@getTabCount("delete")</span> }
    </button>
</div>

@if (allRequests == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else if (!GetFilteredRequests().Any())
{
    <div class="card shadow-glass text-center py-5" style="border-radius: 35px;">
        <i class="bi bi-check-circle text-success mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
        <h4 class="text-muted">Không có yêu cầu nào trong mục này</h4>
        <p class="text-muted">Tất cả các thay đổi đã được giải quyết.</p>
    </div>
}
else
{
    <div class="row animate-stagger">
        <div class="col-12">
            @foreach (var request in GetFilteredRequests())
            {
                <div class="card shadow-glass mb-4 overflow-hidden border-0" style="border-radius: 25px; background: var(--surface);">
                    <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="req-icon-mini @request.ChangeType me-3">
                                <i class="bi @(request.ChangeType == "create" ? "bi-plus-lg" : (request.ChangeType == "delete" ? "bi-trash" : "bi-pencil"))"></i>
                            </div>
                            <div>
                                <h5 class="mb-0" style="font-weight: 800; color: var(--text-main); font-size: 1.2rem;">
                                    @request.Name 
                                    @if(request.ChangeType == "create") { <span class="badge bg-success ms-2" style="font-size: 0.6rem;">QUÁN MỚI</span> }
                                </h5>
                                <span class="text-muted" style="font-size: 0.85rem;">
                                    @if(request.PoiId.HasValue) { <span>ID: <strong>#@request.PoiId</strong> <span class="mx-2">|</span></span> }
                                    Người yêu cầu: <strong>@request.Requester?.Username</strong> 
                                    <span class="mx-2">•</span> 
                                    Thời gian: @request.CreatedAt?.ToString("HH:mm dd/MM/yyyy")
                                </span>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn glass-btn-success" @onclick="() => Approve(request)">
                                <i class="bi bi-check-lg me-1"></i> Phê duyệt
                            </button>
                            <button class="btn btn-outline-danger btn-reject" @onclick="() => Reject(request)">
                                <i class="bi bi-x-lg me-1"></i> Từ chối
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (request.ChangeType == "delete")
                        {
                            <div class="p-4 bg-light border-top text-center">
                                <p class="mb-0 text-danger fw-bold">Xác nhận xóa hoàn toàn quán này khỏi hệ thống?</p>
                                <small class="text-muted">Toàn bộ dữ liệu liên quan sẽ bị gỡ bỏ.</small>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table mb-0 align-middle" style="border-style: hidden; table-layout: fixed;">
                                    <thead style="background: rgba(255, 45, 133, 0.02);">
                                        <tr>
                                            <th style="width: 25%; padding: 1.2rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); border: none;">Trường dữ liệu</th>
                                            @if (request.ChangeType == "update") { <th style="width: 37.5%; padding: 1.2rem; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); border: none;">Giá trị hiện tại</th> }
                                            <th style="width: @(request.ChangeType == "create" ? "75%" : "37.5%"); padding: 1.2rem; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); border: none;">@(request.ChangeType == "create" ? "Dữ liệu quán mới" : "Yêu cầu thay đổi")</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @renderRow("Danh mục", request.ChangeType == "update" ? request.Poi?.Category?.CategoryName : null, request.Category?.CategoryName, request.ChangeType)
                                        @renderRow("Tên quán ăn", request.ChangeType == "update" ? request.Poi?.Name : null, request.Name, request.ChangeType)
                                        @renderRow("Địa chỉ", request.ChangeType == "update" ? request.Poi?.Address : null, request.Address, request.ChangeType)
                                        @renderRow("Giờ mở cửa", request.ChangeType == "update" ? request.Poi?.OpenTime : null, request.OpenTime, request.ChangeType)
                                        @renderRow("Vĩ độ (Lat)", request.ChangeType == "update" ? request.Poi?.Latitude?.ToString() : null, request.Latitude?.ToString(), request.ChangeType)
                                        @renderRow("Kinh độ (Lng)", request.ChangeType == "update" ? request.Poi?.Longitude?.ToString() : null, request.Longitude?.ToString(), request.ChangeType)
                                        @renderRow("Bán kính quét", request.ChangeType == "update" ? request.Poi?.RangeMeters.ToString() : null, request.RangeMeters.ToString(), request.ChangeType)
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<PoiPendingChange>? allRequests;
    private string activeTab = "update";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        // Mặc định nhảy sang tab có đơn nếu tab hiện tại trống
        if (getTabCount("update") == 0) {
            if (getTabCount("create") > 0) activeTab = "create";
            else if (getTabCount("delete") > 0) activeTab = "delete";
        }
    }

    private async Task LoadData()
    {
        allRequests = await PendingChangeService.GetPendingChangesAsync();
    }

    private void SetTab(string tab) => activeTab = tab;

    private List<PoiPendingChange> GetFilteredRequests() 
    {
        return allRequests?.Where(r => r.ChangeType == activeTab).ToList() ?? new();
    }

    private int getTabCount(string type) => allRequests?.Count(r => r.ChangeType == type) ?? 0;

    private bool isProcessing = false;

    private async Task Approve(PoiPendingChange request)
    {
        if (isProcessing) return;
        
        try 
        {
            string action = request.ChangeType switch {
                "create" => "THÊM MỚI quán ăn này",
                "delete" => "XÓA quán ăn này",
                _ => "CẬP NHẬT thay đổi này"
            };

            if (await JSRuntime.InvokeAsync<bool>("confirm", $"Bạn có chắc chắn muốn {action} không?"))
            {
                isProcessing = true;
                StateHasChanged();

                if (await PendingChangeService.ApproveChangeAsync(request.ChangeId))
                {
                    await LoadData();
                    await JSRuntime.InvokeVoidAsync("alert", "Đã phê duyệt thành công!");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Không thể phê duyệt yêu cầu. Vui lòng kiểm tra lại dữ liệu.");
                }
            }
        }
        catch (Exception ex)
        {
            var errorMsg = ex.InnerException != null ? $"{ex.Message} -> {ex.InnerException.Message}" : ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Đã xảy ra lỗi khi phê duyệt:\n{errorMsg}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task Reject(PoiPendingChange request)
    {
        if (isProcessing) return;

        try
        {
            if (await JSRuntime.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn TỪ CHỐI yêu cầu này không?"))
            {
                isProcessing = true;
                StateHasChanged();

                if (await PendingChangeService.RejectChangeAsync(request.ChangeId))
                {
                    await LoadData();
                    await JSRuntime.InvokeVoidAsync("alert", "Đã từ chối yêu cầu.");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Không thể từ chối yêu cầu.");
                }
            }
        }
        catch (Exception ex)
        {
            var errorMsg = ex.InnerException != null ? $"{ex.Message} -> {ex.InnerException.Message}" : ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Đã xảy ra lỗi khi từ chối:\n{errorMsg}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private RenderFragment renderRow(string label, string? oldValue, string? newValue, string type) => __builder => {
        bool isChanged = type == "update" && oldValue != newValue;
        <tr class="@(isChanged ? "table-warning-custom" : "")">
            <td style="padding: 1.2rem 1.5rem; font-weight: 700; color: var(--text-muted);">@label</td>
            @if (type == "update") {
                <td class="text-muted" style="padding: 1.2rem; font-family: inherit; font-size: 0.95rem;">@oldValue</td>
            }
            <td style="padding: 1.2rem; font-weight: 800; color: @(isChanged || type == "create" ? "var(--primary)" : "var(--text-main)"); font-size: 0.95rem;">
                @newValue
                @if (isChanged) {
                    <i class="bi bi-arrow-left-short ms-1" style="opacity: 0.5;"></i>
                }
            </td>
        </tr>
    };
}

<style>
    /* Tabs System */
    .moderation-tabs {
        display: flex;
        gap: 1rem;
        background: #f0f2f5;
        padding: 0.5rem;
        border-radius: 20px;
        width: fit-content;
    }

    .mod-tab {
        border: none;
        background: transparent;
        padding: 0.7rem 1.5rem;
        border-radius: 15px;
        font-weight: 800;
        font-size: 0.9rem;
        color: #666;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .mod-tab.active {
        background: white;
        color: var(--primary);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transform: translateY(-2px);
    }

    .tab-badge {
        background: var(--primary);
        color: white;
        font-size: 0.65rem;
        padding: 0.1rem 0.5rem;
        border-radius: 10px;
        margin-left: 2px;
    }

    .req-icon-mini {
        width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    }
    .req-icon-mini.create { background: rgba(46, 204, 113, 0.1); color: #2ecc71; }
    .req-icon-mini.update { background: rgba(52, 152, 219, 0.1); color: #3498db; }
    .req-icon-mini.delete { background: rgba(231, 76, 60, 0.1); color: #e74c3c; }

    .glass-btn-success {
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        color: white; border: none; border-radius: 12px; padding: 0.6rem 1.2rem; font-weight: 700;
        box-shadow: 0 10px 20px rgba(46, 204, 113, 0.2); transition: all 0.3s ease;
    }
    .glass-btn-success:hover { transform: translateY(-2px); box-shadow: 0 15px 30px rgba(46, 204, 113, 0.3); color: white; }

    .btn-reject { border-radius: 12px; padding: 0.6rem 1.2rem; font-weight: 700; transition: all 0.3s ease; }
    .btn-reject:hover { background: #ff4d4f; color: white; transform: translateY(-2px); }

    .table-warning-custom { background: rgba(255, 193, 7, 0.04) !important; }
    .table-warning-custom td:last-child { background: rgba(255, 45, 133, 0.03); }

    .animate-stagger > * { animation: slideUp 0.5s cubic-bezier(0.19, 1, 0.22, 1) both; }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>
