@page "/images"
@using Microsoft.AspNetCore.Authorization
@using FoodMapAdmin.Models
@using FoodMapAdmin.Services
@inject IPoiImageService PoiImageService
@inject IPoiService PoiService
@inject IPoiImagePendingChangeService PendingChangeService
@inject NavigationManager Navigator
@inject IJSRuntime JS
@attribute [Authorize(Roles = "admin,CNH")]

<PageTitle>Quản lý Hình ảnh - FoodMap Admin</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
    <div>
        <h2 class="page-title">Thư viện Hình ảnh</h2>
        <p class="page-subtitle">Quản lý ảnh cho các quán ăn và địa điểm</p>
    </div>
    <button class="glass-btn" @onclick="AddNew">
        <i class="bi bi-plus-lg"></i> Thêm ảnh mới
    </button>
</div>

<!-- Tabs Configuration -->
<div class="custom-tabs mb-4">
    <button class="tab-item @(activeTab == "all" ? "active" : "")" @onclick='() => SetTab("all")'>
        Tất Cả 
        <span class="tab-count">@images?.Count</span>
    </button>
    <button class="tab-item @(activeTab == "by-poi" ? "active" : "")" @onclick='() => SetTab("by-poi")'>
        Từng Quán
    </button>
</div>

<!-- Sub-filter for specific POI -->
@if (activeTab == "by-poi")
{
    <div class="filter-bar animate-fade-in mb-4">
        <label class="me-3 fw-bold"><i class="bi bi-funnel-fill me-1"></i> LỌC THEO QUÁN:</label>
        <select class="form-select glass-select" style="max-width: 300px; display: inline-block;" @onchange="OnPoiFilterChange">
            <option value="0">-- Chọn quán ăn --</option>
            @foreach (var p in pois)
            {
                <option value="@p.PoiId">@p.Name</option>
            }
        </select>
    </div>
}

<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="padding-left: 2rem;">Mã số</th>
                    <th>Hình ảnh</th>
                    <th>Quán ăn</th>
                    <th>URL / Tên file</th>
                    <th style="text-align: center; padding-right: 2rem;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (images == null)
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    var filtered = GetFilteredImages();
                    if (!filtered.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="bi bi-image text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                                    <p class="text-muted mt-3">Không tìm thấy hình ảnh nào phù hợp.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var img in filtered)
                        {
                            var pending = pendingImages?.FirstOrDefault(p => p.ImageId == img.ImageId);
                            <tr class="align-middle transition-all @(pending != null ? "pending-row" : "")">
                                <td style="padding-left: 2rem; color: var(--text-muted); font-weight: 600;">#@img.ImageId</td>
                                <td>
                                    <div class="image-preview-container">
                                        <img src="@img.ImageUrl" alt="Preview" class="image-preview shadow-sm" onerror="this.src='/favicon.ico'; this.style.opacity='0.5';" />
                                    </div>
                                </td>
                                <td>
                                    @if (img.Poi != null)
                                    {
                                        <div style="font-weight: 700; color: var(--text-main);">@img.Poi.Name</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">
                                            ID: #@img.PoiId
                                            @if (!isAdmin && pending != null && pending.ChangeType == "delete")
                                            {
                                                <span class="badge-pending-danger ms-2" title="Yêu cầu xóa đang chờ duyệt">CHỜ XÓA</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    <code class="text-muted" style="font-size: 0.85rem;">@img.ImageUrl</code>
                                </td>
                                <td style="text-align: center; padding-right: 2rem; white-space: nowrap;">
                                    <div style="display: flex !important; flex-direction: row !important; justify-content: center; align-items: center; gap: 0.75rem;">
                                        @if (isAdmin || pending == null) {
                                            <button class="action-btn btn-edit" title="Chỉnh sửa" @onclick="() => Edit(img.ImageId)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="action-btn btn-delete" title="Xóa" @onclick="() => Delete(img.ImageId)">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        } else {
                                            <span class="badge-lock-mini" title="Không thể thao tác khi đang chờ duyệt">
                                                <i class="bi bi-lock-fill"></i> Khóa
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }

                        <!-- SHOW PENDING ADDITIONS (Owner only) -->
                        @if (!isAdmin && pendingImages != null)
                        {
                            @foreach (var p in pendingImages.Where(pi => pi.ChangeType == "add" || pi.ChangeType == "update"))
                            {
                                <tr class="align-middle pending-creation-row">
                                    <td style="padding-left: 2rem; color: #999; font-style: italic;">(Mới)</td>
                                    <td>
                                        <div class="image-preview-container" style="opacity: 0.7;">
                                            <img src="@p.ImageUrl" alt="Preview" class="image-preview" />
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-weight: 700; color: #777;">@p.Poi?.Name</div>
                                        <div class="badge-pending-primary mt-1" style="display: inline-block;">ĐANG CHỜ DUYỆT</div>
                                    </td>
                                    <td><code class="text-muted" style="font-size: 0.85rem;">@p.ImageUrl</code></td>
                                    <td style="text-align: center; padding-right: 2rem;">
                                        <i class="bi bi-shield-lock text-muted" title="Admin đang xem xét"></i>
                                    </td>
                                </tr>
                            }
                        }
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* Tabs styling */
    .custom-tabs {
        display: flex;
        gap: 1rem;
        background: rgba(0,0,0,0.03);
        padding: 0.5rem;
        border-radius: 20px;
        width: fit-content;
    }

    .tab-item {
        border: none;
        background: transparent;
        padding: 0.8rem 1.5rem;
        border-radius: 15px;
        font-weight: 800;
        font-size: 0.85rem;
        color: #777;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
    }

    .tab-item.active {
        background: white;
        color: var(--primary);
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .tab-count {
        background: rgba(255, 45, 133, 0.1);
        color: var(--primary);
        padding: 0.1rem 0.5rem;
        border-radius: 6px;
        font-size: 0.7rem;
        margin-left: 0.5rem;
    }

    .glass-select {
        background: rgba(255,255,255,0.8);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 12px;
        font-weight: 600;
        padding: 0.5rem 1rem;
    }

    .image-preview-container {
        width: 80px;
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid rgba(255, 45, 133, 0.1);
        background: #f8f8f8;
    }

    .image-preview {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .shadow-glass {
        box-shadow: 0 20px 60px rgba(0,0,0,0.03) !important;
        border: 1px solid var(--glass-border) !important;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        font-size: 1.1rem;
    }

    .btn-edit {
        background: rgba(255, 45, 133, 0.05);
        color: var(--primary);
    }

    .btn-edit:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: rgba(255, 0, 0, 0.05);
        color: #ff4d4f;
    }

    .btn-delete:hover {
        background: #ff4d4f;
        color: white;
        transform: translateY(-2px);
    }

    .badge-lock-mini {
        background: rgba(255, 77, 79, 0.1); color: #ff4d4f;
        font-size: 0.65rem; font-weight: 850; padding: 4px 10px; border-radius: 8px;
        text-transform: uppercase; letter-spacing: 0.5px; display: inline-flex; align-items: center; gap: 4px; border: 1px solid rgba(255, 77, 79, 0.1);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    tr:hover {
        background: rgba(255, 45, 133, 0.01) !important;
    }
    tr.pending-creation-row { background: rgba(52, 152, 219, 0.02) !important; border-style: dashed; }
    .badge-pending-primary { background: rgba(52, 152, 219, 0.1); color: #3498db; padding: 0.2rem 0.5rem; border-radius: 6px; font-size: 0.65rem; font-weight: 800; cursor: default; }
    .badge-pending-danger { background: rgba(255, 71, 87, 0.1); color: #FF4757; padding: 0.2rem 0.5rem; border-radius: 6px; font-size: 0.65rem; font-weight: 800; cursor: default; }
</style>

@code {
    private List<PoiImage>? images;
    private List<PoiImagePendingChange>? pendingImages;
    private List<Poi> pois = new();
    private string activeTab = "all";
    private int selectedPoiId = 0;
    private bool isAdmin = false;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (AuthStateTask != null)
            {
                var authState = await AuthStateTask;
                var user = authState.User;
                isAdmin = user.IsInRole("admin");

                if (isAdmin)
                {
                    images = await PoiImageService.GetAllImagesAsync();
                    pois = await PoiService.GetAllPoisAsync();
                    pendingImages = await PendingChangeService.GetPendingChangesAsync();
                }
                else if (user.IsInRole("CNH"))
                {
                    var userIdStr = user.FindFirst(c => c.Type == "sub" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    if (int.TryParse(userIdStr, out var userId))
                    {
                        images = await PoiImageService.GetImagesByOwnerAsync(userId);
                        pois = await PoiService.GetPoisByOwnerAsync(userId);
                        pendingImages = await PendingChangeService.GetChangesByUserIdAsync(userId);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading images: {ex.Message}");
            images = new List<PoiImage>();
        }
    }

    private IEnumerable<PoiImage> GetFilteredImages()
    {
        if (images == null) return Enumerable.Empty<PoiImage>();

        return activeTab switch
        {
            "all" => images,
            "by-poi" => selectedPoiId == 0 ? images.Where(i => i.PoiId != null) : images.Where(i => i.PoiId == selectedPoiId),
            _ => images
        };
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    private void OnPoiFilterChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            selectedPoiId = id;
        }
    }

    private void AddNew() => Navigator.NavigateTo("/images/add");
    private void Edit(int id) => Navigator.NavigateTo($"/images/edit/{id}");
    
    private async Task Delete(int id) {
        var authState = await AuthStateTask!;
        var user = authState.User;
        
        string msg = user.IsInRole("admin") 
            ? "Bạn có chắc chắn muốn xóa hình ảnh này không? File thực tế cũng sẽ bị xóa."
            : "Bạn có chắc chắn muốn gửi yêu cầu XÓA hình ảnh này? Ảnh sẽ bị gỡ sau khi Admin phê duyệt.";

        var confirmed = await JS.InvokeAsync<bool>("confirm", msg);
        if (confirmed)
        {
            if (await PoiImageService.DeleteImageAsync(id))
            {
                if (user.IsInRole("CNH"))
                {
                    await JS.InvokeVoidAsync("alert", "Yêu cầu xóa ảnh đã được gửi. Ảnh sẽ biến mất sau khi được Admin phê duyệt.");
                }
                else
                {
                    images = images?.Where(img => img.ImageId != id).ToList();
                }
                StateHasChanged();
            }
        }
    }
}
