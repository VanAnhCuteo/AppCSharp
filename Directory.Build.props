<Project>
  <PropertyGroup>
    <!-- Use static graph evaluation for faster NuGet restores -->
    <RestoreUseStaticGraphEvaluation>true</RestoreUseStaticGraphEvaluation>
    
    <!-- Enable VS build acceleration (VS 2022 17.5+) -->
    <AccelerateBuildsInVisualStudio>true</AccelerateBuildsInVisualStudio>
    
    <!-- Optimize copy operations -->
    <CopyRetryCount>3</CopyRetryCount>
    <CopyRetryDelayMilliseconds>500</CopyRetryDelayMilliseconds>

    <!-- Global default for IncludeWindowsTarget -->
    <IncludeWindowsTarget Condition="'$(IncludeWindowsTarget)' == ''">false</IncludeWindowsTarget>
  </PropertyGroup>
</Project>
